        ["ui"] = new Mapping {
          ["hidden"] = true
          ["label"] = "Secret Path/Name in Secret Manager"
          ["placeholder"] = "Enter Secret Path/Name"
          ["help"] = "The secret path or name of the stored secret in the secret manager"
          ["grid"] = 4
          ["rules"] = new Listing {
            requiredRule("Please enter the secret path")
          }
        }
      }
      new Mapping {
        ["filter"] = new Mapping {
          ["\(agentSelectorProperty).agent-type"] = newAppFrameworkAgentType
          ["\(agentSelectorProperty).key-type"] = "multi-key"
        }
        ["ui"] = new Mapping {
          ["hidden"] = false
          ["label"] = "Secret Path/Name in Secret Manager"
          ["placeholder"] = "Enter Secret Path/Name"
          ["help"] = "The secret path or name of the stored secret in the secret manager"
          ["grid"] = 4
          ["rules"] = new Listing {
            requiredRule("Please enter the secret path")
          }
        }
      }
    }
    ["ui"] = new Mapping {
      ["label"] = "Secret Path/Name in Secret Manager"
      ["placeholder"] = "Enter Secret Path/Name"
      ["help"] = "The secret path or name of the stored secret in the secret manager"
      ["hidden"] = false
      ["grid"] = 4
      ["rules"] = new Listing {
        requiredRule("Please enter the secret path")
