        ["ui"] = new Mapping {
          ["widget"] = "select"
          ["label"] = "Secret Store"
          ["placeholder"] = "Secret Store"
          ["hidden"] = false
          ["rules"] = new Listing {
            requiredRule("Please select the secret store")
