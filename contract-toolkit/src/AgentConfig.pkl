/// Contract for the shared secure-agent connector configmap.
///
/// Apps can import and amend this module when they need to generate
/// `atlan-connectors-agent.json` themselves. Native app contracts do not emit
/// it automatically because it is a shared/global configmap by default.
@ModuleInfo { minPklVersion = "0.25.1" }
open module com.atlan.app.contract.AgentConfig

/// Configmap name served by the SDK / Heracles configmap route.
name: String = "atlan-connectors-agent"

/// Workflow form field that contains the AgentSelector value. Conditions in
/// this configmap reference nested values under this property.
agentSelectorProperty: String = "agent-json"

/// Agent type value used by the new app framework agent.
newAppFrameworkAgentType: String = "new-app-framework"

/// Docs URL used by the help banners.
docsUrl: String = "https://ask.atlan.com/"

/// Secret-store options shown in the secure-agent config.
secretManagerValues: Listing<String> = new Listing {
  "awssecretmanager"
  "azurekeyvault"
  "gcpsecretmanager"
  "secretinjectionenvironment"
  "kubernetes"
  "custom"
}

secretManagerLabels: Listing<String> = new Listing {
  "AWS Secret Manager"
  "Azure Key Vault"
  "GCP Secret Manager"
  "Environment Variable based Injection"
  "Kubernetes Secret"
  "Custom"
}

