awsAuthMethodValues: Listing<String> = new Listing {
  "iam"
  "iam-assume-role"
  "access-key"
}

awsAuthMethodLabels: Listing<String> = new Listing {
  "IAM"
  "IAM Assume Role"
  "Access Key and Secret Key"
}

azureAuthMethodValues: Listing<String> = new Listing {
  "managed_identity"
  "service_principal"
}

azureAuthMethodLabels: Listing<String> = new Listing {
  "Managed Identity"
  "Service Principal"
}

keyTypeValues: Listing<String> = new Listing {
  "multi-key"
  "single-key"
}

keyTypeLabels: Listing<String> = new Listing {
  "Multi Key"
  "Single Key"
}

/// Deep patches merged into `baseProperties`. Use this for app-specific
/// changes without copying the whole secure-agent contract:
///
/// ```pkl
/// propertyOverrides {
///   ["secret-path"] {
///     ["ui"] {
///       ["label"] = "Secret name"
///       ["placeholder"] = "Enter secret name"
///     }
///   }
/// }
/// ```
propertyOverrides: Mapping<String, Any> = new Mapping {}

/// Extra fields to append to the secure-agent config.
extraProperties: Mapping<String, Any> = new Mapping {}

/// Extra `anyOf` branches to append to the default conditional requirements.
extraAnyOf: Listing<Any> = new Listing {}

/// Top-level custom metadata to append to the generated config payload.
extraConfig: Mapping<String, Any> = new Mapping {}

function asMapping(value: Any): Mapping<String, Any>? =
  if (value is Mapping<String, Any>)
    value as Mapping<String, Any>
  else if (value is Dynamic)
    new Mapping {
      for (key, member in (value as Dynamic).toMap()) {
        [key] = member
      }
    }
  else null

function deepMerge(base: Any, patch: Any): Any =
  let (baseMap = asMapping(base))
  let (patchMap = asMapping(patch))
  if (baseMap != null && patchMap != null)
    deepMergeMapping(baseMap!!, patchMap!!)
  else patch

function deepMergeMapping(base: Mapping<String, Any>, patch: Mapping<String, Any>): Mapping<String, Any> =
  new Mapping {
    for (key, value in base) {
      [key] = if (patch.containsKey(key)) deepMerge(value, patch[key]) else value
    }
    for (key, value in patch) {
      when (!base.containsKey(key)) {
        [key] = value
      }
    }
  }

local function requiredRule(message: String): Mapping<String, Any> = new Mapping {
  ["required"] = true
  ["message"] = message
}

local function hiddenForNewAppFramework(): Mapping<String, Any> = new Mapping {
  ["property"] = "\(agentSelectorProperty).agent-type"
  ["value"] = newAppFrameworkAgentType
  ["ui"] = new Mapping {
    ["hidden"] = true
  }
}

local function hiddenWidgetForNewAppFramework(widget: String): Mapping<String, Any> = new Mapping {
  ["property"] = "\(agentSelectorProperty).agent-type"
  ["value"] = newAppFrameworkAgentType
  ["ui"] = new Mapping {
    ["widget"] = widget
    ["hidden"] = true
  }
}

local function banner(prefixText: String): Mapping<String, Any> = new Mapping {
  ["type"] = "conditional"
  ["conditions"] = new Listing {
    hiddenWidgetForNewAppFramework("Banner")
  }
  ["ui"] = new Mapping {
    ["widget"] = "Banner"
    ["hidden"] = false
    ["category"] = "info"
    ["prefixText"] = prefixText
    ["link"] = new Mapping {
      ["label"] = "View docs"
      ["url"] = docsUrl
    }
  }
}

baseProperties: Mapping<String, Any> = new Mapping {
  ["divider"] = new Mapping {
    ["ui"] = new Mapping {
      ["widget"] = "divider"
      ["class"] = "mt-0"
    }
  }
  ["header"] = new Mapping {
    ["ui"] = new Mapping {
      ["widget"] = "header"
      ["label"] = "Secure Agent Configuration"
      ["class"] = "mb-4 text-base text-new-gray-500"
    }
