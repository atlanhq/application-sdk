properties: Mapping<String, Any> =
  deepMergeMapping(deepMergeMapping(baseProperties, extraProperties), propertyOverrides)

defaultAnyOf: Listing<Any> = new Listing {
  new Mapping {
    ["properties"] = new Mapping {
      ["secret-manager"] = new Mapping {
        ["const"] = "awssecretmanager"
      }
    }
    ["required"] = new Listing {
      "aws-auth-method"
      "aws-region"
      "secret-path"
      "aws-secret-manager-help-text"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["aws-auth-method"] = new Mapping {
        ["const"] = "iam-assume-role"
      }
      ["secret-manager"] = new Mapping {
        ["const"] = "awssecretmanager"
      }
    }
    ["required"] = new Listing {
      "aws-assume-role-arn"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["secret-manager"] = new Mapping {
        ["const"] = "azurekeyvault"
      }
    }
    ["required"] = new Listing {
      "azure-auth-method"
      "azure-vault-name"
      "azure-help-text"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["secret-manager"] = new Mapping {
        ["const"] = "secretinjectionenvironment"
      }
    }
    ["required"] = new Listing {
      "secret-injection-help-text"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["secret-manager"] = new Mapping {
        ["const"] = "kubernetes"
      }
    }
    ["required"] = new Listing {
      "secret-path"
      "kubernetes-secret-help-text"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["secret-manager"] = new Mapping {
        ["const"] = "gcpsecretmanager"
      }
    }
    ["required"] = new Listing {
      "gcp-help-text"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["secret-manager"] = new Mapping {
        ["const"] = "custom"
      }
    }
    ["required"] = new Listing {
      "agent-custom-config"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["agent-type"] = new Mapping {
        ["const"] = newAppFrameworkAgentType
      }
    }
    ["required"] = new Listing {
      "key-type"
    }
  }
  new Mapping {
    ["properties"] = new Mapping {
      ["agent-type"] = new Mapping {
        ["const"] = newAppFrameworkAgentType
      }
      ["key-type"] = new Mapping {
        ["const"] = "multi-key"
      }
    }
    ["required"] = new Listing {
      "secret-path"
    }
  }
}

anyOf: Listing<Any> = new Listing {
  for (entry in defaultAnyOf) {
    entry
  }
  for (entry in extraAnyOf) {
    entry
  }
}

config: Mapping<String, Any> = new Mapping {
  ["properties"] = properties
  ["anyOf"] = anyOf
  ...extraConfig
}

configFile: FileOutput = new FileOutput {
  value = config
  renderer = new JsonRenderer {}
}

output: ModuleOutput = new ModuleOutput {
  files {
    ["\(name).json"] = configFile
  }
}
