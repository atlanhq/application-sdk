/// Deployment configuration classes for native Atlan apps.
///
/// This module is imported by `App.pkl` and re-exported to amending contracts
/// so apps write `new DeployConfig {}`, `new KedaConfig {}`, `new DaprComponents {}`
/// etc. without any supplemental import.
@ModuleInfo { minPklVersion = "0.25.1" }
module com.atlan.app.contract.Deployment

/// Dapr component flags. Each boolean controls whether the component sidecar
/// is wired into the app deployment.
class DaprComponents {
  objectstore: Boolean = false
  secretstore: Boolean = false
  statestore: Boolean = false
  eventstore: Boolean = false
  subscription: Boolean = false
  configurationstore: Boolean = false
  lock: Boolean = false
  /// Full-spec Dapr components that can't be expressed as boolean flags
  /// (e.g. pubsub.kafka with custom metadata).
  customComponents: Mapping<String, Any> = new Mapping {}
}

class KedaTemporalConfig {
  /// Only `targetQueueSize` is read by the Helm chart — NOT the top-level
  /// `keda.targetQueueSize`. Always set via this nested path.
  targetQueueSize: Int = 5
}

class KedaConfig {
  enabled: Boolean = true
  minReplicaCount: Int = 0
  /// Seconds KEDA waits after the queue drains before scaling to zero.
  /// Omit to use the Helm chart default.
  /// Use a small value (e.g. 30) for exceptional scale-to-zero pools;
  /// a larger value (e.g. 300) for hot pools where spin-up latency matters.
  cooldownPeriod: Int? = null
  temporal: KedaTemporalConfig = new KedaTemporalConfig {}
}

class ResourceConfig {
  requests: Mapping<String, String> = new Mapping {}
  limits: Mapping<String, String> = new Mapping {}
}

/// Per-pool deployment configuration. Declares the logical profiles this
/// worker pool serves and its scaling/resource settings.
///
/// Simple apps never configure this — the single "default" pool serves all
/// profiles with platform defaults. Multi-pool apps declare named pools:
///
/// ```pkl
/// deployments {
///   ["hot"] = new Deployment {
///     profiles { "main" }
///     keda { minReplicaCount = 1; cooldownPeriod = 300 }
///   }
///   ["cold"] = new Deployment {
///     profiles { "exceptional" }
///     keda { minReplicaCount = 0; cooldownPeriod = 30 }
///     resources = new ResourceConfig { requests { ["cpu"] = "100m" } }
///   }
/// }
/// ```
class Deployment {
  /// Logical profiles this worker pool serves.
  /// Empty (default) → pool serves the app's default profile at render time.
  /// Corresponds to `@task(profile="…")` in Python app code.
  profiles: Listing<String> = new Listing {}

  /// Override replica count. Ignored when `keda.enabled = true`.
  replicaCount: Int? = null

  keda: KedaConfig = new KedaConfig {}
  resources: ResourceConfig? = null
  env: Mapping<String, String> = new Mapping {}
  envOverrides: Mapping<String, Mapping<String, String>> = new Mapping {}

  /// Per-pool escape hatch for `atlan.yaml` keys not yet modelled above.
  /// Deep-merged on top of the rendered pool block last.
  deployOverrides: Mapping<String, Any> = new Mapping {}
}

/// Typed deployment configuration rendered into `atlan.yaml`'s `deploy:` block.
/// @Deprecated — use `deployments` instead. Will be removed in the next minor version.
class DeployConfig {
  executionMode: String = "native"
  splitDeployment: Boolean = true
  /// Ignored when keda.enabled = true (KEDA manages replica count).
  replicaCount: Int? = null
  dapr: DaprComponents = new DaprComponents {}
  keda: KedaConfig = new KedaConfig {}
  resources: ResourceConfig? = null
  env: Mapping<String, String> = new Mapping {}
  envOverrides: Mapping<String, Mapping<String, String>> = new Mapping {}
}
