/// Widget that renders a switch/toggle with optional toast feedback.
class Switcher extends UIElement {
  fixed type = "boolean"
  required: Boolean? = false

  hidden switchTitle: String = title

  hidden defaultSelection: Boolean = false

  hidden begin: Int?

  hidden toastConfig: Mapping<String, String>?

  fixed default = defaultSelection

  fixed ui {
    widget = "switcher"
    title = outer.switchTitle
    start = begin
    toast = outer.toastConfig
  }
}

/// Widget that renders a preflight / health check against the connector.
class Sage extends UIElement {
  fixed type = "string"
  required: Boolean? = false

  hidden checks: Listing<Dynamic>?

  hidden connectorConfig: String?

  hidden selectedCredentialGuid: String?

  fixed ui {
    widget = "sage"
    config = checks
    connectorConfigName = connectorConfig
    selectedConnectionCredentialGuidProperty = selectedCredentialGuid
  }
}

/// Widget that renders a v2 preflight / health check against the connector.
class SageV2 extends UIElement {
  fixed type = "string"
  required: Boolean? = false

