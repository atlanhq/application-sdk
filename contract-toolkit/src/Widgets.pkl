/// Widget that renders an SQL-driven metadata tree for browsing database objects.
class SqlTree extends UIElement {
  fixed type = "object"
  required: Boolean? = false

  hidden credentialType: String?

  hidden sqlQuery: String?

  hidden excludePatterns: List<String>?

  hidden databaseExcludePatterns: List<String>?

  hidden desc: String?

  hidden multiSelect: Boolean?

  hidden cred: String = "credential-guid"

  hidden dependsOn: String?

  hidden databasesUnselectable: Boolean?

  hidden additionalPropertiesToIncludeInCredentialBody: Listing<String>?

  hidden validationRules: Listing<ValidationRule>?

  hidden includeDefault: Boolean = true

  fixed additionalProperties = new Mapping {
    ["type"] = "array"
  }.toMap()

  fixed default: String? = if (includeDefault) "{}" else null

  fixed ui {
    widget = "sqltree"
    sql = sqlQuery
    credential = cred
    connectorConfigName = credentialType
    schemaExcludePattern = excludePatterns
    databaseExcludePattern = databaseExcludePatterns
    description = desc
    multiple = multiSelect
    dependentConnectionField = dependsOn
    areDatabasesUnselectable = databasesUnselectable
    additionalPropertiesToIncludeInCredentialBody = outer.additionalPropertiesToIncludeInCredentialBody
    rules = validationRules
  }
}

/// Widget that conditionally changes its rendering based on form state or feature flags.
class ConditionalInput extends UIElement {
  fixed type = "conditional"
  required: Boolean? = false

  hidden baseWidgetType: String = "radio"

  hidden baseEnum: Listing<String>?

  hidden baseEnumNames: Listing<String>?

  default: Any?

  conditions: Listing<Condition>?

  additionalProperties: Dynamic?

  hidden placeholderText: String?

  hidden validationRules: Listing<ValidationRule>?

  hidden outputValueType: String = if (baseWidgetType == "sqltree" || baseWidgetType == "apitree" || baseWidgetType == "apiTreeSelect" || baseWidgetType == "dsnTreeMap") "object" else "string"

  hidden uiType: String?

  hidden content: String?

  hidden iconName: String?

  hidden hideWidgetIcon: Boolean?

  hidden linkConfig: Any?

  hidden widgetConfig: Any?

  hidden checks: Listing<Dynamic>?

  hidden sqlQuery: String?

  hidden credentialRef: String?

  hidden connectorConfig: String?

  hidden schemaExcludePatterns: List<String>?

  hidden databaseExcludePatterns: List<String>?

  hidden desc: String?

  hidden multiSelect: Boolean?

  hidden dependsOn: String?

  hidden databasesUnselectable: Boolean?

  hidden connOptions: Boolean?

  hidden credentialType: String?

  hidden allowTestAuthentication: Boolean?

  hidden authTypeVsLabel: Mapping<String, String>?

  hidden hiddenFields: Listing<String>?

  hidden additionalDisplayFields: Listing<Dynamic>?

  fixed enum: List<String>? = if (baseEnum != null) baseEnum.toList() else null

  fixed enumNames: List<String>? = if (baseEnumNames != null) baseEnumNames.toList() else null

  fixed ui {
    widget = baseWidgetType
    placeholder = placeholderText
    rules = validationRules
    config = if (widgetConfig != null) widgetConfig else checks
    type = outer.uiType
    content = outer.content
    icon = outer.iconName
    hideIcon = outer.hideWidgetIcon
    link = outer.linkConfig
    sql = sqlQuery
    credential = credentialRef
    connectorConfigName = connectorConfig
    schemaExcludePattern = schemaExcludePatterns
    databaseExcludePattern = databaseExcludePatterns
    description = desc
    multiple = multiSelect
    dependentConnectionField = dependsOn
    areDatabasesUnselectable = databasesUnselectable
    connectionOptions = connOptions
    credentialType = outer.credentialType
    isTestAuthenticationDisabled = if (allowTestAuthentication != null) !allowTestAuthentication else null
    authTypeVsLabel = outer.authTypeVsLabel
    hiddenFields = outer.hiddenFields
    additionalDisplayFields = outer.additionalDisplayFields
  }
}

/// A condition that overrides rendering when a form property, lab flag, or feature flag matches.
class Condition {
  property: String?

  value: Any?

  labFlag: String?

  featureFlag: String?

  filter: Dynamic?

  hidden overrideEnum: Listing<String>?

  hidden overrideEnumNames: Listing<String>?

  hidden overrideRequired: Boolean?

  hidden overrideDefault: Any?

  hidden overrideType: String?

  hidden overrideUi: (Widget|Mapping<String, Any>)? = null

  fixed enum: List<String>? = if (overrideEnum != null) overrideEnum.toList() else null

  fixed enumNames: List<String>? = if (overrideEnumNames != null) overrideEnumNames.toList() else null

  fixed required: Boolean? = overrideRequired

  fixed default: Any? = overrideDefault

  fixed type: String? = overrideType

  fixed ui: (Widget|Mapping<String, Any>)? = overrideUi
}

/// Widget that renders a repeatable list of text input fields for entering multiple string values.
class InputRepeater extends UIElement {
  fixed type = "object"
  required: Boolean? = false

  hidden placeholderText: String = ""

  hidden validationRules: Listing<ValidationRule>?

  fixed ui {
    widget = "inputRepeater"
    placeholder = placeholderText
    rules = validationRules
  }
}

/// Create an `evaluate` widget override for use inside `Condition.overrideUi`.
const function evaluateWidget(val: String): Widget = new Widget {
  widget = "evaluate"
  value = val
}

/// Widget that renders a cron schedule picker.
class Schedule extends UIElement {
  fixed type = "string"
  required: Boolean? = false

  fixed ui {
    widget = "schedule"
  }
}

/// Escape hatch for bespoke frontend widgets not covered by the typed widget catalog.
class CustomWidget extends UIElement {
  hidden valueType: String = "string"
  fixed type = valueType
  required: Boolean? = false

  hidden widgetName: String

  hidden props: Mapping<String, Any>?

  fixed ui: Mapping<String, Any> = new Mapping {
    ["widget"] = widgetName
    when (props != null) {
      for (k, v in props!!) {
        [k] = v
      }
    }
  }
}
