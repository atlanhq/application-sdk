class InfoBanner extends UIElement {
  fixed type = "string"
  required: Boolean? = false

  hidden widgetName: String = "infoBanner"

  hidden content: String

  hidden bannerType: InfoBannerType = "info"

  hidden iconName: String?

  hidden hideBannerIcon: Boolean?

  hidden linkConfig: (WidgetLink|Mapping<String, String>)? = null

  hidden includeInManifest: Boolean = false
  hidden includeInInput: Boolean = false

  fixed ui {
    widget = widgetName
    type = bannerType
    content = outer.content
    icon = outer.iconName
    hideIcon = outer.hideBannerIcon
    link = outer.linkConfig
  }
}

