/// Consolidated template for Atlan native apps (v0.10.0+).
///
/// One `amends` line is all a consuming app needs:
///
/// ```pkl
/// amends "@app-contract-toolkit/App.pkl"
/// ```
///
/// All widget types are accessible as `Widgets.*` (e.g. `Widgets.TextInput`,
/// `Widgets.Radio`) without any supplemental `import` in the amending file.
/// Connector constants are accessible as `Connectors.*`.
///
/// **Single-entrypoint apps** (the common case): set `uiConfig`, `pipeline`,
/// and optionally `deploy`, then run:
///
///   `pkl eval -m . contract/app.pkl`
///
/// from the repo root. PKL writes every generated file to its final location:
/// `atlan.yaml`, `app.yaml`, `app/generated/manifest.json`,
/// `app/generated/_input.py`, etc.
///
/// **Multi-entrypoint apps**: set `entrypoints` with `contract` references on
/// each `Entrypoint`. The bundle-level file owns `atlan.yaml`/`app.yaml` and
/// re-exports per-entrypoint artifacts into `app/generated/{name}/`.
@ModuleInfo { minPklVersion = "0.25.1" }
open module com.atlan.app.contract.App

import "Connectors.pkl"
import "Widgets.pkl"

// ── WIDGET TYPE RE-EXPORTS ────────────────────────────────────────────────────
// Typealiases so amending contracts write `new UIConfig { }`, `new TextInput { }`, etc.
// without needing a supplemental `import "@app-contract-toolkit/Widgets.pkl"`.

typealias InfoBannerType = Widgets.InfoBannerType
typealias WidgetLink = Widgets.WidgetLink
typealias UIConfig = Widgets.UIConfig
typealias UIStep = Widgets.UIStep
typealias UIRule = Widgets.UIRule
typealias UIElement = Widgets.UIElement
typealias UIElementWithEnum = Widgets.UIElementWithEnum
typealias Widget = Widgets.Widget
typealias TextInput = Widgets.TextInput
typealias TextBoxInput = Widgets.TextBoxInput
typealias Radio = Widgets.Radio
typealias ConnectionCreator = Widgets.ConnectionCreator
typealias ConnectionSelector = Widgets.ConnectionSelector
typealias ConnectionRefInput = Widgets.ConnectionRefInput
typealias FileUploader = Widgets.FileUploader
typealias FileCopier = Widgets.FileCopier
typealias NumericInput = Widgets.NumericInput
typealias DateInput = Widgets.DateInput
typealias BooleanInput = Widgets.BooleanInput
typealias DropDown = Widgets.DropDown
typealias TagsInput = Widgets.TagsInput
typealias MultipleGroups = Widgets.MultipleGroups
typealias SingleGroup = Widgets.SingleGroup
typealias MultipleUsers = Widgets.MultipleUsers
typealias SingleUser = Widgets.SingleUser
typealias ConnectorTypeSelector = Widgets.ConnectorTypeSelector
typealias APITokenSelector = Widgets.APITokenSelector
typealias KeygenInput = Widgets.KeygenInput
typealias PasswordInput = Widgets.PasswordInput
typealias CredentialInput = Widgets.CredentialInput
typealias NestedInput = Widgets.NestedInput
typealias SQLExecutor = Widgets.SQLExecutor
typealias APITree = Widgets.APITree
typealias ApiTreeSelect = Widgets.ApiTreeSelect
typealias InfoBanner = Widgets.InfoBanner
typealias DsnTreeMap = Widgets.DsnTreeMap
typealias GlossarySelector = Widgets.GlossarySelector
typealias Switcher = Widgets.Switcher
typealias Sage = Widgets.Sage
typealias SageV2 = Widgets.SageV2
typealias CloudProvider = Widgets.CloudProvider
typealias AgentSelector = Widgets.AgentSelector
typealias SqlTree = Widgets.SqlTree
typealias ConditionalInput = Widgets.ConditionalInput
typealias Condition = Widgets.Condition
typealias InputRepeater = Widgets.InputRepeater
typealias Schedule = Widgets.Schedule
typealias CustomWidget = Widgets.CustomWidget

// ── CONSTRAINED TYPES ────────────────────────────────────────────────────────

/// Lowercase kebab-case string: `[a-z][a-z0-9]*(-[a-z0-9]+)*`.
/// Used for identifiers that flow into file names, queue names, and manifest keys.
typealias KebabCase = String(matches(Regex("[a-z][a-z0-9]*(-[a-z0-9]+)*")))

// ── APP METADATA ──────────────────────────────────────────────────────────────

/// Unique identifier for this app (e.g., "redshift", "trino", "postgres").
/// Used to derive configmap names, task queues, and file names.
/// Must be lowercase kebab-case: `[a-z][a-z0-9]*(-[a-z0-9]+)*`.
name: KebabCase

/// Human-readable display name for the app.
displayName: String = name.capitalize()

/// Connector type from the Connectors registry.
/// Required only when a credential configmap is emitted (`hasCredentialConfig = true`).
/// Apps without credentials (e.g. utility apps) can omit this.
connector: Connectors.Type? = null

/// Icon URL for the app.
icon: String

/// Link to documentation.
docsUrl: String = ""

/// Logo URL (defaults to icon).
logo: String = icon

/// Helpdesk link for credential configuration.
helpdeskLink: String = ""

// ── BUNDLE / MARKETPLACE METADATA ────────────────────────────────────────────

/// Global Marketplace UUID.
appId: String = ""

/// Owning organization. Omitted when null.
creatorOrg: String?

/// Marketplace app type (`connector`, `miner`, `utility`, `system`, ...).
type: String = "connector"

/// Marketplace icon URL. Defaults to the app `icon` when not set.
iconUrl: String? = icon

/// Marketplace visibility.
visibility: String = "public"

/// Marketplace build tag.
buildTag: String = "v1"

/// Whether images are published for self-deployed runtime.
selfDeployedRuntime: Boolean = true

/// Extra top-level metadata fields for atlan.yaml.
metadata: Mapping<String, Any> = new Mapping {}

/// Deep overrides applied to the rendered `atlan.yaml` after typed fields.
atlanYamlOverrides: Mapping<String, Any> = new Mapping {}

/// Whether to emit `atlan.yaml` in the output.
emitAtlanYaml: Boolean = true

/// Whether to emit the `entrypoints:` block into `atlan.yaml`.
emitEntrypoints: Boolean = true

/// Whether to emit `app.yaml` in the output.
emitAppYaml: Boolean = true

/// Whether to re-export entrypoint contract artifacts in multi-entrypoint mode.
emitGeneratedArtifacts: Boolean = true

// ── WORKFLOW TYPE ────────────────────────────────────────────────────────────

/// Temporal workflow type written to `manifest.json` as `workflow_type` (in kebab-case).
/// Accepts PascalCase (e.g. `"SnowflakeApp"`) or kebab-case (e.g. `"snowflake-app"`)
/// — the toolkit converts either form to kebab-case at output time.
/// Defaults to `name`. Also accepts colon-format identifiers (e.g. `"dbt:extract-metadata"`),
/// which pass through the conversion unchanged.
workflowType: String = name

/// Task queue prefix for the extract node in the AE manifest.
taskQueuePrefix: String = "atlan-\(name)"

// ── E2E TEST HARNESS ──────────────────────────────────────────────────────────

/// Argo WorkflowTemplate package name used by the e2e test harness.
/// Default: `"@atlan/<name>"`. Override for apps with scoped or non-standard package names.
argoPackageName: String = "@atlan/\(name)"

/// Argo WorkflowTemplate resource name as deployed in the cluster.
/// Default: `"atlan-<name>"` — same pattern as `taskQueuePrefix`.
argoTemplateName: String = "atlan-\(name)"

/// In-cluster HTTP URL for the app's Dapr service; used by the e2e harness to
/// forward AE workflow calls to the running app.
/// Default: `"http://<name>.<name>-app.svc.cluster.local"`.
appServiceUrl: String = "http://\(name).\(name)-app.svc.cluster.local"

// ── CREDENTIAL CONFIG ─────────────────────────────────────────────────────────

/// Whether this app has a credential config.
hasCredentialConfig: Boolean = true

/// Name for the credential configmap (e.g., "atlan-connectors-redshift").
connectorConfigName: String = "atlan-connectors-\(name)"

/// Default connector type for credentials (e.g., "jdbc", "rest").
credentialConnectorType: String = "rest"

/// Fields shared across all auth types.
credentialCommonFields: Listing<CredentialFieldEntry> = new Listing {}

/// Additional fields nested under a shared top-level `extra` object in the credential payload.
credentialSharedExtraFields: Listing<CredentialFieldEntry> = new Listing {}

/// Auth type options. Each key becomes a radio option.
credentialAuthOptions: Mapping<String, AuthOption>?

/// Opt-in JDBC Host↔URL credential form.
credentialUrlGroup: AdvancedJDBCUrlGroup?

/// Label for the auth-type radio button.
credentialAuthTitle: String = "Authentication"

/// Default auth type selected in the credential auth radio.
credentialAuthDefault: String?

/// Validation rules for the auth-type radio button.
credentialAuthRules: Listing<Dynamic>?

/// Placeholder text for the auth-type radio button.
credentialAuthPlaceholder: String?

/// Help text under the auth-type radio button.
credentialAuthHelp: String?

/// Grid width for the auth-type radio button.
credentialAuthWidth: Int?

/// Auth-type options hidden during credential creation.
credentialAuthHiddenEnumListForCreating: Listing<String>?

/// Placeholder for the hidden credential `name` field.
credentialNamePlaceholder: String = "Host Name"

/// Optional default for the hidden credential `connector` field.
credentialConnectorDefault: String?

/// Field name for the app's credential reference in the generated Input class.
credentialFieldName: String? = if (hasCredentialConfig) "\(name.replaceAll("-", "_"))_credential" else null

// ── WORKFLOW / UI CONFIG ──────────────────────────────────────────────────────

/// The workflow configmap name (e.g., "redshift").
workflowConfigName: String = name

/// UI configuration for the workflow setup form.
/// Required for single-entrypoint apps (when `entrypoints` is empty).
uiConfig: Widgets.UIConfig?

// ── MANIFEST CONFIG ───────────────────────────────────────────────────────────

/// Additional DAG nodes beyond the pipeline.
/// If key "publish" is defined here, it replaces the auto-generated publish node.
/// If key "notifications" is defined here, it replaces the auto-generated
/// completion notification node.
extraNodes: Mapping<String, DAGNode> = new Mapping {}

/// Top-level on/off for app notifications.
///
/// When `true`, appends a run-level notification node (`NotificationNode`, key
/// `notifications`) that fires once when the workflow run reaches any
/// terminal state (success or failure) and dispatches the notification app to
/// fan alerts out to the tenant's enabled integrations (Teams, etc.). The
/// notification app decides delivery per integration via its
/// `alertsWorkflowChannel.failureOnly` config (failure-only vs. all runs) — so
/// this flag is purely the broad app-level switch; *which* runs and *which*
/// channels are the customer's call.
///
/// Default `false`, so apps must explicitly opt in with `notifications = true`
/// before the generated manifest includes the notification node. Override the
/// node by defining `extraNodes["notifications"]`, which suppresses the
/// toolkit-generated node.
notifications: Boolean = false

/// Mapping of manifest arg name → form field name for top-level extract args.
manifestTopLevelArgs: Mapping<String, String> = new Mapping {
  ["credential_guid"] = "credential-guid"
  ["connection"] = "connection"
}

// ── PIPELINE ─────────────────────────────────────────────────────────────────

/// Typed orchestration pipeline for the AE manifest.
///
/// Five canonical steps in fixed order:
///   extract → parseQueries → popularity → lineage → publish
///
/// `extract` and `publish` are **default-on** (opt out by setting to `null`).
/// `parseQueries`, `popularity`, and `lineage` are **default-off** (opt in).
///
/// Example — opt out of publish:
/// ```pkl
/// pipeline {
///   publish = null
/// }
/// ```
/// Example — opt in to query parsing:
/// ```pkl
/// pipeline {
///   parseQueries = new ParseQueriesStep {
///     sqlKey = "QUERY_TEXT"
///     vendorName = "snowflake"
///   }
/// }
/// ```
pipeline: Pipeline = new Pipeline {}

// ── DEPLOY CONFIG ─────────────────────────────────────────────────────────────

/// Typed deployment configuration rendered into `atlan.yaml`'s `deploy:` block.
deploy: DeployConfig = new DeployConfig {}

/// Deep-merged on top of the rendered `deploy` block last.
/// Use this for marketplace keys the toolkit does not yet model (VPA, canary,
/// extraVolumes, securityContext, appExternalResources, etc.).
deployOverrides: Mapping<String, Any> = new Mapping {}

// ── ENTRYPOINTS ──────────────────────────────────────────────────────────────

/// One marketplace card / SDK entrypoint under the deployed app.
///
/// Leave empty for single-entrypoint apps — App.pkl synthesises the implicit
/// entrypoint from the bundle-level fields for `atlan.yaml` rendering.
/// Populate for multi-entrypoint apps (e.g. crawler + miner under one service).
entrypoints: Listing<Entrypoint> = new Listing {}

// ────────────────────────────────────────────────────────────────────────────
// CLASSES
// ────────────────────────────────────────────────────────────────────────────

// ── Credential field types ────────────────────────────────────────────────────

/// Supported field types for credential UI generation.
typealias FieldType = "text"|"password"|"textarea"|"select"|"number"|"checkbox"|"url"|"email"|"inputRepeater"|"fileUpload"|"credentialFileInput"

/// A single credential field definition.
class FieldSpec {
  name: String

  displayName: String = name.replaceAll("_", " ").replaceAll("-", " ").capitalize()

  placeholder: String?

  helpText: String?

  required: Boolean = true

  includeRequiredWhenFalse: Boolean = false

  sensitive: Boolean = false

  fieldType: FieldType = "text"

  options: Listing<String>?

  optionLabels: Mapping<String, String>?

  /// File extensions or MIME types accepted by file upload credential fields.
  fileTypes: Listing<String>?

  /// Whether file upload fields return upload metadata JSON.
  fileMetadata: Boolean = true

  /// Whether file upload fields should remove the prior upload before accepting a replacement.
  removeBeforeUpload: Boolean = false

  defaultValue: String?

  validationRegex: String?

  width: Int = 8

  rows: Int?

  isHidden: Boolean = false

  includeUiWidget: Boolean = true

  includeUiLabel: Boolean = true

  includeUiHidden: Boolean = true

  includeUiPlaceholder: Boolean = true

  includeUiGrid: Boolean = true

  uiClass: String?

  uiRequired: Boolean?

  feedback: Boolean?

  message: String?

  validationRules: Listing<Dynamic>?

  byocDisabled: Boolean?
}

/// A credential field whose visibility/label/placeholder is driven by a compound boolean filter.
class ConditionalFieldSpec {
  name: String

  required: Boolean = false

  conditions: Listing<Widgets.Condition>

  additionalProperties: Dynamic?

  defaultValue: Any?
}

/// Wrapper that pairs a `Widgets.UIElement` with an explicit JSON property name.
class NamedWidget {
  name: String

  widget: Widgets.UIElement
}

/// Wrapper for a fully-rendered credential configmap property.
class NamedProperty {
  name: String

  property: Mapping<String, Any>
}

/// Entry type accepted inside credential auth-option field listings.
typealias CredentialFieldEntry = FieldSpec|ConditionalFieldSpec|NamedWidget|NamedProperty

/// An auth type option for the credential form.
open class AuthOption {
  label: String

  fields: Listing<CredentialFieldEntry>

  extraFields: Listing<CredentialFieldEntry> = new Listing {}

  postExtraFields: Listing<CredentialFieldEntry> = new Listing {}

  anyOfRequiredFields: Listing<String> = new Listing {}

  nestedLabel: String = ""

  nestedPlaceholder: String?

  nestedHidden: Boolean = true

  nestedExtraLabel: String = ""

  nestedExtraHeader: String? = "Advanced"
}

// ── JDBC URL credential types ─────────────────────────────────────────────────

abstract class UrlValue {}

class UrlLiteral extends UrlValue {
  value: String
}

class UrlRef extends UrlValue {
  field: String
}

class UrlPartMapping {
  hostname: String?
  port: String?
  pathname: String?
  searchParams: Mapping<String, UrlValue> = new Mapping {}
}

class JDBCUrlAuthOption extends AuthOption {
  urlPartMapping: UrlPartMapping

  extractionModes: Listing<String(this == "direct" || this == "agent")> = new Listing {
    "direct"
    "agent"
  }

  nestedLabel: String

  nestedHidden = true
}

class AdvancedJDBCUrlGroup {
  protocol: String = ""

  urlAddonBefore: String

  connectByDefault: String(this == "host" || this == "url") = "host"

  urlLabel: String = "SQLAlchemy Connection URL"

  urlHelp: String?

  urlPlaceholder: String?

  hostField: FieldSpec

  portField: FieldSpec

  extraFields: Listing<FieldSpec|ConditionalFieldSpec> = new Listing {}

  extraHeader: String = "Advanced"

  connectByLabel: String = "Connect by"

  connectByRules: Listing<Dynamic> = new Listing {
    new Dynamic {
      required = true
      message = "Please select a valid connection method"
    }
  }
}

// ── DAG node types ────────────────────────────────────────────────────────────

/// Explicit Automation Engine dependency condition.
class DependencyCondition {
  nodeId: String?

  /// Tag required on the direct dependency. AE reserves `success` and `failure`;
  /// any other value is treated as a custom tag emitted by the node.
  ///
  /// `workflow_complete` is a reserved *run-level* tag: with no `nodeId`, it marks
  /// a finalizer that AE runs last on any terminal state (success or failure).
  /// Used by the default `NotificationNode`.
  tag: String?

  andConditions: Listing<DependencyCondition>?

  orConditions: Listing<DependencyCondition>?

  hidden _conditionShapeCheck: Any =
    if (nodeId != null && (andConditions != null || orConditions != null))
      throw("DependencyCondition cannot combine nodeId with andConditions/orConditions.")
    else if (andConditions != null && orConditions != null)
      throw("DependencyCondition cannot set both andConditions and orConditions.")
    else if (tag == "workflow_complete" && nodeId == null)
      null // run-level finalizer trigger: a node-less reserved tag is valid
    else if (tag != null && nodeId == null)
      throw("DependencyCondition.tag requires nodeId (except the reserved run-level \"workflow_complete\" tag).")
    else if (nodeId == null && andConditions == null && orConditions == null)
      throw("DependencyCondition requires nodeId, andConditions, or orConditions.")
    else if (andConditions != null && andConditions.length == 0)
      throw("DependencyCondition.andConditions must contain at least one condition.")
    else if (orConditions != null && orConditions.length == 0)
      throw("DependencyCondition.orConditions must contain at least one condition.")
    else null
}

/// A generic node in the Automation Engine DAG.
open class DAGNode {
  nodeType: "activity"|"workflow" = "workflow"

  displayName: String
  workflowType: String
  appName: String = "automation-engine"
  taskQueue: String?
  args: Mapping<String, Any>

  dependsOn: Listing<String>?

  dependsOnCondition: DependencyCondition?

  errorHandling: ErrorHandlingConfig?

  hidden _errorHandlingCheck: Any =
    if (nodeType == "workflow" && errorHandling != null && errorHandling.heartbeatTimeoutSeconds != null)
      throw("errorHandling.heartbeatTimeoutSeconds is not valid for workflow nodes (DAGNode.nodeType == \"workflow\"). "
            + "Set nodeType = \"activity\" or remove heartbeatTimeoutSeconds.")
    else null

  hidden _dependencyConfigCheck: Any =
    if (dependsOn != null && dependsOnCondition != null)
      throw("DAGNode cannot set both dependsOn and dependsOnCondition. Use dependsOn for shorthand or dependsOnCondition for explicit AE conditions.")
    else null
}

/// Error handling / retry / timeout configuration for a DAG node.
class ErrorHandlingConfig {
  initialInterval: Int(this >= 1)?

  backoffCoefficient: Int?

  maximumInterval: Int(this >= 1)?

  maximumAttempts: Int?

  nonRetryableErrorTypes: Listing<String>?

  startToCloseTimeoutSeconds: Int(isBetween(1, 259200))?

  heartbeatTimeoutSeconds: Int(isBetween(1, 3600))?

  hidden _timeoutOrderingCheck: Any =
    if (startToCloseTimeoutSeconds != null && heartbeatTimeoutSeconds != null
        && heartbeatTimeoutSeconds >= startToCloseTimeoutSeconds)
      throw("heartbeatTimeoutSeconds (\(heartbeatTimeoutSeconds)) must be less than "
            + "startToCloseTimeoutSeconds (\(startToCloseTimeoutSeconds)).")
    else null
}

/// Pre-built publish node.
open class PublishNode extends DAGNode {
  hidden upstream: String = "extract"
  executorEnabled: Boolean|String = true
  tagPipelineEnabled: Boolean|String? = null
  tagAttachmentsPrefix: String? = null
  /// Defaults to 72h `startToCloseTimeoutSeconds`. AE's source-code default for
  /// workflow nodes is 2h, which is too tight for any non-trivial publish on a
  /// large tenant. Override on the instance to use a different value.
  errorHandling: ErrorHandlingConfig? = new ErrorHandlingConfig {
    startToCloseTimeoutSeconds = 259200
  }

  /// Whether publish should build and upload the connection-cache index after writing assets.
  ///
  /// When `true`, publish reads the transformed crawl output and builds a SQLite
  /// index mapping every entity in the connection (`typeName` + `qualifiedName` →
  /// metadata), then uploads it as a single file. This index lets other workflows
  /// (miners, BI/dbt lineage builders) resolve asset identifiers by qualified name
  /// without re-crawling the source system.
  ///
  /// Defaults to `false` as the safe base for direct use (e.g. `extraNodes`).
  /// When this node is created via the typed `pipeline.publish` step, the
  /// pipeline injects `true` unless the app contract overrides it explicitly
  /// on `PublishStep.connectionCacheEnabled`. Must be `false` for any publish
  /// node that must not overwrite the shared connection-cache index (e.g. lineage publish).
  connectionCacheEnabled: Boolean = false

  /// App-level gate for the connection-cache activity, paired with `connectionCacheEnabled`.
  ///
  /// Both flags must be `true` for the connection-cache index to be built and
  /// uploaded. Same default and injection semantics as `connectionCacheEnabled`.
  connectionCacheViaAppEnabled: Boolean = false

  /// Whether publish should package and upload the current-state snapshot after writing assets.
  ///
  /// When `true`, publish packages the transformed crawl output into a compressed
  /// archive and uploads it to the current-state path. This snapshot is the
  /// authoritative "what Atlan currently knows about this connection" baseline;
  /// downstream consumers (e.g. the current-state syncer and on-demand asset caches)
  /// read it to get an up-to-date view without re-crawling.
  ///
  /// Defaults to `false` as the safe base for direct use (e.g. `extraNodes`).
  /// When this node is created via the typed `pipeline.publish` step, the
  /// pipeline injects `true` from `PublishStep.currentStateEnabled`.
  currentStateEnabled: Boolean = false

  /// App-level gate for the current-state activity, paired with `currentStateEnabled`.
  ///
  /// Both flags must be `true` for the current-state snapshot to be written.
  /// Same default and injection semantics as `currentStateEnabled`. When `true`
  /// (via `PublishStep`), publish writes to the real current-state path so the
  /// next run can diff against it; when `false`, the snapshot is either skipped
  /// or written to a dry-run path.
  currentStateViaAppEnabled: Boolean = false

  /// Connection entity passed to the publish workflow as `args["connection_entity"]`.
  ///
  /// The full connection entity JSON (typeName + attributes), used for connection
  /// creation. Defaults to the `"{{connection}}"` form placeholder. Set to `null`
  /// to omit the arg entirely — doing so also turns `connectionCreationEnabled`
  /// off (see below), since there is no entity for publish to create from.
  connectionEntity: String? = "{{connection}}"

  /// Whether publish should create the connection (`args["connection_creation_enabled"]`).
  ///
  /// Linked to `connectionEntity`: defaults to `connectionEntity != null`, so a
  /// `null` entity yields `false` (publish targets an existing connection and
  /// creates nothing) and a present entity yields `true`. Override explicitly to
  /// disable creation even when an entity is present.
  connectionCreationEnabled: Boolean = connectionEntity != null

  displayName = "Publish to Atlas"
  workflowType = "PublishWorkflow"
  appName = "publish"
  args {
    ["connection_qualified_name"] = "$.\(upstream).outputs.connection_qualified_name"
    ["transformed_data_prefix"] = "$.\(upstream).outputs.transformed_data_prefix"
    ["publish_state_prefix"] = "$.\(upstream).outputs.publish_state_prefix"
    ["current_state_prefix"] = "$.\(upstream).outputs.current_state_prefix"
    ["connection_creation_enabled"] = connectionCreationEnabled
    ["executor_enabled"] = executorEnabled
    when (connectionEntity != null) { ["connection_entity"] = connectionEntity }
    ["connection_cache_enabled"] = connectionCacheEnabled
    ["connection_cache_via_app_enabled"] = connectionCacheViaAppEnabled
    ["current_state_enabled"] = currentStateEnabled
    ["current_state_via_app_enabled"] = currentStateViaAppEnabled
  }
  dependsOn { upstream }
}

/// Pre-built run-completion notification node (a system app, like PublishNode).
///
/// Dispatches a `NotificationWorkflow` to the notification app, which fans the
/// alert out to the tenant's enabled integrations (Teams, etc.). It is a
/// run-level finalizer: `dependsOnCondition = {tag: "workflow_complete"}` makes
/// Automation Engine run it last on ANY terminal state (success or failure),
/// carrying the real `$.workflow.status`. The notification app then decides
/// delivery per integration via its `alertsWorkflowChannel.failureOnly` config
/// (failure-only vs. all runs) — so the trigger is "on completion" and the
/// failure-vs-all policy lives entirely in the customer's integration config.
///
/// The args template AE's run/failure context (`$.workflow.*`, `$.failure.*`),
/// which AE injects into node input resolution — so the node is self-contained
/// (no app-specific wiring). Gated by the app-level `notifications` toggle;
/// override per app via `extraNodes["notifications"]`.
open class NotificationNode extends DAGNode {
  displayName = "Notify on workflow completion"
  workflowType = "NotificationWorkflow"
  appName = "notification-app"
  dependsOnCondition = new DependencyCondition { tag = "workflow_complete" }
  args {
    ["metadata"] = new Mapping {
      ["notification_type"] = "workflow_completion_alert"
      ["workflow_name"] = "$.workflow.name"
      ["workflow_qualified_name"] = "$.workflow.qualified_name"
      ["workflow_slug"] = "$.workflow.slug"
      ["connector"] = "$.workflow.connector"
      ["status"] = "$.workflow.status"
      ["started_at"] = "$.workflow.started_at"
      ["completed_at"] = "$.workflow.completed_at"
      ["duration_ms"] = "$.workflow.duration_ms"
      ["schedule"] = "$.workflow.schedule"
      ["next_run_time"] = "$.workflow.next_run_time"
      ["last_runs"] = "$.workflow.last_runs"
      ["creator_name"] = "$.workflow.creator_name"
      ["modified_by_name"] = "$.workflow.modified_by_name"
      ["run_details_url"] = "$.workflow.run_url"
      ["workflow_run_guid"] = "$.workflow.run_id"
      ["error_message"] = "$.failure.message"
      ["error_category"] = "$.failure.category"
      ["suggested_action"] = "$.failure.suggested_action"
      ["failed_node_id"] = "$.failure.node_id"
      ["failed_activity"] = "$.failure.activity"
    }
  }
}

/// Pre-built Query Intelligence node.
open class QueryIntelligenceNode extends DAGNode {
  hidden upstream: String = "extract"

  connectionQualifiedName: String = "$.\(upstream).outputs.connection_qualified_name"

  inputPrefix: String = "$.\(upstream).outputs.qi_input_prefix"

  outputPrefix: String = "$.\(upstream).outputs.qi_output_prefix"

  vendorName: String?

  vendorKey: String?

  sqlKey: String

  catalogKey: String = "DATABASE_NAME"

  schemaKey: String = "SCHEMA_NAME"

  /// Deprecated: QI no longer filters records by timestamp. The arg is still
  /// emitted for back-compat but is ignored by the QI app.
  @Deprecated { message = "QI no longer filters records by timestamp; this field is ignored." }
  timestampKey: String = "START_TIME"

  /// `"json"` is the default for new integrations. `"parquet"` remains valid
  /// for legacy miner-style inputs but should not be used by new contracts.
  mineOutputType: "parquet"|"json" = "json"

  /// Deprecated: parsing strategy is tuned internally by QI based on workload.
  /// The arg is still emitted for back-compat but is ignored.
  @Deprecated { message = "Parsing mode is now tuned internally by QI; this field is ignored." }
  parsingMode: "fast"|"fallback"|"schema-aware"|"competitive"|"lorien-only" = "fallback"

  extraFilter: String?

  indirectLineage: Boolean|String? = null

  ignoreOrphans: Boolean|String? = null

  /// Deprecated: all columns/fields are preserved in JSON mode (the default).
  /// The arg is still emitted when set but is ignored by the QI app.
  @Deprecated { message = "All columns/fields are preserved in JSON mode; this field is ignored." }
  columnsToPreserve: String?

  relatedAssetsOutputPrefix: String?

  /// Deprecated: parser artifacts are no longer consumed via this key. The arg
  /// is still emitted when set but is ignored.
  @Deprecated { message = "No longer used by QI." }
  parserArtifactsKey: String?

  connectionCacheKey: String?

  currentStatePrefix: String?

  /// Deprecated: instance name is read from QI app environment variables, not
  /// per-workflow inputs. The arg is still emitted when set but is ignored.
  @Deprecated { message = "Instance name is read from QI app environment, not workflow args; this field is ignored." }
  instanceName: String?

  hidden _qiArgsCheck: Any =
    if (vendorName == null && vendorKey == null)
      throw("QueryIntelligenceNode requires either vendorName or vendorKey.")
    else null

  displayName = "Parse SQL Queries"
  workflowType = "QueryIntelligenceWorkflow"
  appName = "automation-engine"
  taskQueue = "atlan-query-intelligence-{deployment_name}"
  args {
    ["connection_qualified_name"] = connectionQualifiedName
    ["input_prefix"] = inputPrefix
    ["output_prefix"] = outputPrefix
    ["sql_key"] = sqlKey
    ["catalog_key"] = catalogKey
    ["schema_key"] = schemaKey
    ["timestamp_key"] = timestampKey
    ["mine_output_type"] = mineOutputType
    ["parsing_mode"] = parsingMode
    when (vendorName != null) { ["vendor_name"] = vendorName }
    when (vendorKey != null) { ["vendor_key"] = vendorKey }
    when (extraFilter != null) { ["extra_filter"] = extraFilter }
    when (indirectLineage != null) { ["indirect_lineage"] = indirectLineage }
    when (ignoreOrphans != null) { ["ignore_orphans"] = ignoreOrphans }
    when (columnsToPreserve != null) { ["columns_to_preserve"] = columnsToPreserve }
    when (relatedAssetsOutputPrefix != null) { ["related_assets_output_prefix"] = relatedAssetsOutputPrefix }
    when (parserArtifactsKey != null) { ["parser_artifacts_key"] = parserArtifactsKey }
    when (connectionCacheKey != null) { ["connection_cache_key"] = connectionCacheKey }
    when (currentStatePrefix != null) { ["current_state_prefix"] = currentStatePrefix }
    when (instanceName != null) { ["instance_name"] = instanceName }
  }
  dependsOn { upstream }
}

/// Source-specific column mapping for `PopularityNode`.
class PopularityMineColumnMapping {
  queryId: String = "QUERY_ID"
  userName: String = "USER_NAME"
  warehouseName: String = "WAREHOUSE_NAME"
  roleName: String = "ROLE_NAME"
  totalElapsedTime: String = "TOTAL_ELAPSED_TIME"
  creditsCloudServices: String = "CREDITS_USED_CLOUD_SERVICES"
  creditsCompute: String = "CREDITS_USED_COMPUTE"
  queryType: String = "QUERY_TYPE"
  startTime: String = "START_TIME"
  queryHash: String = "md5(QUERY_TEXT)"
  queryText: String = "QUERY_TEXT"
  queryTag: String = "NULL"
  queryTagsSql: String = "NULL"
  sourceQueryTypeQi: String = "SOURCE_QUERY_TYPE"
  parsedDataKeepFilter: String = "(OUTPUT_FLAGS & (33554432 | 67108864)) != 0"
  caseInsensitiveMatch: Boolean = true
  hasNativeInputs: String?
  nativeInputsPayload: String?
}

const local function renderPopularityMineColumnMapping(
  mapping: PopularityMineColumnMapping
): Mapping<String, Any> = new Mapping {
  ["query_id"] = mapping.queryId
  ["user_name"] = mapping.userName
  ["warehouse_name"] = mapping.warehouseName
  ["role_name"] = mapping.roleName
  ["total_elapsed_time"] = mapping.totalElapsedTime
  ["credits_cloud_services"] = mapping.creditsCloudServices
  ["credits_compute"] = mapping.creditsCompute
  ["query_type"] = mapping.queryType
  ["start_time"] = mapping.startTime
  ["query_hash"] = mapping.queryHash
  ["query_text"] = mapping.queryText
  ["query_tag"] = mapping.queryTag
  ["query_tags_sql"] = mapping.queryTagsSql
  ["source_query_type_qi"] = mapping.sourceQueryTypeQi
  ["parsed_data_keep_filter"] = mapping.parsedDataKeepFilter
  ["case_insensitive_match"] = mapping.caseInsensitiveMatch
  when (mapping.hasNativeInputs != null) {
    ["has_native_inputs"] = mapping.hasNativeInputs
  }
  when (mapping.nativeInputsPayload != null) {
    ["native_inputs_payload"] = mapping.nativeInputsPayload
  }
}

/// Pre-built Popularity app node.
open class PopularityNode extends DAGNode {
  queryIntelligenceNode: String? = "qi"

  assetPublishNode: String? = "publish"

  waitForQueryIntelligence: Boolean = true

  waitForAssetPublish: Boolean = true

  connectionQualifiedName: String = "$.extract.outputs.connection_qualified_name"

  tenantId: String

  parsedDataPrefix: String

  minedDataPrefix: String

  connectionCachePath: String

  outputPrefix: String

  accessHistoryDataPrefix: String?

  windowDays: (Int(this >= 1)|String)?

  topNQueries: (Int(this >= 1)|String)?

  topNUsers: (Int(this >= 1)|String)?

  lakeProvider: ("local"|"aws"|"gcp"|"azure")? = null

  mineColumnMapping: PopularityMineColumnMapping?

  includeFilter: Mapping<String, Listing<String>>?

  excludeFilter: Mapping<String, Listing<String>>?

  parsedDataFilterHasError: (Boolean|String)?

  relationshipsOutputAttribution: (Boolean|String)?

  queryTypesToIgnore: Listing<String>?

  dryRun: (Boolean|String)?

  extraArgs: Mapping<String, Any> = new Mapping {}

  hidden _popularityDependencyCheck: Any =
    if (waitForQueryIntelligence && queryIntelligenceNode == null)
      throw("PopularityNode.waitForQueryIntelligence requires queryIntelligenceNode.")
    else if (waitForAssetPublish && assetPublishNode == null)
      throw("PopularityNode.waitForAssetPublish requires assetPublishNode.")
    else null

  displayName = "Compute Popularity"
  workflowType = "PopularityWorkflow"
  appName = "popularity"
  taskQueue = "atlan-popularity-{deployment_name}"
  args {
    ["connection_qualified_name"] = connectionQualifiedName
    ["tenant_id"] = tenantId
    ["parsed_data_prefix"] = parsedDataPrefix
    ["mined_data_prefix"] = minedDataPrefix
    ["connection_cache_path"] = connectionCachePath
    ["output_prefix"] = outputPrefix
    when (accessHistoryDataPrefix != null) {
      ["access_history_data_prefix"] = accessHistoryDataPrefix
    }
    when (windowDays != null) { ["window_days"] = windowDays }
    when (topNQueries != null) { ["top_n_queries"] = topNQueries }
    when (topNUsers != null) { ["top_n_users"] = topNUsers }
    when (lakeProvider != null) { ["lake_provider"] = lakeProvider }
    when (mineColumnMapping != null) {
      ["mine_column_mapping"] = renderPopularityMineColumnMapping(mineColumnMapping!!)
    }
    when (includeFilter != null) { ["include_filter"] = includeFilter }
    when (excludeFilter != null) { ["exclude_filter"] = excludeFilter }
    when (parsedDataFilterHasError != null) {
      ["parsed_data_filter_has_error"] = parsedDataFilterHasError
    }
    when (relationshipsOutputAttribution != null) {
      ["relationships_output_attribution"] = relationshipsOutputAttribution
    }
    when (queryTypesToIgnore != null) {
      ["query_types_to_ignore"] = queryTypesToIgnore
    }
    when (dryRun != null) { ["dry_run"] = dryRun }
    ...extraArgs
  }

  dependsOn = if (waitForQueryIntelligence && !waitForAssetPublish)
    new Listing { queryIntelligenceNode!! }
  else if (!waitForQueryIntelligence && waitForAssetPublish)
    new Listing { assetPublishNode!! }
  else null

  dependsOnCondition = if (waitForQueryIntelligence && waitForAssetPublish)
    new DependencyCondition {
      andConditions {
        new DependencyCondition {
          nodeId = queryIntelligenceNode!!
          tag = "success"
        }
        new DependencyCondition {
          nodeId = assetPublishNode!!
          tag = "success"
        }
      }
    }
  else null
}

/// Pre-built Lineage app node.
open class LineageNode extends DAGNode {
  hidden upstream: String = "extract"

  connectionQualifiedName: String = "$.\(upstream).outputs.connection_qualified_name"

  connectorName: String

  sessionKey: String = "view-lineage"

  sqlUnquotedCase: "upper"|"lower"|"preserve"

  ignoreAllCase: Boolean

  inputPath: String = ""

  lineageOutputPath: String = "$.\(upstream).outputs.lineage_stage_prefix"

  cachePath: String = "connection-cache"

  stagePath: String?

  lakeProvider: ("local"|"aws"|"gcp"|"azure")? = null

  cloudStorageBucket: String?

  localOutputPrefix: String?

  fileType: "parquet"|"json" = "json"

  azureBlob: Boolean?

  isTestEnv: Boolean?

  excludeFilePattern: String?

  includeFilePattern: String?

  enableSharded: Boolean?

  enableParentJobScoping: Boolean?

  enableFallbackMatch: Boolean?

  includeIndirectColumnRelations: Boolean?

  parsedViewsPath: String? = "$.\(upstream).outputs.view_lineage_output_prefix"

  parsedViewsCurrentState: String?

  processRoutines: Boolean?

  routineMappingsPath: String?

  columnMapping: Mapping<String, String>?

  jsonKeyMapping: Mapping<String, String>?

  sortColumns: String?

  lineageCurrentState: String?

  workflowName: String?

  runName: String?

  tenantId: String?

  packageName: String?

  gudusoftVersion: String?

  startTimeEpoch: Int?

  endTimeEpoch: Int?

  maxParallelChunks: Int?

  maxRowsPerChunk: Int?

  ingestGroupSize: Int?

  maxParallelIngestGroups: Int?

  enableAccuracyTest: Boolean?

  traceDir: String?

  checkpointDir: String?

  resumeFromStage: Int?

  extraArgs: Mapping<String, Any> = new Mapping {}

  displayName = "Build Lineage Entities"
  workflowType = "LineageWorkflow"
  appName = "automation-engine"
  taskQueue = "atlan-lineage-{deployment_name}"
  args {
    ["connection_qualified_name"] = connectionQualifiedName
    ["connector_name"] = connectorName
    ["session_key"] = sessionKey
    ["sql_unquoted_case"] = sqlUnquotedCase
    ["ignore_all_case"] = ignoreAllCase
    ["input_path"] = inputPath
    when (parsedViewsPath != null) { ["parsed_views_path"] = parsedViewsPath }
    ["lineage_output_path"] = lineageOutputPath
    ["cache_path"] = cachePath
    ["file_type"] = fileType
    when (lakeProvider != null) { ["lake_provider"] = lakeProvider }
    when (cloudStorageBucket != null) { ["cloud_storage_bucket"] = cloudStorageBucket }
    when (stagePath != null) { ["stage_path"] = stagePath }
    when (localOutputPrefix != null) { ["local_output_prefix"] = localOutputPrefix }
    when (azureBlob != null) { ["azure_blob"] = azureBlob }
    when (isTestEnv != null) { ["is_test_env"] = isTestEnv }
    when (excludeFilePattern != null) { ["exclude_file_pattern"] = excludeFilePattern }
    when (includeFilePattern != null) { ["include_file_pattern"] = includeFilePattern }
    when (enableSharded != null) { ["enable_sharded"] = enableSharded }
    when (enableParentJobScoping != null) { ["enable_parent_job_scoping"] = enableParentJobScoping }
    when (enableFallbackMatch != null) { ["enable_fallback_match"] = enableFallbackMatch }
    when (includeIndirectColumnRelations != null) { ["include_indirect_column_relations"] = includeIndirectColumnRelations }
    when (parsedViewsCurrentState != null) { ["parsed_views_current_state"] = parsedViewsCurrentState }
    when (processRoutines != null) { ["process_routines"] = processRoutines }
    when (routineMappingsPath != null) { ["routine_mappings_path"] = routineMappingsPath }
    when (columnMapping != null) { ["column_mapping"] = columnMapping }
    when (jsonKeyMapping != null) { ["json_key_mapping"] = jsonKeyMapping }
    when (sortColumns != null) { ["sort_columns"] = sortColumns }
    when (lineageCurrentState != null) { ["lineage_current_state"] = lineageCurrentState }
    when (workflowName != null) { ["workflow_name"] = workflowName }
    when (runName != null) { ["run_name"] = runName }
    when (tenantId != null) { ["tenant_id"] = tenantId }
    when (packageName != null) { ["package_name"] = packageName }
    when (gudusoftVersion != null) { ["gudusoft_version"] = gudusoftVersion }
    when (startTimeEpoch != null) { ["start_time_epoch"] = startTimeEpoch }
    when (endTimeEpoch != null) { ["end_time_epoch"] = endTimeEpoch }
    when (maxParallelChunks != null) { ["max_parallel_chunks"] = maxParallelChunks }
    when (maxRowsPerChunk != null) { ["max_rows_per_chunk"] = maxRowsPerChunk }
    when (ingestGroupSize != null) { ["ingest_group_size"] = ingestGroupSize }
    when (maxParallelIngestGroups != null) { ["max_parallel_ingest_groups"] = maxParallelIngestGroups }
    when (enableAccuracyTest != null) { ["enable_accuracy_test"] = enableAccuracyTest }
    when (traceDir != null) { ["trace_dir"] = traceDir }
    when (checkpointDir != null) { ["checkpoint_dir"] = checkpointDir }
    when (resumeFromStage != null) { ["resume_from_stage"] = resumeFromStage }
    ...extraArgs
  }
  dependsOn { upstream }
}

/// Pre-built lineage publish node.
open class LineagePublishNode extends DAGNode {
  hidden upstream: String = "lineage-app"

  assetPublishNode: String = "publish"

  waitForAssetPublish: Boolean = true

  hidden extractNode: String = "extract"

  connectionQualifiedName: String = "$.\(extractNode).outputs.connection_qualified_name"

  transformedDataPrefix: String = "$.\(extractNode).outputs.lineage_stage_prefix"

  publishStatePrefix: String = "$.\(extractNode).outputs.lineage_publish_state_prefix"

  currentStatePrefix: String = "$.\(extractNode).outputs.lineage_current_state_prefix"

  connectionEntity: String = "{{connection}}"

  /// Whether lineage publish should build and upload the connection-cache index.
  ///
  /// Defaults to `false` because the connection-cache index (SQLite, mapping
  /// `typeName` + `qualifiedName` → metadata) is built from asset entities
  /// (`Database`/`Schema`/`Table`). Writing it from lineage-stage data
  /// (`Process`/`ColumnProcess`) would overwrite the asset crawler's index and
  /// break downstream workflows (miners, BI/dbt lineage builders) that rely on
  /// it for qualified-name lookups. Set to `true` only when the lineage pipeline
  /// owns the entire connection cache and no asset crawler shares it.
  connectionCacheEnabled: Boolean = false

  /// App-level gate for the connection-cache activity, paired with `connectionCacheEnabled`.
  ///
  /// Defaults to `false` for the same reason: lineage publish must not overwrite
  /// the shared connection-cache index built by the asset crawler.
  connectionCacheViaAppEnabled: Boolean = false

  /// App-level gate for the current-state activity.
  ///
  /// When `true`, publish packages the transformed crawl output into a compressed
  /// archive and uploads it to the current-state path — the authoritative
  /// "what Atlan currently knows about this connection" baseline read by downstream
  /// consumers (e.g. the current-state syncer and on-demand asset caches).
  /// Defaults to `true` so lineage runs keep the baseline current.
  currentStateViaAppEnabled: Boolean = true

  cacheNamespace: String = "lineage"

  extraArgs: Mapping<String, Any> = new Mapping {}

  displayName = "Publish Lineage to Atlas"
  workflowType = "PublishWorkflow"
  appName = "publish"
  taskQueue = "atlan-publish-{deployment_name}"
  args {
    ["connection_qualified_name"] = connectionQualifiedName
    ["transformed_data_prefix"] = transformedDataPrefix
    ["publish_state_prefix"] = publishStatePrefix
    ["current_state_prefix"] = currentStatePrefix
    ["connection_creation_enabled"] = false
    ["executor_enabled"] = true
    ["cache_namespace"] = cacheNamespace
    ["connection_entity"] = connectionEntity
    ["connection_cache_enabled"] = connectionCacheEnabled
    ["connection_cache_via_app_enabled"] = connectionCacheViaAppEnabled
    ["current_state_via_app_enabled"] = currentStateViaAppEnabled
    ...extraArgs
  }
  dependsOn = if (waitForAssetPublish)
    null
  else
    new Listing { upstream }

  dependsOnCondition = if (waitForAssetPublish)
    new DependencyCondition {
      andConditions {
        new DependencyCondition {
          nodeId = upstream
          tag = "success"
        }
        new DependencyCondition {
          nodeId = assetPublishNode
          tag = "success"
        }
      }
    }
  else null
}

// ── Pipeline step classes ─────────────────────────────────────────────────────

/// Configuration for the extract step. Overrides the AE node display name and
/// error handling; the node id is always `"extract"`.
class ExtractStep {
  /// Display name for the AE step. Defaults to "Extract <displayName> Metadata".
  displayName: String?

  /// Error handling for the extract node.
  errorHandling: ErrorHandlingConfig? = null
}

/// Query Intelligence step — opt-in. Extends `QueryIntelligenceNode` with no
/// additional fields; the node id is `"qi"` and `upstream` defaults to `"extract"`.
class ParseQueriesStep extends QueryIntelligenceNode {}

/// Popularity step — opt-in. Extends `PopularityNode`; node id is `"popularity"`.
class PopularityStep extends PopularityNode {}

/// Lineage step — opt-in. Extends `LineageNode`; node id is `"lineage-app"`.
class LineageStep extends LineageNode {}

/// Configuration for the lineage-publish sub-step inside `PublishStep`.
class LineagePublishStep extends LineagePublishNode {}

/// Configuration for the publish step (default-on).
///
/// Set `pipeline.publish = null` to opt out of publishing entirely (e.g. for
/// utility apps that apply changes but don't publish assets to Atlas).
class PublishStep {
  /// Value emitted as `args["executor_enabled"]`.
  executorEnabled: Boolean|String = true

  /// Whether to append publish scaffolding fields (output_dir, checkpoint_dir,
  /// load_to_atlan, publish_dry_run) to the generated `_input.py`.
  includeInputFields: Boolean = true

  /// Display name for the AE step.
  displayName: String = "Publish to Atlas"

  /// Error handling for the publish node. Defaults to 72h
  /// `startToCloseTimeoutSeconds`. AE's source-code default for workflow nodes
  /// is 2h — too tight for any non-trivial publish on a large tenant (Cosmos
  /// APP-1235, Fabric HYP-1189). Override to a different value as needed.
  /// `heartbeatTimeoutSeconds` is invalid for the publish workflow node.
  errorHandling: ErrorHandlingConfig? = new ErrorHandlingConfig {
    startToCloseTimeoutSeconds = 259200
  }

  /// Whether the asset publish node should build and upload the connection-cache index.
  ///
  /// When `true`, publish reads the transformed crawl output and builds a SQLite
  /// index mapping every entity in the connection (`typeName` + `qualifiedName` →
  /// metadata), then uploads it as a single file. This index lets downstream
  /// workflows (miners, BI/dbt lineage builders) resolve asset identifiers by
  /// qualified name without re-crawling.
  ///
  /// Defaults to `true` for asset crawlers: the `Database`/`Schema`/`Table` rows
  /// they produce are exactly what populates this index. Set to `false` explicitly
  /// when this publish step must not overwrite the shared connection-cache index.
  connectionCacheEnabled: Boolean = true

  /// App-level gate for the connection-cache activity, paired with `connectionCacheEnabled`.
  ///
  /// Both flags must be `true` for the connection-cache index to be built and
  /// uploaded. Defaults to `true`. Set to `false` alongside `connectionCacheEnabled`
  /// when the node must not touch the shared index.
  connectionCacheViaAppEnabled: Boolean = true

  /// Whether the asset publish node should package and upload the current-state snapshot.
  ///
  /// When `true`, publish packages the transformed crawl output into a compressed
  /// archive and uploads it to the current-state path. This snapshot is the
  /// authoritative "what Atlan currently knows about this connection" baseline;
  /// downstream consumers (e.g. the current-state syncer and on-demand asset caches)
  /// read it to get an up-to-date view without re-crawling.
  ///
  /// Defaults to `true` so every crawler run records a fresh baseline that the
  /// next run can diff against. Set to `false` explicitly when this publish step
  /// must not write to current-state storage.
  currentStateEnabled: Boolean = true

  /// App-level gate for the current-state activity, paired with `currentStateEnabled`.
  ///
  /// Both flags must be `true` for the current-state snapshot to be written.
  /// Defaults to `true` so publish writes to the real current-state path rather
  /// than a dry-run path, enabling incremental diffing on subsequent runs. Set to
  /// `false` alongside `currentStateEnabled` when the node must not write
  /// current-state at all.
  currentStateViaAppEnabled: Boolean = true

  /// Connection entity passed to the publish workflow as `args["connection_entity"]`.
  ///
  /// The full connection entity JSON (typeName + attributes), used for connection
  /// creation. Defaults to the `"{{connection}}"` form placeholder. Set to `null`
  /// to omit the arg entirely; doing so also sets `connection_creation_enabled` to
  /// `false` on the generated publish node (the node links the two), so publish
  /// targets an existing connection and creates nothing.
  connectionEntity: String? = "{{connection}}"

  /// Optional lineage-publish sub-step. When set, adds a `"lineage-publish"`
  /// node after the main publish step.
  lineagePublish: LineagePublishStep? = null
}

/// Typed orchestration pipeline with five canonical steps.
class Pipeline {
  /// Extract step. Default-on. Set to `null` to omit (very rare).
  extract: ExtractStep? = new ExtractStep {}

  /// Parse Queries (Query Intelligence) step. Default-off. Opt in via:
  /// `parseQueries = new ParseQueriesStep { sqlKey = "..."; vendorName = "..." }`
  parseQueries: ParseQueriesStep? = null

  /// Popularity step. Default-off.
  popularity: PopularityStep? = null

  /// Lineage step. Default-off.
  lineage: LineageStep? = null

  /// Publish step. Default-on. Set to `null` to opt out.
  publish: PublishStep? = new PublishStep {}
}

// ── Deploy config classes ─────────────────────────────────────────────────────

/// Dapr component flags. Each boolean controls whether the component sidecar
/// is wired into the app deployment.
class DaprComponents {
  objectstore: Boolean = false
  secretstore: Boolean = false
  statestore: Boolean = false
  eventstore: Boolean = false
  subscription: Boolean = false
  configurationstore: Boolean = false
  lock: Boolean = false
  /// Full-spec Dapr components that can't be expressed as boolean flags
  /// (e.g. pubsub.kafka with custom metadata).
  customComponents: Mapping<String, Any> = new Mapping {}
}

class KedaTemporalConfig {
  /// Only `targetQueueSize` is read by the Helm chart — NOT the top-level
  /// `keda.targetQueueSize`. Always set via this nested path.
  targetQueueSize: Int = 5
}

class KedaConfig {
  enabled: Boolean = true
  minReplicaCount: Int = 0
  temporal: KedaTemporalConfig = new KedaTemporalConfig {}
}

class ResourceConfig {
  requests: Mapping<String, String> = new Mapping {}
  limits: Mapping<String, String> = new Mapping {}
}

/// Typed deployment configuration rendered into `atlan.yaml`'s `deploy:` block.
class DeployConfig {
  executionMode: String = "native"
  splitDeployment: Boolean = true
  /// Ignored when keda.enabled = true (KEDA manages replica count).
  replicaCount: Int? = null
  dapr: DaprComponents = new DaprComponents {}
  keda: KedaConfig = new KedaConfig {}
  resources: ResourceConfig? = null
  env: Mapping<String, String> = new Mapping {}
  envOverrides: Mapping<String, Mapping<String, String>> = new Mapping {}
}

// ── Entrypoint class ──────────────────────────────────────────────────────────

/// One marketplace card / SDK entrypoint under the deployed app.
open class Entrypoint {
  name: String

  id: String?

  displayName: String = name.capitalize()

  description: String?

  iconUrl: String?

  type: String = "connector"

  source: String?

  sourceCategory: String?

  categories: Listing<String> = new Listing {}

  docsUrl: String?

  metadata: Mapping<String, Any> = new Mapping {}

  /// Optional imported contract for this entrypoint.
  /// When set and `emitGeneratedArtifacts` is true, all files from
  /// `contract.output.files` are re-exported under `app/generated/{name}/`.
  /// Credential configmaps are hoisted to `app/generated/` root and deduped.
  contract: Typed?
}

// ────────────────────────────────────────────────────────────────────────────
// LOCAL RENDERING FUNCTIONS
// ────────────────────────────────────────────────────────────────────────────

// ── FieldSpec → credential configmap JSON ────────────────────────────────────

local function renderField(f: FieldSpec): Mapping<String, Any> = new Mapping {
  ["type"] = if (f.fieldType == "number") "number"
    else if (f.fieldType == "checkbox") "boolean"
    else if (f.fieldType == "inputRepeater") "object"
    else "string"

  when (f.required || f.includeRequiredWhenFalse) { ["required"] = f.required }

  when (f.fieldType == "select" && f.options != null) {
    ["enum"] = f.options
    when (f.optionLabels != null) {
      ["enumNames"] = new Listing {
        for (opt in f.options!!) {
          f.optionLabels!!.toMap().getOrNull(opt) ?? opt
        }
      }
    }
  }

  when (f.defaultValue != null) {
    ["default"] = if (f.fieldType == "number") f.defaultValue!!.toInt()
      else if (f.fieldType == "checkbox") f.defaultValue == "true"
      else f.defaultValue
  }

  ["ui"] = new Mapping {
    when (f.includeUiWidget) {
      ["widget"] = if (f.fieldType == "fileUpload") "fileUpload"
        else if (f.fieldType == "credentialFileInput") "credentialFileInput"
        else if (f.sensitive || f.fieldType == "password") "password"
        else if (f.fieldType == "textarea") "TextInput"
        else if (f.fieldType == "number") "inputNumber"
        else if (f.fieldType == "checkbox") "checkbox"
        else if (f.fieldType == "select" && f.options != null && f.options!!.length <= 4) "radio"
        else if (f.fieldType == "select") "select"
        else if (f.fieldType == "inputRepeater") "inputRepeater"
        else "input"
    }
    when (f.includeUiLabel) { ["label"] = f.displayName }
    when (f.includeUiHidden) { ["hidden"] = f.isHidden }
    when (f.helpText != null) { ["help"] = f.helpText }
    when (f.includeUiPlaceholder && f.placeholder != null) { ["placeholder"] = f.placeholder }
    when (f.includeUiGrid) { ["grid"] = f.width }
    when (f.rows != null) { ["rows"] = f.rows }
    when (f.uiClass != null) { ["class"] = f.uiClass }
    when (f.uiRequired != null) { ["required"] = f.uiRequired }
    when (f.feedback != null) { ["feedback"] = f.feedback }
    when (f.message != null) { ["message"] = f.message }
    when (f.byocDisabled != null) { ["BYOCdisabled"] = f.byocDisabled }
    when (f.includeUiWidget) {
      when ((f.fieldType == "fileUpload" || f.fieldType == "credentialFileInput") && f.fileTypes != null) { ["accept"] = f.fileTypes!!.toList() }
      when (f.fieldType == "fileUpload" || f.fieldType == "credentialFileInput") { ["fileMetadata"] = f.fileMetadata }
      when ((f.fieldType == "fileUpload" || f.fieldType == "credentialFileInput") && f.removeBeforeUpload) { ["removeBeforeUpload"] = true }
    }
    when (f.validationRules != null) {
      ["rules"] = f.validationRules
    }
    when (f.validationRules == null && f.validationRegex != null) {
      ["rules"] = new Listing {
        new Dynamic {
          pattern = f.validationRegex
          message = "Invalid format"
          trigger = "blur"
        }
      }
    }
  }
}

local function renderConditionalField(cf: ConditionalFieldSpec): Mapping<String, Any> = new Mapping {
  ["type"] = "conditional"
  when (cf.required) { ["required"] = true }
  when (cf.additionalProperties != null) { ["additionalProperties"] = cf.additionalProperties }
  when (cf.defaultValue != null) { ["default"] = cf.defaultValue }
  ["conditions"] = cf.conditions
}

local function renderAnyField(f: CredentialFieldEntry): Any =
  if (f is ConditionalFieldSpec) renderConditionalField(f)
  else if (f is NamedWidget) f.widget
  else if (f is NamedProperty) (f as NamedProperty).property
  else renderField(f as FieldSpec)

local function renderAuthOption(opt: AuthOption): Mapping<String, Any> = new Mapping {
  ["type"] = "object"
  ["ui"] = new Mapping {
    ["widget"] = "nested"
    ["label"] = opt.nestedLabel
    when (opt.nestedPlaceholder != null) { ["placeholder"] = opt.nestedPlaceholder }
    ["hidden"] = opt.nestedHidden
    ["nestedValue"] = false
  }
  when (!opt.fields.isEmpty || !opt.extraFields.isEmpty || !opt.postExtraFields.isEmpty) {
    ["properties"] = new Mapping {
      for (f in opt.fields) {
        [f.name] = renderAnyField(f)
      }
      when (!opt.extraFields.isEmpty) {
        ["extra"] = new Mapping {
          ["type"] = "object"
          ["ui"] = new Mapping {
            ["widget"] = "nested"
            ["label"] = opt.nestedExtraLabel
            when (opt.nestedExtraHeader != null) { ["header"] = opt.nestedExtraHeader }
            ["hidden"] = false
          }
          ["properties"] = new Mapping {
            for (f in opt.extraFields) {
              [f.name] = renderAnyField(f)
            }
          }
        }
      }
      for (f in opt.postExtraFields) {
        [f.name] = renderAnyField(f)
      }
    }
  }
}

// ── AdvancedJDBCUrlGroup renderer ─────────────────────────────────────────────

local function stripUiDefaults(ui: Mapping<String, Any>): Mapping<String, Any> =
  let (m = ui.toMap())
  let (w = m.getOrNull("widget"))
  let (isDefaultWidget = w == "input" || w == "inputNumber")
  let (keepHiddenFalse = w == "radio" || w == "select")
  let (step1 = if (isDefaultWidget) m.remove("widget") else m)
  let (step2 = if (!keepHiddenFalse && step1.getOrNull("hidden") == false)
    step1.remove("hidden") else step1)
  step2.toMapping()

local function renderFieldStripped(f: FieldSpec): Mapping<String, Any> =
  let (full = renderField(f).toMap())
  full.put("ui", stripUiDefaults(full["ui"] as Mapping<String, Any>)).toMapping()

local function renderAnyFieldStripped(f: CredentialFieldEntry): Any =
  if (f is ConditionalFieldSpec) renderConditionalField(f)
  else if (f is NamedWidget) (f as NamedWidget).widget
  else if (f is NamedProperty) (f as NamedProperty).property
  else renderFieldStripped(f as FieldSpec)

local function renderJdbcAuthOption(opt: AuthOption): Mapping<String, Any> = new Mapping {
  ["type"] = "object"
  ["ui"] = new Mapping {
    ["widget"] = "nested"
    ["label"] = opt.nestedLabel
    when (opt.nestedPlaceholder != null) { ["placeholder"] = opt.nestedPlaceholder }
    ["hidden"] = opt.nestedHidden
    ["nestedValue"] = false
  }
  when (!opt.fields.isEmpty || !opt.extraFields.isEmpty || !opt.postExtraFields.isEmpty) {
    ["properties"] = new Mapping {
      for (f in opt.fields) {
        [f.name] = renderAnyFieldStripped(f)
      }
      when (!opt.extraFields.isEmpty) {
        ["extra"] = new Mapping {
          ["type"] = "object"
          ["ui"] = new Mapping {
            ["widget"] = "nested"
            ["label"] = opt.nestedExtraLabel
            when (opt.nestedExtraHeader != null) { ["header"] = opt.nestedExtraHeader }
            ["hidden"] = false
          }
          ["properties"] = new Mapping {
            for (f in opt.extraFields) {
              [f.name] = renderAnyFieldStripped(f)
            }
          }
        }
      }
      for (f in opt.postExtraFields) {
        [f.name] = renderAnyFieldStripped(f)
      }
    }
  }
}

local function renderJdbcAuthMergeTargetOption(opt: AuthOption): Mapping<String, Any> =
  let (auth = renderJdbcAuthOption(opt).toMap())
  let (ui = (auth["ui"] as Mapping<String, Any>).toMap())
  auth.put("ui", ui.put("hidden", true).toMapping()).toMapping()

local extractionNamespaces: Map<String, String> = Map(
  "direct", "credential-guid",
  "agent", "agent-json"
)

local function nsFor(mode: String): String = extractionNamespaces[mode]

local function resolveUrlValue(v: UrlValue, ns: String): String =
  if (v is UrlLiteral) (v as UrlLiteral).value
  else "\(ns).\((v as UrlRef).field)"

local function renderUrlPartMapping(m: UrlPartMapping, ns: String): Mapping<String, Any> = new Mapping {
  when (m.hostname != null) { ["hostname"] = "\(ns).\(m.hostname!!)" }
  when (m.port != null) { ["port"] = "\(ns).\(m.port!!)" }
  when (m.pathname != null) { ["pathname"] = "\(ns).\(m.pathname!!)" }
  ["searchParams"] = new Mapping {
    for (k, v in m.searchParams) {
      [k] = resolveUrlValue(v, ns)
    }
  }
}

local function andPair(mode: String, pathSuffix: String, value: String): Dynamic = new {
  `$and` {
    new Dynamic { ["extraction-method"] = mode }
    new Dynamic { ["\(nsFor(mode)).\(pathSuffix)"] = value }
  }
}

local function activeModes(options: Mapping<String, AuthOption>): List<String> =
  let (union = options.toMap().values.toList()
    .flatMap((opt) -> (opt as JDBCUrlAuthOption).extractionModes.toList()))
  let (seen = union.toSet())
  List("agent", "direct").filter((m) -> seen.contains(m))

local function connectByFilter(connectBy: String, options: Mapping<String, AuthOption>): Dynamic = new {
  `$or` {
    for (mode in activeModes(options)) {
      andPair(mode, "connectBy", connectBy)
    }
  }
}

local function renderJdbcBranch(
  group: AdvancedJDBCUrlGroup,
  authKey: String,
  jdbcOpt: JDBCUrlAuthOption,
  mode: String
): Mapping<String, Any> = new Mapping {
  ["filter"] = new Dynamic {
    `$and` {
      new Dynamic { ["extraction-method"] = mode }
      new Dynamic { ["\(nsFor(mode)).auth-type"] = authKey }
    }
  }
  ["ui"] = new Mapping {
    ["widget"] = "AdvancedJDBCUrlGroup"
    ["urlPropertyId"] = "\(nsFor(mode)).extra.compiled_url"
    ["protocol"] = group.protocol
    ["connectByPropertyId"] = "\(nsFor(mode)).connectBy"
    ["urlPartPropertyIdMapping"] = renderUrlPartMapping(jdbcOpt.urlPartMapping, nsFor(mode))
  }
}

local function renderCompiledUrlField(
  group: AdvancedJDBCUrlGroup,
  options: Mapping<String, AuthOption>
): Mapping<String, Any> = new Mapping {
  ["type"] = "conditional"
  ["default"] = ""
  ["conditions"] = new Listing {
    new Mapping {
      ["filter"] = connectByFilter("url", options)
      ["required"] = true
      ["type"] = "string"
      ["ui"] = new Mapping {
        ["label"] = group.urlLabel
        when (group.urlHelp != null) { ["help"] = group.urlHelp }
        when (group.urlPlaceholder != null) { ["placeholder"] = group.urlPlaceholder }
        ["addonBefore"] = group.urlAddonBefore
        ["rules"] = new Listing {
          new Dynamic { required = true; message = "Please enter a valid URL" }
        }
      }
    }
    new Mapping {
      ["filter"] = connectByFilter("host", options)
      ["type"] = "string"
      ["ui"] = new Mapping {
        ["label"] = group.urlLabel
        ["addonBefore"] = group.urlAddonBefore
        ["disabled"] = true
      }
    }
  }
  ["ui"] = new Mapping {}
}

local function renderHostOrPortField(
  f: FieldSpec,
  options: Mapping<String, AuthOption>,
  isPort: Boolean
): Mapping<String, Any> =
  let (visible = renderFieldStripped(f))
  let (hostUi = (visible["ui"] as Mapping<String, Any>).toMap())
  new Mapping {
    ["type"] = "conditional"
    when (f.defaultValue != null) {
      ["default"] = if (f.fieldType == "number") f.defaultValue!!.toInt() else f.defaultValue
    }
    ["conditions"] = new Listing {
      new Mapping {
        ["filter"] = connectByFilter("host", options)
        when (f.required) { ["required"] = true }
        when (isPort && !f.required) { ["required"] = false }
        ["type"] = visible["type"]
        ["ui"] = if (isPort) hostUi.put("disabled", false).toMapping() else visible["ui"]
      }
      new Mapping {
        ["filter"] = connectByFilter("url", options)
        ["type"] = visible["type"]
        ["ui"] = hostUi.filter((k, _) -> k != "rules").put("disabled", true).toMapping()
      }
    }
    ["ui"] = new Mapping {}
  }

local function renderJdbcAuthTypeField(options: Mapping<String, AuthOption>): Mapping<String, Any> =
  let (allKeys = options.keys.toList())
  let (directKeys = allKeys.filter((k) -> (options[k] as JDBCUrlAuthOption).extractionModes.toList().contains("direct")))
  let (agentKeys = allKeys.filter((k) -> (options[k] as JDBCUrlAuthOption).extractionModes.toList().contains("agent")))
  new Mapping {
    ["type"] = "conditional"
    ["conditions"] = new Listing {
      new Mapping {
        ["property"] = "extraction-method"
        ["value"] = "agent"
        ["enum"] = new Listing { for (k in agentKeys) { k } }
        ["enumNames"] = new Listing { for (k in agentKeys) { options[k].label } }
      }
    }
    ["enum"] = new Listing { for (k in directKeys) { k } }
    ["default"] = directKeys.first
    ["required"] = true
    ["enumNames"] = new Listing { for (k in directKeys) { options[k].label } }
    ["ui"] = new Mapping {
      ["widget"] = "radio"
      ["hidden"] = credentialAuthHidden
      ["label"] = credentialAuthTitle
      when (credentialAuthHelp != null) { ["help"] = credentialAuthHelp }
      when (credentialAuthPlaceholder != null) { ["placeholder"] = credentialAuthPlaceholder }
      when (credentialAuthRules != null) { ["rules"] = credentialAuthRules }
    }
  }

local function renderJdbcExtraSection(group: AdvancedJDBCUrlGroup): Mapping<String, Any> = new Mapping {
  ["type"] = "object"
  ["ui"] = new Mapping {
    ["widget"] = "nested"
    ["label"] = ""
    ["header"] = group.extraHeader
    ["hidden"] = false
  }
  ["properties"] = new Mapping {
    for (f in group.extraFields) {
      [f.name] = renderAnyFieldStripped(f)
    }
  }
}

local function renderJdbcUrlField(
  group: AdvancedJDBCUrlGroup,
  options: Mapping<String, AuthOption>
): Mapping<String, Any> = new Mapping {
  ["type"] = "conditional"
  ["conditions"] = new Listing {
    for (mode in activeModes(options)) {
      for (authKey, opt in options) {
        when ((opt as JDBCUrlAuthOption).extractionModes.toList().contains(mode)) {
          renderJdbcBranch(group, authKey, opt as JDBCUrlAuthOption, mode)
        }
      }
    }
  }
  ["properties"] = new Mapping {
    ["extra.compiled_url"] = renderCompiledUrlField(group, options)
    ["host"] = renderHostOrPortField(group.hostField, options, false)
    ["port"] = renderHostOrPortField(group.portField, options, true)
    ["auth-type"] = renderJdbcAuthTypeField(options)
    for (authKey, opt in options) {
      [authKey] = renderJdbcAuthOption(opt)
    }
    when (!group.extraFields.isEmpty) {
      ["extra"] = renderJdbcExtraSection(group)
    }
  }
  ["ui"] = new Mapping {
    ["widget"] = "AdvancedJDBCUrlGroup"
    ["urlPropertyId"] = "credential-guid.extra.compiled_url"
    ["connectByPropertyId"] = "credential-guid.connectBy"
    ["protocol"] = group.protocol
    ["urlPartPropertyIdMapping"] = new Mapping {}
  }
  ["anyOf"] = new Listing {
    for (authKey, _ in options) {
      new Mapping {
        ["properties"] = new Mapping {
          ["auth-type"] = new Mapping { ["const"] = authKey }
        }
        ["required"] = new Listing { authKey }
      }
    }
  }
}

local function renderConnectByRadio(group: AdvancedJDBCUrlGroup): Mapping<String, Any> = new Mapping {
  ["type"] = "string"
  ["enum"] = new Listing { "host"; "url" }
  ["default"] = group.connectByDefault
  ["required"] = true
  ["enumNames"] = new Listing { "Host"; "URL" }
  ["ui"] = new Mapping {
    ["widget"] = "radio"
    ["hidden"] = false
    ["label"] = group.connectByLabel
    ["rules"] = group.connectByRules
  }
}

const local function agentJsonFieldOverride(f: FieldSpec): Mapping<String, Any> = new Mapping {
  ["default"] = ""
  ["ui"] = new Mapping {
    when (f.sensitive || f.fieldType == "password") { ["widget"] = "" }
    ["placeholder"] = "Store Credential Path"
    when (f.validationRules != null || f.validationRegex != null) {
      ["rules"] = new Listing {}
    }
  }
}

const local function renderAgentAuthOptionOverride(opt: AuthOption): Mapping<String, Any> = new Mapping {
  when (!opt.fields.isEmpty || !opt.extraFields.isEmpty || !opt.postExtraFields.isEmpty) {
    ["properties"] = new Mapping {
      for (f in opt.fields) {
        when (f is FieldSpec) {
          [(f as FieldSpec).name] = agentJsonFieldOverride(f as FieldSpec)
        }
      }
      when (!opt.extraFields.isEmpty) {
        ["extra"] = new Mapping {
          ["properties"] = new Mapping {
            for (f in opt.extraFields) {
              when (f is FieldSpec) {
                [(f as FieldSpec).name] = agentJsonFieldOverride(f as FieldSpec)
              }
            }
          }
        }
      }
      for (f in opt.postExtraFields) {
        when (f is FieldSpec) {
          [(f as FieldSpec).name] = agentJsonFieldOverride(f as FieldSpec)
        }
      }
    }
  }
}

/// Public helper — build `agentConfigEntries` for a JDBC-URL credential form.
///
/// Wire into `Widgets.AgentSelector.agentConfigEntries`:
/// ```pkl
/// ["agent-json"] = new Widgets.AgentSelector {
///   agentConfigEntries = generatedAgentJsonEntries(
///     credentialUrlGroup, credentialAuthOptions, connectorConfigName
///   )
/// }
/// ```
const function generatedAgentJsonEntries(
  group: AdvancedJDBCUrlGroup,
  options: Mapping<String, AuthOption>,
  connectorConfigName: String
): Listing<Any> = new Listing {
  new Listing {
    connectorConfigName
    new Mapping {
      ["properties"] = new Mapping {
        ["agent-type"] = new Mapping {
          ["type"] = "string"
          ["ui"] = new Mapping { ["hidden"] = true }
        }
        ["jdbcUrl"] = new Mapping {
          ["properties"] = new Mapping {
            for (authKey, opt in options) {
              when ((opt as JDBCUrlAuthOption).extractionModes.toList().contains("agent")) {
                [authKey] = renderAgentAuthOptionOverride(opt)
              }
            }
          }
        }
      }
    }
  }
  new Listing { "atlan-connectors-agent" }
}

// ── JDBC invariant ────────────────────────────────────────────────────────────

local jdbcInvariant: Any =
  if (credentialUrlGroup != null)
    if (credentialAuthOptions == null)
      throw("credentialUrlGroup is set but credentialAuthOptions is null. "
          + "JDBC URL mode requires at least one JDBCUrlAuthOption in credentialAuthOptions.")
    else if (credentialAuthOptions!!.toMap().isEmpty)
      throw("credentialUrlGroup is set but credentialAuthOptions is empty. "
          + "JDBC URL mode requires at least one JDBCUrlAuthOption in credentialAuthOptions.")
    else
      let (nonJdbc = credentialAuthOptions!!.toMap().values.toList().filter((o) -> !(o is JDBCUrlAuthOption)))
      if (!nonJdbc.isEmpty)
        throw("credentialUrlGroup is set but credentialAuthOptions contains a plain AuthOption. "
            + "Every option must be a JDBCUrlAuthOption when credentialUrlGroup is non-null.")
      else null
  else null

// ── Credential config generation ──────────────────────────────────────────────

local connectorInvariant =
  if (hasCredentialConfig && connector == null)
    throw("connector must be set when hasCredentialConfig = true.")
  else true

/// Auto-derived: hide the auth-type radio when the connector has a single auth
/// option, since presenting a one-item radio adds no value. Auto-calculation
/// keeps this in sync as connectors add or remove auth options — no manual
/// flag to forget.
local credentialAuthHidden: Boolean =
  credentialAuthOptions != null && credentialAuthOptions!!.length == 1

local function generateCredentialConfig(): Mapping<String, Any> =
  let (_ = jdbcInvariant)
  new Mapping {
  ["icon"] = icon
  ["helpdeskLink"] = helpdeskLink
  ["logo"] = logo
  ["connector"] = connector?.value
  ["defaultConnectorType"] = credentialConnectorType
  ["config"] = new Mapping {
    ["properties"] = new Mapping {
      ["name"] = new Mapping {
        ["type"] = "string"
        ["required"] = false
        ["ui"] = new Mapping { ["label"] = "Name"; ["hidden"] = true; ["placeholder"] = credentialNamePlaceholder }
      }
      ["connector"] = new Mapping {
        ["type"] = "string"
        when (credentialConnectorDefault != null) { ["default"] = credentialConnectorDefault }
        ["required"] = false
        ["ui"] = new Mapping { ["label"] = "Connector"; ["hidden"] = true; ["placeholder"] = "Connector" }
      }
      ["connectorType"] = new Mapping {
        ["type"] = "string"
        ["required"] = false
        ["ui"] = new Mapping { ["key"] = "_host"; ["label"] = "connectorType"; ["placeholder"] = "connectorType"; ["hidden"] = true }
      }
      when (credentialUrlGroup == null) {
        for (f in credentialCommonFields) {
          [f.name] = renderAnyField(f)
        }
      }
      when (credentialUrlGroup != null && credentialAuthOptions != null) {
        ["connectBy"] = renderConnectByRadio(credentialUrlGroup!!)
        ["jdbcUrl"] = renderJdbcUrlField(credentialUrlGroup!!, credentialAuthOptions!!)
        // Top-level copies are agent merge targets only. The visible JDBC auth
        // panes live inside jdbcUrl.properties.
        for (k, opt in credentialAuthOptions!!) {
          [k] = renderJdbcAuthMergeTargetOption(opt)
        }
      }
      when (credentialUrlGroup == null && credentialAuthOptions != null) {
        ["auth-type"] = new Mapping {
          ["type"] = "string"
          ["enum"] = new Listing { for (k, _ in credentialAuthOptions!!) { k } }
          ["default"] = credentialAuthDefault ?? credentialAuthOptions!!.keys.first
          ["required"] = true
          ["enumNames"] = new Listing { for (_, v in credentialAuthOptions!!) { v.label } }
          when (credentialAuthHiddenEnumListForCreating != null) {
            ["hiddenEnumListForCreating"] = credentialAuthHiddenEnumListForCreating
          }
          ["ui"] = new Mapping {
            ["widget"] = "radio"
            ["hidden"] = credentialAuthHidden
            ["label"] = credentialAuthTitle
            when (credentialAuthRules != null) { ["rules"] = credentialAuthRules }
            when (credentialAuthPlaceholder != null) { ["placeholder"] = credentialAuthPlaceholder }
            when (credentialAuthWidth != null) { ["grid"] = credentialAuthWidth }
          }
        }
        for (k, opt in credentialAuthOptions!!) {
          [k] = renderAuthOption(opt)
        }
      }
      when (!credentialSharedExtraFields.isEmpty && credentialUrlGroup == null) {
        ["extra"] = new Mapping {
          ["type"] = "object"
          ["ui"] = new Mapping {
            ["widget"] = "nested"
            ["label"] = ""
            ["header"] = "Advanced"
            ["hidden"] = false
          }
          ["properties"] = new Mapping {
            for (f in credentialSharedExtraFields) {
              [f.name] = renderAnyField(f)
            }
          }
        }
      }
    }
    when (credentialUrlGroup == null && credentialAuthOptions != null) {
      ["anyOf"] = new Listing {
        for (k, opt in credentialAuthOptions!!) {
          new Mapping {
            ["properties"] = new Mapping {
              ["auth-type"] = new Mapping { ["const"] = k }
            }
            ["required"] = new Listing {
              k
              for (field in opt.anyOfRequiredFields) {
                field
              }
            }
          }
        }
      }
    }
  }
}

// ── Manifest / DAG generation ─────────────────────────────────────────────────

/// Auto-detected publish tag pipeline value from uiConfig properties.
local _publishTagPipelineEnabled: Boolean|String? =
  if (uiConfig != null && uiConfig!!.properties.containsKey("enable-tags")) "{{enable-tags}}"
  else if (uiConfig != null && uiConfig!!.properties.containsKey("enable-tag-sync")) "{{enable-tag-sync}}"
  else null

local _publishTagAttachmentsPrefix: String? =
  if (_publishTagPipelineEnabled != null) "$.extract.outputs.tag_attachments_prefix" else null

local manifestData: Mapping<String, Any> = new Mapping {
  ["execution_mode"] = "automation-engine"
  ["dag"] = generateDAG()
}

local function generateDAG(): Mapping<String, Any> = new Mapping {
  when (pipeline.extract != null) {
    ["extract"] = generateExtractNode()
  }
  when (pipeline.parseQueries != null) {
    ["qi"] = renderNode(pipeline.parseQueries!!)
  }
  when (pipeline.popularity != null) {
    ["popularity"] = renderNode(pipeline.popularity!!)
  }
  when (pipeline.lineage != null) {
    ["lineage-app"] = renderNode(pipeline.lineage!!)
  }
  when (pipeline.publish != null || extraNodes.toMap().containsKey("publish")) {
    // If the app overrides the publish node via `extraNodes["publish"]`, emit
    // the override here so it keeps the typed publish node's position in the
    // generated DAG (between `lineage-app` and `lineage-publish`). Without
    // this in-place emit, the override would only be appended by the trailing
    // `for` loop and end up after `lineage-publish` — a cosmetic but noisy
    // diff that hurts reviewability of override PRs.
    ["publish"] =
      if (extraNodes.toMap().containsKey("publish"))
        renderNode(extraNodes["publish"])
      else
        let (ps = pipeline.publish!!)
        let (_publishEhCheck = validateWorkflowNodeErrorHandling(ps.errorHandling, "pipeline.publish.errorHandling"))
        renderNode(new PublishNode {
          executorEnabled = ps.executorEnabled
          displayName = ps.displayName
          errorHandling = ps.errorHandling
          connectionCacheEnabled = ps.connectionCacheEnabled
          connectionCacheViaAppEnabled = ps.connectionCacheViaAppEnabled
          currentStateEnabled = ps.currentStateEnabled
          currentStateViaAppEnabled = ps.currentStateViaAppEnabled
          connectionEntity = ps.connectionEntity
        })
  }
  when (pipeline.publish != null && pipeline.publish!!.lineagePublish != null) {
    ["lineage-publish"] = renderNode(pipeline.publish!!.lineagePublish!!)
  }
  for (nodeId, node in extraNodes) {
    // `publish` is already emitted above (at its in-pipeline position) when
    // overridden via `extraNodes["publish"]`; skip it here to avoid emitting
    // a duplicate trailing entry.
    when (nodeId != "publish") {
      [nodeId] = renderNode(node)
    }
  }
  when (notifications && !extraNodes.toMap().containsKey("notifications")) {
    ["notifications"] = renderNode(new NotificationNode {})
  }
}

local function validateWorkflowNodeErrorHandling(errorHandling: ErrorHandlingConfig?, propertyName: String): Any =
  if (errorHandling != null && errorHandling.heartbeatTimeoutSeconds != null)
    throw("\(propertyName).heartbeatTimeoutSeconds is not valid for toolkit-managed workflow nodes. "
          + "Built-in extract/publish nodes render activity_name = \"execute_workflow\", "
          + "which Automation Engine treats as a workflow node. Use startToCloseTimeoutSeconds instead.")
  else if (errorHandling != null) errorHandling._timeoutOrderingCheck
  else null

local function renderDependencyCondition(condition: DependencyCondition): Mapping<String, Any> =
  let (_conditionCheck = condition._conditionShapeCheck)
  new Mapping {
  when (condition.nodeId != null) {
    ["node_id"] = condition.nodeId
  }
  when (condition.tag != null) {
    ["tag"] = condition.tag
  }
  when (condition.andConditions != null) {
    ["and_conditions"] = condition.andConditions.toList()
      .map((c) -> renderDependencyCondition(c))
  }
  when (condition.orConditions != null) {
    ["or_conditions"] = condition.orConditions.toList()
      .map((c) -> renderDependencyCondition(c))
  }
}

local function renderNode(node: DAGNode): Mapping<String, Any> =
  let (_nodeCheck = node._errorHandlingCheck)
  let (_depCheck = node._dependencyConfigCheck)
  let (_qiCheck = if (node is QueryIntelligenceNode) (node as QueryIntelligenceNode)._qiArgsCheck else null)
  let (_popularityCheck = if (node is PopularityNode) (node as PopularityNode)._popularityDependencyCheck else null)
  let (_popularityFormRefCheck = if (node is PopularityNode) validatePopularityFormRefs(node as PopularityNode) else null)
  let (_ehCheck = if (node.errorHandling != null) node.errorHandling._timeoutOrderingCheck else null)
  new Mapping {
  ["activity_name"] = "execute_workflow"
  ["activity_display_name"] = node.displayName
  ["app_name"] = node.appName
  ["inputs"] = new Mapping {
    ["workflow_type"] = node.workflowType
    ["app_name"] = node.appName
    ["task_queue"] = node.taskQueue ?? "atlan-\(node.appName)-{deployment_name}"
    ["args"] = renderNodeArgs(node)
  }
  when (node.dependsOn != null && node.dependsOn.length == 1) {
    ["depends_on"] = new Mapping {
      ["node_id"] = node.dependsOn.first
    }
  }
  when (node.dependsOn != null && node.dependsOn.length > 1) {
    ["depends_on"] = new Mapping {
      ["and_conditions"] = node.dependsOn.toList()
        .map((n) -> new Mapping {
          ["node_id"] = n
          ["tag"] = "success"
        })
    }
  }
  when (node.dependsOnCondition != null) {
    ["depends_on"] = renderDependencyCondition(node.dependsOnCondition)
  }
  when (node.errorHandling != null) {
    ["error_handling"] = renderErrorHandling(node.errorHandling)
  }
}

local exactWorkflowParamRegex = Regex("^\\{\\{[A-Za-z0-9][A-Za-z0-9_-]*\\}\\}$")

local popularityFirstClassArgKeys: Mapping<String, Boolean> = new Mapping {
  ["connection_qualified_name"] = true
  ["tenant_id"] = true
  ["parsed_data_prefix"] = true
  ["mined_data_prefix"] = true
  ["connection_cache_path"] = true
  ["output_prefix"] = true
  ["access_history_data_prefix"] = true
  ["window_days"] = true
  ["top_n_queries"] = true
  ["top_n_users"] = true
  ["lake_provider"] = true
  ["mine_column_mapping"] = true
  ["include_filter"] = true
  ["exclude_filter"] = true
  ["parsed_data_filter_has_error"] = true
  ["relationships_output_attribution"] = true
  ["query_types_to_ignore"] = true
  ["dry_run"] = true
}

local function workflowParamName(value: String): String =
  value.substring(2, value.length - 2)

local function validatePopularityExtraArgs(node: PopularityNode): Any =
  let (conflictingKeys = node.extraArgs.keys.toList()
    .filter((key) -> popularityFirstClassArgKeys.containsKey(key)))
  if (!conflictingKeys.isEmpty)
    throw("PopularityNode.extraArgs cannot set first-class arg(s): \(conflictingKeys.join(", ")). "
          + "Use the typed PopularityNode property instead; extraArgs is only for fields not modeled by the toolkit.")
  else null

local function validatePopularityNumericRef(value: Any, propertyName: String): Any =
  if (value is String)
    let (placeholder = value as String)
    if (!placeholder.matches(exactWorkflowParamRegex))
      throw("PopularityNode.\(propertyName) string value must be an exact workflow parameter placeholder such as "
            + "`\"{{popularity-window-days}}\"`.")
    else
      let (fieldName = workflowParamName(placeholder))
      if (uiConfig == null || !uiConfig!!.properties.containsKey(fieldName))
        throw("PopularityNode.\(propertyName) references workflow field `\(fieldName)`, but uiConfig does not define that field.")
      else
        let (field = uiConfig!!.properties[fieldName])
        if (!(field is Widgets.NumericInput))
          throw("PopularityNode.\(propertyName) references workflow field `\(fieldName)`, but that field must be Widgets.NumericInput.")
        else null
  else null

local function validatePopularityBooleanRef(value: Any, propertyName: String): Any =
  if (value is String)
    let (placeholder = value as String)
    if (!placeholder.matches(exactWorkflowParamRegex))
      throw("PopularityNode.\(propertyName) string value must be an exact workflow parameter placeholder such as "
            + "`\"{{popularity-dry-run}}\"`.")
    else
      let (fieldName = workflowParamName(placeholder))
      if (uiConfig == null || !uiConfig!!.properties.containsKey(fieldName))
        throw("PopularityNode.\(propertyName) references workflow field `\(fieldName)`, but uiConfig does not define that field.")
      else
        let (field = uiConfig!!.properties[fieldName])
        if (!(field is Widgets.BooleanInput) && !(field is Widgets.Switcher))
          throw("PopularityNode.\(propertyName) references workflow field `\(fieldName)`, but that field must be Widgets.BooleanInput or Widgets.Switcher.")
        else null
  else null

local function validatePopularityFormRefs(node: PopularityNode): Any =
  let (_extraArgs = validatePopularityExtraArgs(node))
  let (_windowDays = validatePopularityNumericRef(node.windowDays, "windowDays"))
  let (_topNQueries = validatePopularityNumericRef(node.topNQueries, "topNQueries"))
  let (_topNUsers = validatePopularityNumericRef(node.topNUsers, "topNUsers"))
  let (_parsedDataFilterHasError = validatePopularityBooleanRef(node.parsedDataFilterHasError, "parsedDataFilterHasError"))
  let (_relationshipsOutputAttribution = validatePopularityBooleanRef(node.relationshipsOutputAttribution, "relationshipsOutputAttribution"))
  let (_dryRun = validatePopularityBooleanRef(node.dryRun, "dryRun"))
  null

local function renderErrorHandling(errorHandling: ErrorHandlingConfig): Mapping<String, Any> = new Mapping {
  when (errorHandling.initialInterval != null) {
    ["initial_interval"] = errorHandling.initialInterval
  }
  when (errorHandling.backoffCoefficient != null) {
    ["backoff_coefficient"] = errorHandling.backoffCoefficient
  }
  when (errorHandling.maximumInterval != null) {
    ["maximum_interval"] = errorHandling.maximumInterval
  }
  when (errorHandling.maximumAttempts != null) {
    ["maximum_attempts"] = errorHandling.maximumAttempts
  }
  when (errorHandling.nonRetryableErrorTypes != null) {
    ["non_retryable_error_types"] = errorHandling.nonRetryableErrorTypes
  }
  when (errorHandling.startToCloseTimeoutSeconds != null) {
    ["start_to_close_timeout_seconds"] = errorHandling.startToCloseTimeoutSeconds
  }
  when (errorHandling.heartbeatTimeoutSeconds != null) {
    ["heartbeat_timeout_seconds"] = errorHandling.heartbeatTimeoutSeconds
  }
}

local function renderNodeArgs(node: DAGNode): Mapping<String, Any> =
  if (node is PublishNode)
    let (publishNode = node as PublishNode)
    let (nodeArgs = node.args)
    let (tagPipelineValue = publishNode.tagPipelineEnabled ?? _publishTagPipelineEnabled)
    let (tagAttachmentsValue = publishNode.tagAttachmentsPrefix ?? _publishTagAttachmentsPrefix)
    new Mapping {
      ...nodeArgs
      when (!nodeArgs.toMap().containsKey("tag_pipeline_enabled") && tagPipelineValue != null) {
        ["tag_pipeline_enabled"] = tagPipelineValue
      }
      when (!nodeArgs.toMap().containsKey("tag_attachments_prefix") && tagAttachmentsValue != null) {
        ["tag_attachments_prefix"] = tagAttachmentsValue
      }
    }
  else node.args

local function generateExtractNode(): Mapping<String, Any> =
  let (step = pipeline.extract!!)
  let (_extractEhCheck = validateWorkflowNodeErrorHandling(step.errorHandling, "pipeline.extract.errorHandling"))
  let (topLevelFormFields = manifestTopLevelArgs.toMap().values.toList())
  new Mapping {
    ["activity_name"] = "execute_workflow"
    ["activity_display_name"] = step.displayName ?? "Extract \(displayName) Metadata"
    ["app_name"] = "{app_name}"
    ["inputs"] = new Mapping {
      ["workflow_type"] = workflowType
          .replaceAll(Regex("([A-Z]+)([A-Z][a-z])"), "$1-$2")
          .replaceAll(Regex("([a-z0-9])([A-Z])"), "$1-$2")
          .toLowerCase()
      ["app_name"] = "{app_name}"
      ["app_id"] = ""
      ["argo_workflow_slug"] = ""
      ["task_queue"] = "\(taskQueuePrefix)-{deployment_name}"
      ["args"] = new Mapping {
        ["credential"] = "{{credential}}"
        for (argName, formField in manifestTopLevelArgs) {
          when (uiConfig != null && uiConfig!!.properties.containsKey(formField) && uiConfig!!.properties[formField].includeInManifest) {
            [argName] = "{{" + formField + "}}"
          }
        }
        for (paramKey, param in (uiConfig?.properties ?? Map())) {
          when (param.includeInManifest && !topLevelFormFields.contains(paramKey)) {
            [toPyName(paramKey)] = "{{" + paramKey + "}}"
          }
        }
      }
    }
    when (step.errorHandling != null) {
      ["error_handling"] = renderErrorHandling(step.errorHandling)
    }
  }

// ── Output file emitters ──────────────────────────────────────────────────────

local workflowConfigOutput: FileOutput = new FileOutput {
  value = new Mapping {
    ["id"] = workflowConfigName
    ["name"] = displayName
    ["logo"] = logo
    ["config"] = uiConfig
  }
  renderer = new JsonRenderer {}
}

local manifestOutput: FileOutput = new FileOutput {
  value = manifestData
  renderer = new JsonRenderer {}
}

local credentialConfigOutput: FileOutput = new FileOutput {
  value = generateCredentialConfig()
  renderer = new JsonRenderer {}
}

// ── _input.py generation ──────────────────────────────────────────────────────

local function toPyName(k: String): String = k.replaceAll("-", "_")

local function getPyDefaultFactoryField(k: String, fieldType: String, factory: String): String =
  let (line = "\(k): \(fieldType) = Field(default_factory=\(factory))")
  if (line.length <= 84)
    line
  else
    "\(k): \(fieldType) = Field(\n        default_factory=\(factory)\n    )"

local function getInputPyField(k: String, u: Widgets.UIElement): String =
  let (k = toPyName(k))
  if (u is Widgets.BooleanInput)
    "\(k): bool = \(if ((u as Widgets.BooleanInput).default) "True" else "False")"
  else if (u is Widgets.Switcher)
    "\(k): bool = \(if ((u as Widgets.Switcher).default) "True" else "False")"
  else if (u is Widgets.NumericInput)
    "\(k): int = \(if ((u as Widgets.NumericInput).default != null) (u as Widgets.NumericInput).default!!.toInt() else 0)"
  else if (u is Widgets.DateInput)
    "\(k): int = 0"
  else if (u is Widgets.FileUploader)
    "\(k): FileReference | None = None"
  else if (u is Widgets.ConnectionCreator)
    "\(k): ConnectionRef | None = None"
  else if (u is Widgets.ConnectionRefInput)
    (if ((u as Widgets.ConnectionRefInput).multiSelect)
      getPyDefaultFactoryField(k, "Annotated[list[ConnectionRef], MaxItems(1000)]", "list")
    else
      "\(k): ConnectionRef | None = None")
  else if (u is Widgets.ConnectionSelector)
    "\(k): str = \"\""
  else if (u is Widgets.CredentialInput)
    "\(k): str = \"\""
  else if (u is Widgets.PasswordInput)
    "\(k): str = \"\""
  else if (u is Widgets.TagsInput)
    getPyDefaultFactoryField(k, "Annotated[list[str], MaxItems(1000)]", "list")
  else if (u is Widgets.InputRepeater)
    getPyDefaultFactoryField(k, "Annotated[list[str], MaxItems(1000)]", "list")
  else if (u is Widgets.DropDown)
    (if ((u as Widgets.DropDown).multiSelect)
      getPyDefaultFactoryField(k, "Annotated[list[str], MaxItems(1000)]", "list")
    else
      "\(k): str = \"\(if ((u as Widgets.DropDown).default != null) (u as Widgets.DropDown).default!! else "")\"")
  else if (u is Widgets.Radio)
    "\(k): str = \"\(if ((u as Widgets.Radio).default != null) (u as Widgets.Radio).default!! else "")\""
  else if (u is Widgets.CloudProvider)
    "\(k): str = \"\""
  else if (u is Widgets.Sage || u is Widgets.SageV2)
    "\(k): str = \"\""
  else if (u is Widgets.InfoBanner || u is Widgets.GlossarySelector)
    "\(k): str = \"\""
  else if (u is Widgets.CustomWidget)
    "\(k): str = \"\""
  else if (u is Widgets.TextInput)
    "\(k): str = \"\(if ((u as Widgets.TextInput).default != null) (u as Widgets.TextInput).default!! else "")\""
  else if (u is Widgets.TextBoxInput)
    "\(k): str = \"\""
  else if (u is Widgets.ConditionalInput)
    (let (ci = u as Widgets.ConditionalInput)
      if (ci.outputValueType == "object")
        getPyDefaultFactoryField(k, "Annotated[dict[str, Any], MaxItems(1000)]", "dict")
      else
        "\(k): str = \"\(if (ci.default != null) ci.default!!.toString() else "")\"")
  else if (u is Widgets.SqlTree)
    // Values are bounded strings (schema names / JSON-encoded selections); `str` avoids
    // the SDK's AAF-CTR-002 rejection of `Any`.  Pydantic's lax mode coerces non-string
    // leaf values (e.g. booleans) to str during model construction.
    getPyDefaultFactoryField(k, "Annotated[dict[str, str], MaxItems(1000)]", "dict")
  else if (u is Widgets.NestedInput || u is Widgets.APITree || u is Widgets.ApiTreeSelect || u is Widgets.DsnTreeMap || u is Widgets.AgentSelector)
    getPyDefaultFactoryField(k, "Annotated[dict[str, Any], MaxItems(1000)]", "dict")
  else
    "\(k): str = \"\""

local function needsJsonObjectStringCoercion(u: Widgets.UIElement): Boolean =
  u is Widgets.NestedInput
  || u is Widgets.APITree
  || u is Widgets.ApiTreeSelect
  || u is Widgets.DsnTreeMap
  || u is Widgets.SqlTree
  || u is Widgets.AgentSelector
  || (u is Widgets.ConditionalInput && (u as Widgets.ConditionalInput).outputValueType == "object")

local function pyQuotedCsv(values: List<String>): String =
  values.fold("", (acc: String, value: String) ->
    if (acc == "") "\"\(value)\"" else "\(acc), \"\(value)\""
  )

local extractionInputProvidedFields: Listing<String> = new Listing {
  "workflow_id"
  "connection"
  "credential_guid"
  "credential_ref"
  "extraction_method"
  "agent_json"
  "output_prefix"
  "output_path"
  "include_filter"
  "exclude_filter"
  "temp_table_regex"
  "source_tag_prefix"
}

local function generateInputClassPy(): FileOutput = new FileOutput {
  local props = uiConfig?.properties ?? Map()
  local skipFields: Set<String> = extractionInputProvidedFields.toList().toSet()
  local uiFieldLines: String = (new Listing {
    for (k, u in props) {
      if (u.includeInInput && !skipFields.contains(toPyName(k)))
        "    " + getInputPyField(k.replaceAll("-", "_"), u) + "\n" +
        (if (u.helpText != "") "    \"\"\"" + u.helpText + "\"\"\"\n" else "")
      else
        ""
    }
  }).toList().fold("", (acc: String, s: String) -> acc + s)
  local objectStringCoercionFields: List<String> = (new Listing {
    for (k, u in props) {
      when (u.includeInInput && !skipFields.contains(toPyName(k)) && needsJsonObjectStringCoercion(u)) {
        toPyName(k)
      }
    }
  }).toList()
  local objectStringCoercionBlock: String = if (!objectStringCoercionFields.isEmpty)
    "    @field_validator(\(pyQuotedCsv(objectStringCoercionFields)), mode=\"before\")\n" +
    "    @classmethod\n" +
    "    def _coerce_json_object_strings(cls, value: Any) -> Any:\n" +
    "        if value is None or isinstance(value, dict):\n" +
    "            return value\n" +
    "        if isinstance(value, str):\n" +
    "            stripped = value.strip()\n" +
    "            if not stripped:\n" +
    "                return {}\n" +
    "            try:\n" +
    "                parsed = json.loads(stripped)\n" +
    "            except json.JSONDecodeError:\n" +
    "                return value\n" +
    "            if isinstance(parsed, dict):\n" +
    "                return parsed\n" +
    "        return value\n\n"
  else ""
  local objectStringCoercionSeparator: String =
    if (!uiFieldLines.isEmpty && !objectStringCoercionBlock.isEmpty) "\n" else ""
  local credFieldLine: String = if (credentialFieldName != null && !skipFields.contains(credentialFieldName!!))
    "    \(credentialFieldName!!): CredentialRef | None = None\n"
  else ""
  local hasPublish = pipeline.publish != null
  local includePublishInputFields = hasPublish && pipeline.publish!!.includeInputFields
  // py-names already emitted from uiConfig — used to deduplicate the publish scaffold
  local uiPyNames: Set<String> = (new Listing {
    for (k, u in props) {
      when (u.includeInInput && !skipFields.contains(toPyName(k))) {
        toPyName(k)
      }
    }
  }).toList().toSet()
  local publishHashExcludeBlock: String = if (includePublishInputFields)
    "    _config_hash_exclude: ClassVar[set[str]] = {\n" +
    "        \"output_dir\",\n" +
    "        \"checkpoint_dir\",\n" +
    "        \"load_to_atlan\",\n" +
    "        \"publish_dry_run\",\n" +
    "    }\n\n"
  else ""
  // Skip scaffold fields already declared via uiConfig to avoid duplicate class members.
  local publishFieldBlock: String = if (includePublishInputFields)
    (if (!uiPyNames.contains("output_dir"))
      "    output_dir: str = \"\"\n" +
      "    \"\"\"Directory for output JSONL files.\"\"\"\n"
    else "") +
    (if (!uiPyNames.contains("checkpoint_dir"))
      "    checkpoint_dir: str = \"\"\n" +
      "    \"\"\"Directory for checkpoint database. If provided, enables incremental extraction.\"\"\"\n"
    else "") +
    (if (!uiPyNames.contains("load_to_atlan"))
      "    load_to_atlan: bool = True\n" +
      "    \"\"\"If True, load extracted metadata to Atlan via publish-app.\"\"\"\n"
    else "") +
    (if (!uiPyNames.contains("publish_dry_run"))
      "    publish_dry_run: bool = False\n" +
      "    \"\"\"When True, skip the Atlas publish step (executor_enabled=False).\"\"\"\n"
    else "")
  else ""
  local classBody: String =
    publishHashExcludeBlock +
    uiFieldLines +
    objectStringCoercionSeparator +
    objectStringCoercionBlock +
    credFieldLine +
    publishFieldBlock
  local usesAnnotated: Boolean = uiFieldLines.contains("Annotated[")
  local usesAny: Boolean = uiFieldLines.contains("dict[str, Any]") || !objectStringCoercionFields.isEmpty
  local usesClassVar: Boolean = includePublishInputFields
  local typingImports: List<String> = (new Listing {
    when (usesAnnotated) {
      "Annotated"
    }
    when (usesAny) {
      "Any"
    }
    when (usesClassVar) {
      "ClassVar"
    }
  }).toList()
  local stdlibImportLines: String =
    (if (!objectStringCoercionFields.isEmpty) "import json\n" else "") +
    (if (!typingImports.isEmpty) "from typing import \(typingImports.join(", "))\n" else "")
  local pydanticImports: List<String> = (new Listing {
    when (uiFieldLines.contains(" = Field(")) {
      "Field"
    }
    when (!objectStringCoercionFields.isEmpty) {
      "field_validator"
    }
  }).toList()
  local pydanticImportLines: String =
    if (!pydanticImports.isEmpty) "from pydantic import \(pydanticImports.join(", "))\n" else ""
  local sdkTypeImports: List<String> = (new Listing {
    when (uiFieldLines.contains(": ConnectionRef") || uiFieldLines.contains("list[ConnectionRef]")) {
      "ConnectionRef"
    }
    when (uiFieldLines.contains(": FileReference")) {
      "FileReference"
    }
    when (uiFieldLines.contains("MaxItems(")) {
      "MaxItems"
    }
  }).toList()
  local firstPartyImportLines: String =
    (if (!sdkTypeImports.isEmpty)
      "from application_sdk.contracts.types import \(sdkTypeImports.join(", "))\n"
    else "") +
    (if (!credFieldLine.isEmpty) "from application_sdk.credentials.ref import CredentialRef\n" else "") +
    "from application_sdk.templates.contracts import ExtractionInput\n"
  local inputImportBlock: String =
    "from __future__ import annotations\n\n" +
    (if (!stdlibImportLines.isEmpty) stdlibImportLines + "\n" else "") +
    (if (!pydanticImportLines.isEmpty) pydanticImportLines + "\n" else "") +
    firstPartyImportLines +
    "\n\n"
  text =
    "# AUTO-GENERATED from contract/app.pkl — DO NOT EDIT MANUALLY.\n" +
    "# To regenerate: pkl eval -m . contract/app.pkl\n" +
    inputImportBlock +
    "class AppInputContract(ExtractionInput):\n" +
    (if (classBody.isEmpty) "    pass\n" else classBody)
}

// ── e2e code generation ───────────────────────────────────────────────────────

// Escape a string for use inside a Python double-quoted literal.
local function escapePyStr(s: String): String =
  s.replaceAll("\\", "\\\\").replaceAll("\"", "\\\"").replaceAll("\n", "\\n").replaceAll("\r", "\\r")

local function capitalizeFirst(s: String): String =
  if (s.isEmpty) s else s.take(1).toUpperCase() + s.drop(1)

local function pascalCase(s: String): String =
  (new Listing {
    for (seg in s.split(Regex("[^A-Za-z0-9]+"))) { capitalizeFirst(seg) }
  }).toList().join("")

// SQL-family categories drive SQLAppE2ETest / SQLMustacheSubstitutions selection.
local function e2eBaseClass(): String =
  let (cat = connector?.category)
  if (cat == "warehouse" || cat == "database" || cat == "lake" || cat == "queryengine")
    "SQLAppE2ETest"
  else "BaseE2ETest"

local function e2eSubsParent(): String =
  let (cat = connector?.category)
  if (cat == "warehouse" || cat == "database" || cat == "lake" || cat == "queryengine")
    "SQLMustacheSubstitutions"
  else "MustacheSubstitutions"

// Fields already provided by MustacheSubstitutions (always skip).
local e2eSubsBaseSkip: Set<String> =
  (new Listing { "credential"; "credential_guid"; "connection" }).toList().toSet()

// Fields added by SQLMustacheSubstitutions (skip when parent is SQL).
local e2eSubsSqlSkip: Set<String> =
  List("extraction_method", "agent_json", "include_filter", "exclude_filter", "exclude_table_regex", "preflight_check")
    .fold(e2eSubsBaseSkip, (acc, elem) -> (acc as Set<String>).add(elem))

local function e2eSubsSkip(): Set<String> =
  if (e2eSubsParent() == "SQLMustacheSubstitutions") e2eSubsSqlSkip
  else e2eSubsBaseSkip

// Line-length-aware Field line: inlines if ≤ 88 chars, wraps otherwise.
local function fmtSubsField(pyName: String, typeStr: String, defaultExpr: String, k: String): String =
  let (inline = "    \(pyName): \(typeStr) = Field(\(defaultExpr), alias=\"{{\(k)}}\")")
  if (inline.length <= 88) inline
  else "    \(pyName): \(typeStr) = Field(\n        \(defaultExpr),\n        alias=\"{{\(k)}}\",\n    )"

// Returns a typed pydantic Field line for a substitution field, or null to skip.
local function getSubsFieldLine(k: String, u: Widgets.UIElement): String? =
  let (pyName = toPyName(k))
  if (u is Widgets.ConnectionCreator || u is Widgets.ConnectionSelector || u is Widgets.ConnectionRefInput)
    null
  else if (u is Widgets.BooleanInput)
    fmtSubsField(pyName, "bool", "default=\(if ((u as Widgets.BooleanInput).default) "True" else "False")", k)
  else if (u is Widgets.Switcher)
    fmtSubsField(pyName, "bool", "default=\(if ((u as Widgets.Switcher).default) "True" else "False")", k)
  else if (u is Widgets.NumericInput)
    let (d = (u as Widgets.NumericInput).default)
    fmtSubsField(pyName, "int", "default=\(if (d != null) d!!.toInt() else 0)", k)
  else if (u is Widgets.Radio)
    let (radio = u as Widgets.Radio)
    let (vals = radio.possibleValues.keys.toList())
    if (!vals.isEmpty)
      let (litStr = (new Listing { for (v in vals) { "\"\(v)\"" } }).toList().join(", "))
      let (defVal = if (radio.default != null) radio.default!! else vals.first)
      fmtSubsField(pyName, "Literal[\(litStr)]", "default=\"\(defVal)\"", k)
    else
      fmtSubsField(pyName, "str", "default=\"\(if (radio.default != null) radio.default!! else "")\"", k)
  else if (u is Widgets.DropDown)
    let (dd = u as Widgets.DropDown)
    let (vals = dd.possibleValues.keys.toList())
    if (!vals.isEmpty && !dd.multiSelect)
      let (litStr = (new Listing { for (v in vals) { "\"\(v)\"" } }).toList().join(", "))
      let (defVal = if (dd.default != null) dd.default!! else vals.first)
      fmtSubsField(pyName, "Literal[\(litStr)]", "default=\"\(defVal)\"", k)
    else
      fmtSubsField(pyName, "str", "default=\"\(if (dd.default != null) dd.default!! else "")\"", k)
  else if (u is Widgets.ConditionalInput)
    let (ci = u as Widgets.ConditionalInput)
    if (ci.outputValueType == "object")
      fmtSubsField(pyName, "dict[str, Any] | None", "default=None", k)
    else if (ci.baseWidgetType == "radio" && ci.baseEnum != null && !ci.baseEnum!!.isEmpty)
      let (litStr = (new Listing { for (v in ci.baseEnum!!) { "\"\(v)\"" } }).toList().join(", "))
      let (defVal = if (ci.default != null) ci.default!!.toString() else ci.baseEnum!!.toList().first)
      fmtSubsField(pyName, "Literal[\(litStr)]", "default=\"\(defVal)\"", k)
    else
      fmtSubsField(pyName, "str", "default=\"\(if (ci.default != null) ci.default!!.toString() else "")\"", k)
  else if (u is Widgets.SqlTree || u is Widgets.NestedInput || u is Widgets.APITree ||
      u is Widgets.ApiTreeSelect || u is Widgets.DsnTreeMap || u is Widgets.AgentSelector)
    fmtSubsField(pyName, "dict[str, Any] | None", "default=None", k)
  else
    // TextInput, PasswordInput, CredentialInput, TextBoxInput, etc. → str
    let (defVal =
      if (u is Widgets.TextInput && (u as Widgets.TextInput).default != null)
        (u as Widgets.TextInput).default!!
      else "")
    fmtSubsField(pyName, "str", "default=\"\(defVal)\"", k)

local function generateE2EBasePy(): FileOutput = new FileOutput {
  local baseClass = e2eBaseClass()
  local cname = pascalCase(name)
  local emitConnType = connector != null && connector!!.value != name
  local emitConnCat = connector != null && connector!!.category != "warehouse"
  text =
    "# Generated from contract/app.pkl via contract-toolkit. DO NOT EDIT.\n" +
    "# Regenerate with: pkl eval -m . contract/app.pkl\n" +
    "from application_sdk.testing.e2e import \(baseClass)\n\n\n" +
    "class \(cname)GeneratedE2EBase(\(baseClass)):\n" +
    "    connector_short_name = \"\(escapePyStr(name))\"\n" +
    "    argo_package_name = \"\(escapePyStr(argoPackageName))\"\n" +
    "    argo_template_name = \"\(escapePyStr(argoTemplateName))\"\n" +
    "    app_service_url = \"\(escapePyStr(appServiceUrl))\"\n" +
    (if (emitConnType) "    connection_type = \"\(escapePyStr(connector!!.value))\"\n" else "") +
    (if (emitConnCat) "    connection_category = \"\(escapePyStr(connector!!.category))\"\n" else "")
}

local function generateE2ESubstitutionsPy(): FileOutput? =
  let (props = uiConfig?.properties ?? Map())
  let (skip = e2eSubsSkip())
  let (fieldLines = (new Listing {
    for (k, u in props) {
      when (!skip.contains(toPyName(k)) && u.includeInInput && getSubsFieldLine(k, u) != null) {
        getSubsFieldLine(k, u)!! + "\n"
      }
    }
  }).toList().fold("", (acc: String, s: String) -> acc + s))
  if (fieldLines.isEmpty) null
  else new FileOutput {
    local parentClass = e2eSubsParent()
    local cname = pascalCase(name)
    local usesLiteral = fieldLines.contains("Literal[")
    local usesAny = fieldLines.contains("dict[str, Any]")
    local typingLine =
      if (usesLiteral && usesAny) "from typing import Any, Literal\n\n"
      else if (usesLiteral) "from typing import Literal\n\n"
      else if (usesAny) "from typing import Any\n\n"
      else ""
    local parentImport =
      if (parentClass == "SQLMustacheSubstitutions")
        "from application_sdk.testing.e2e.substitutions import SQLMustacheSubstitutions\n"
      else
        "from application_sdk.testing.e2e.substitutions import MustacheSubstitutions\n"
    text =
      "# Generated from contract/app.pkl via contract-toolkit. DO NOT EDIT.\n" +
      "# Regenerate with: pkl eval -m . contract/app.pkl\n" +
      "from __future__ import annotations\n\n" +
      typingLine +
      "from pydantic import Field\n\n" +
      parentImport +
      "\n\nclass \(cname)MustacheSubstitutions(\(parentClass)):\n" +
      fieldLines
  }

// Returns a typed Field line for a single FieldSpec in a CredentialBody class.
// authSpecific=true means the field only appears in some auth options (always use a default).
local function credFieldLine(f: FieldSpec, authSpecific: Boolean): String =
  let (pyName = toPyName(f.name))
  let (pyType = if (f.fieldType == "number") "int" else "str")
  let (defExpr =
    if (f.defaultValue != null)
      if (f.fieldType == "number") f.defaultValue!! else "\"" + f.defaultValue!! + "\""
    else if (authSpecific || !f.required)
      if (f.fieldType == "number") "0" else "\"\""
    else "")
  if (defExpr.isEmpty)
    "    \(pyName): \(pyType) = Field(alias=\"\(f.name)\")"
  else
    "    \(pyName): \(pyType) = Field(default=\(defExpr), alias=\"\(f.name)\")"

local function generateE2ECredentialPy(): FileOutput? =
  if (!(hasCredentialConfig && credentialAuthOptions != null && !credentialAuthOptions!!.isEmpty))
    null
  else new FileOutput {
    local cname = pascalCase(name)

    // Default auth type: honour credentialAuthDefault when set, fall back to first key.
    local firstAuthKey: String =
      credentialAuthDefault ??
      (new Listing { for (k, v in credentialAuthOptions!!) { k } }).toList().first

    // Common top-level FieldSpec entries from either credentialUrlGroup or credentialCommonFields.
    local commonSpecs: List<FieldSpec> = (new Listing {
      when (credentialUrlGroup != null) {
        credentialUrlGroup!!.hostField
        credentialUrlGroup!!.portField
        for (f in credentialUrlGroup!!.extraFields) {
          when (f is FieldSpec) { f }
        }
      }
      when (credentialUrlGroup == null) {
        for (f in credentialCommonFields) {
          when (f is FieldSpec) { f }
        }
      }
    }).toList()

    local condCommonSpecs: List<ConditionalFieldSpec> = (new Listing {
      when (credentialUrlGroup != null) {
        for (f in credentialUrlGroup!!.extraFields) {
          when (f is ConditionalFieldSpec) { f }
        }
      }
      when (credentialUrlGroup == null) {
        for (f in credentialCommonFields) {
          when (f is ConditionalFieldSpec) { f }
        }
      }
    }).toList()

    // Set of field names already in the common group (used to exclude from auth-specific).
    local commonNameSet: Set<String> =
      (new Listing { for (f in commonSpecs) { f.name } }).toList().toSet()

    // Deduplicated auth-specific top-level FieldSpecs (first occurrence per name, excluding common).
    local allAuthTopRaw: List<FieldSpec> = (new Listing {
      for (key, opt in credentialAuthOptions!!) {
        for (f in opt.fields) {
          when (f is FieldSpec) { f }
        }
      }
    }).toList()

    local authTopDeduped: List<FieldSpec> =
      allAuthTopRaw
        .filter((f: FieldSpec) -> !commonNameSet.contains(f.name))
        .fold(
          List(),
          (acc: List<FieldSpec>, f: FieldSpec) ->
            if ((new Listing { for (s in acc) { s.name } }).toList().contains(f.name)) acc
            else acc.add(f)
        )

    // Collect all extra FieldSpecs from auth options (for the nested Extra model).
    local sharedExtraSpecs: List<FieldSpec> = (new Listing {
      for (f in credentialSharedExtraFields) {
        when (f is FieldSpec) { f }
      }
    }).toList()

    local sharedExtraNames: Set<String> =
      (new Listing { for (f in sharedExtraSpecs) { f.name } }).toList().toSet()

    local allAuthExtraRaw: List<FieldSpec> = (new Listing {
      for (key, opt in credentialAuthOptions!!) {
        for (f in opt.extraFields) {
          when (f is FieldSpec) { f }
        }
      }
    }).toList()

    // Extra model: sharedExtraSpecs + auth-specific extras, deduped.
    local allExtraSpecs: List<FieldSpec> =
      allAuthExtraRaw.fold(
        sharedExtraSpecs,
        (acc: List<FieldSpec>, f: FieldSpec) ->
          if (sharedExtraNames.contains(f.name) ||
              (new Listing { for (s in acc) { s.name } }).toList().contains(f.name))
            acc
          else acc.add(f)
      )

    local hasExtraModel = !allExtraSpecs.isEmpty

    // Build field line blocks.
    local commonLines = (new Listing {
      for (f in commonSpecs) { credFieldLine(f, false) + "\n" }
    }).toList().fold("", (acc: String, s: String) -> acc + s)

    local condCommonLines = (new Listing {
      for (f in condCommonSpecs) {
        "    " + toPyName(f.name) + ": str | None = Field(default=None, alias=\"" + f.name + "\")\n"
      }
    }).toList().fold("", (acc: String, s: String) -> acc + s)

    local authTopLines = (new Listing {
      for (f in authTopDeduped) { credFieldLine(f, true) + "\n" }
    }).toList().fold("", (acc: String, s: String) -> acc + s)

    local extraFieldProp: String =
      if (hasExtraModel)
        let (line = "    extra: \(cname)CredentialBodyExtra = Field(default_factory=\(cname)CredentialBodyExtra, alias=\"extra\")")
        (if (line.length <= 88) line
        else "    extra: \(cname)CredentialBodyExtra = Field(\n        default_factory=\(cname)CredentialBodyExtra, alias=\"extra\"\n    )") + "\n"
      else ""

    local extraModelLines = (new Listing {
      for (f in allExtraSpecs) { credFieldLine(f, true) + "\n" }
    }).toList().fold("", (acc: String, s: String) -> acc + s)

    local mainClassBody =
      "    name: str = Field(alias=\"name\")\n" +
      "    auth_type: str = Field(default=\"\(firstAuthKey)\", alias=\"authType\")\n" +
      commonLines +
      condCommonLines +
      authTopLines +
      extraFieldProp

    local extraModelBlock =
      if (hasExtraModel)
        "\n\nclass \(cname)CredentialBodyExtra(BaseModel):\n" +
        "    model_config = ConfigDict(frozen=True, populate_by_name=True, serialize_by_alias=True)\n\n" +
        extraModelLines
      else ""

    local hasPipeType =
      mainClassBody.contains(" | None") || extraModelLines.contains(" | None")

    local pydanticImports: List<String> = (new Listing {
      "Field"
      when (hasExtraModel) { "BaseModel"; "ConfigDict" }
    }).toList()

    text =
      "# Generated from contract/app.pkl via contract-toolkit. DO NOT EDIT.\n" +
      "# Regenerate with: pkl eval -m . contract/app.pkl\n" +
      (if (hasPipeType) "from __future__ import annotations\n\n" else "") +
      "from pydantic import \(pydanticImports.join(", "))\n\n" +
      "from application_sdk.testing.e2e.credential import CredentialBody\n" +
      extraModelBlock +
      "\n\nclass \(cname)CredentialBody(CredentialBody):\n" +
      mainClassBody
  }

// ── atlan.yaml generation ─────────────────────────────────────────────────────

local function asMapping(value: Any): Mapping<String, Any>? =
  if (value is Mapping<String, Any>)
    value as Mapping<String, Any>
  else if (value is Dynamic)
    new Mapping {
      for (key, member in (value as Dynamic).toMap()) {
        [key] = member
      }
    }
  else null

local function deepMerge(base: Any, patch: Any): Any =
  let (baseMap = asMapping(base))
  let (patchMap = asMapping(patch))
  if (baseMap != null && patchMap != null)
    deepMergeMapping(baseMap!!, patchMap!!)
  else patch

local function deepMergeMapping(base: Mapping<String, Any>, patch: Mapping<String, Any>): Mapping<String, Any> =
  new Mapping {
    for (key, value in base) {
      [key] = if (patch.containsKey(key)) deepMerge(value, patch[key]) else value
    }
    for (key, value in patch) {
      when (!base.containsKey(key)) {
        [key] = value
      }
    }
  }

local function renderEntrypoint(e: Entrypoint): Mapping<String, Any> = new Mapping {
  when (e.id != null) { ["id"] = e.id }
  ["name"] = e.name
  ["display_name"] = e.displayName
  when (e.description != null) { ["description"] = e.description }
  when (e.iconUrl != null || iconUrl != null) { ["icon_url"] = e.iconUrl ?? iconUrl }
  ["type"] = e.type
  when (e.source != null) { ["source"] = e.source }
  when (e.sourceCategory != null) { ["source_category"] = e.sourceCategory }
  when (!e.categories.isEmpty) { ["categories"] = e.categories }
  when (e.docsUrl != null) { ["docs_url"] = e.docsUrl }
  ...e.metadata
}

local function renderDeployConfig(d: DeployConfig): Mapping<String, Any> = new Mapping {
  ["execution_mode"] = d.executionMode
  ["splitDeploymentEnabled"] = d.splitDeployment
  when (d.replicaCount != null) { ["replicaCount"] = d.replicaCount }
  ["dapr"] = new Mapping {
    ["objectstore"] = d.dapr.objectstore
    ["secretstore"] = d.dapr.secretstore
    ["statestore"] = d.dapr.statestore
    ["eventstore"] = d.dapr.eventstore
    ["subscription"] = d.dapr.subscription
    ["configurationstore"] = d.dapr.configurationstore
    ["lock"] = d.dapr.lock
    for (k, v in d.dapr.customComponents) {
      [k] = v
    }
  }
  ["keda"] = new Mapping {
    ["enabled"] = d.keda.enabled
    when (d.keda.enabled) {
      ["minReplicaCount"] = d.keda.minReplicaCount
      ["temporal"] = new Mapping {
        ["targetQueueSize"] = d.keda.temporal.targetQueueSize
      }
    }
  }
  when (d.resources != null) {
    ["resources"] = new Mapping {
      when (!d.resources!!.requests.isEmpty) { ["requests"] = d.resources!!.requests }
      when (!d.resources!!.limits.isEmpty) { ["limits"] = d.resources!!.limits }
    }
  }
  when (!d.env.isEmpty) { ["env"] = d.env }
  when (!d.envOverrides.isEmpty) { ["envOverrides"] = d.envOverrides }
}

local effectiveEntrypoints: Listing<Entrypoint> =
  if (!entrypoints.isEmpty) entrypoints
  else
    let (_name = name)
    let (_displayName = displayName)
    let (_iconUrl = iconUrl)
    let (_type = type)
    new Listing {
      new Entrypoint {
        name = _name
        displayName = _displayName
        iconUrl = _iconUrl
        type = _type
      }
    }

local generatedAtlanYamlData: Mapping<String, Any> = new Mapping {
  ["name"] = name
  when (appId != "") { ["app_id"] = appId }
  ["display_name"] = displayName
  when (creatorOrg != null) { ["creator_org"] = creatorOrg }
  ["type"] = type
  ["execution_mode"] = deploy.executionMode
  when (iconUrl != null) { ["icon_url"] = iconUrl }
  ["visibility"] = visibility
  ["build_tag"] = buildTag
  ["self_deployed_runtime"] = selfDeployedRuntime
  when (emitEntrypoints) {
    ["entrypoints"] = new Listing {
      for (ep in effectiveEntrypoints) {
        renderEntrypoint(ep)
      }
    }
  }
  ["deploy"] = deepMergeMapping(renderDeployConfig(deploy), deployOverrides)
}

local atlanYamlData: Mapping<String, Any> =
  deepMergeMapping(deepMergeMapping(generatedAtlanYamlData, metadata), atlanYamlOverrides)

local generatedYamlHeader: String =
  "# AUTO-GENERATED from contract/app.pkl — DO NOT EDIT MANUALLY.\n" +
  "# To regenerate: pkl eval -m . contract/app.pkl\n"

local atlanYamlOutput: FileOutput = new FileOutput {
  value = atlanYamlData
  renderer = new YamlRenderer {}
  text = generatedYamlHeader + renderer.renderDocument(value)
}

local appYamlOutput: FileOutput = new FileOutput {
  value = new Mapping<String, Any> {
    ["app_name"] = name
    ["app_image"] = "${APP_IMAGE}"
    ["app_port"] = 8000
  }
  renderer = new YamlRenderer {}
  text = generatedYamlHeader + renderer.renderDocument(value)
}

// ── Multi-entrypoint credential dedup (from NativeAppBundle.pkl) ──────────────

class ContractFile {
  name: String
  output: FileOutput
}

// App.pkl contracts emit full repo-root paths ("app/generated/foo.json",
// "atlan.yaml"). In bundle mode we need bare artifact names ("foo.json") for
// dedup keys and per-entrypoint path construction. Bundle-owned root files
// (atlan.yaml, app.yaml) are skipped — returns "" as a skip sentinel.
local function normalizeContractFileName(fileName: String): String =
  let (prefix = "app/generated/")
  if (fileName == "atlan.yaml" || fileName == "app.yaml") ""
  else if (fileName.startsWith(prefix)) fileName.drop(prefix.length)
  else fileName

local function isCredentialFile(entrypoint: Entrypoint, rawFileName: String): Boolean =
  let (normalized = normalizeContractFileName(rawFileName))
  normalized != "" &&
  entrypoint.contract != null &&
  entrypoint.contract!!.hasCredentialConfig &&
  normalized == "\(entrypoint.contract!!.connectorConfigName).json"

local credentialFiles: Listing<ContractFile> = new Listing {
  for (entrypoint in entrypoints) {
    when (entrypoint.contract != null) {
      for (fileName, fileOutput in entrypoint.contract!!.output.files) {
        when (isCredentialFile(entrypoint, fileName)) {
          new ContractFile {
            name = normalizeContractFileName(fileName)
            output = fileOutput
          }
        }
      }
    }
  }
}

local credentialFileGroups: Map<String, List<ContractFile>> =
  credentialFiles.toList().groupBy((file) -> file.name)

local credentialConflictNames: List<String> =
  credentialFileGroups.keys.toList().filter((fileName) ->
    let (files = credentialFileGroups[fileName])
    !files.every((file) -> file.output.text == files.first.output.text)
  )

hidden _credentialConflictCheck: Any =
  if (!credentialConflictNames.isEmpty)
    throw("App.pkl found credential config filename(s) generated with different content: \(credentialConflictNames.join(", ")). "
      + "Use unique connectorConfigName values for different credentials, or share one identical config definition.")
  else null

// ────────────────────────────────────────────────────────────────────────────
// OUTPUT BLOCK
// ────────────────────────────────────────────────────────────────────────────

output =
  let (_jdbcCheck = jdbcInvariant)
  let (_connectorCheck = connectorInvariant)
  let (_credCheck = _credentialConflictCheck)
  let (_e2eCredOutput = generateE2ECredentialPy())
  let (_e2eSubsOutput = generateE2ESubstitutionsPy())
  new ModuleOutput {
    files = new Mapping {

      // ── repo-root files ────────────────────────────────────────────────────
      when (emitAtlanYaml) {
        ["atlan.yaml"] = atlanYamlOutput
      }
      when (emitAppYaml) {
        ["app.yaml"] = appYamlOutput
      }

      // ── single-entrypoint mode ────────────────────────────────────────────
      when (entrypoints.isEmpty) {
        // uiConfig-dependent runtime artifacts
        when (uiConfig != null) {
          ["app/generated/\(workflowConfigName).json"] = workflowConfigOutput
          when (hasCredentialConfig && credentialAuthOptions != null) {
            ["app/generated/\(connectorConfigName).json"] = credentialConfigOutput
          }
          ["app/generated/manifest.json"] = manifestOutput
          ["app/generated/_input.py"] = generateInputClassPy()
          ["app/generated/__init__.py"] = new FileOutput { text = "" }
        }
        // e2e test-harness artifacts (independent of uiConfig)
        ["app/generated/_e2e_base.py"] = generateE2EBasePy()
        when (_e2eCredOutput != null) {
          ["app/generated/_e2e_credential.py"] = _e2eCredOutput!!
        }
        when (_e2eSubsOutput != null) {
          ["app/generated/_e2e_substitutions.py"] = _e2eSubsOutput!!
        }
      }

      // ── multi-entrypoint mode (entrypoints is non-empty) ──────────────────
      when (!entrypoints.isEmpty) {
        // hoisted credential files (deduped by filename)
        for (fileName, files in credentialFileGroups) {
          ["app/generated/\(fileName)"] = files.first.output
        }
        // per-entrypoint artifacts under app/generated/{entrypoint.name}/
        when (emitGeneratedArtifacts) {
          for (entrypoint in entrypoints) {
            when (entrypoint.contract != null) {
              for (fileName, fileOutput in entrypoint.contract!!.output.files) {
                when (normalizeContractFileName(fileName) != "" && !isCredentialFile(entrypoint, fileName)) {
                  ["app/generated/\(entrypoint.name)/\(normalizeContractFileName(fileName))"] = fileOutput
                }
              }
            }
          }
        }
      }

    }
  }
