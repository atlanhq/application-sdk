/// Widget that conditionally changes its rendering based on form state or feature flags.
/// Generates a `type: "conditional"` property with a `conditions` array.
///
/// The base widget defaults to `"radio"`, but can be changed via `baseWidgetType`
/// to support patterns like sqltree-in-direct-mode / text-input-in-agent-mode.
///
/// | Field | | Description | Default |
/// |---|---|---|---|
/// | **`title`** | | name to show in the UI for the widget | |
/// | `baseWidgetType` | | base widget type for the UI | `"radio"` |
/// | `baseEnum` | | base enum values | |
/// | `baseEnumNames` | | base enum display names | |
/// | `default` | | default value | |
/// | `conditions` | | conditions that override base rendering | |
/// | `required` | | whether a value must be selected to proceed with the UI setup | `false` |
/// | `hide` | | whether the widget will be shown in the UI (false) or not (true) | `false` |
/// | `helpText` | | informational text to place in a hover-over to describe the use of the input | `""` |
class ConditionalInput extends UIElement {
  fixed type = "conditional"
  required: Boolean? = false

  /// Base widget type for the UI rendering. Defaults to "radio".
  /// Set to "sqltree" for conditional metadata trees, "connection" for
  /// conditional connections, etc.
  hidden baseWidgetType: String = "radio"

  /// Base enum values.
  hidden baseEnum: Listing<String>?

  /// Base enum display names.
  hidden baseEnumNames: Listing<String>?

  /// Default value.
  default: Any?

  /// Conditions that override base rendering.
  conditions: Listing<Condition>?

  /// Additional properties (e.g., for sqltree sub-schemas).
  additionalProperties: Dynamic?

  /// (Optional) Placeholder text.
  hidden placeholderText: String?

  /// (Optional) Validation rules.
  hidden validationRules: Listing<Dynamic>?

  /// Python/Input value type for this conditional field. Set to `"object"` when
  /// a condition renders an object-producing widget such as `dsnTreeMap`.
  hidden outputValueType: String = if (baseWidgetType == "sqltree" || baseWidgetType == "apitree" || baseWidgetType == "apiTreeSelect" || baseWidgetType == "dsnTreeMap") "object" else "string"

  /// Generic UI `type` for base widgets such as InfoBanner.
  hidden uiType: String?

  /// Generic UI content for base widgets such as InfoBanner.
  hidden content: String?

  /// Generic UI icon for base widgets such as InfoBanner.
  hidden iconName: String?

  /// Whether to hide the icon for base widgets such as InfoBanner.
  hidden hideWidgetIcon: Boolean?

  /// Generic UI link object for base widgets such as InfoBanner.
  hidden linkConfig: Any?

  /// Generic UI config object for base widgets such as dsnTreeMap.
  hidden widgetConfig: Any?

  /// Configuration for sage/sageV2 preflight checks when the base widget is sage.
  hidden checks: Listing<Dynamic>?

  // --- SqlTree-specific properties (used when baseWidgetType = "sqltree") ---

  /// SQL query for browsing the metadata tree.
  hidden sqlQuery: String?

  /// Variable containing the GUID of the credential.
  hidden credentialRef: String?

  /// Connector config name for the credential.
  hidden connectorConfig: String?

  /// Schema name patterns to exclude from the tree display.
  hidden schemaExcludePatterns: List<String>?

  /// Database/catalog name patterns to exclude from the tree display.
  hidden databaseExcludePatterns: List<String>?

  /// Description text shown below the widget label.
  hidden desc: String?

  /// Whether multiple objects can be selected.
  hidden multiSelect: Boolean?

  /// Sibling form field whose value scopes a sqltree branch. Emitted as
  /// `dependentConnectionField` when set.
  hidden dependsOn: String?

  /// For sqltree branches — whether database/catalog nodes are non-selectable.
  /// Emitted as `areDatabasesUnselectable` when set.
  hidden databasesUnselectable: Boolean?

  // --- Connection-specific properties (used when baseWidgetType = "connection") ---

  /// Whether to show connection options dropdown.
  hidden connOptions: Boolean?

  // --- Credential-specific properties (used when baseWidgetType = "credential") ---

  /// Type of credential to be nested within the widget.
  hidden credentialType: String?

  /// Whether to show the credential widget's Test Authentication button.
  hidden allowTestAuthentication: Boolean?

  /// Display labels keyed by auth type in credential view mode.
  hidden authTypeVsLabel: Mapping<String, String>?

  /// Credential summary fields to hide in view mode.
  hidden hiddenFields: Listing<String>?

  /// Extra credential fields to render in view mode.
  hidden additionalDisplayFields: Listing<Dynamic>?

  /// (Generated) Enum keys derived from baseEnum.
  fixed enum: List<String>? = if (baseEnum != null) baseEnum.toList() else null

  /// (Generated) Enum display names derived from baseEnumNames.
  fixed enumNames: List<String>? = if (baseEnumNames != null) baseEnumNames.toList() else null

  /// (Generated) Internal configuration for the UI's rendering.
  fixed ui {
    widget = baseWidgetType
    placeholder = placeholderText
    rules = validationRules
    config = if (widgetConfig != null) widgetConfig else checks
    type = outer.uiType
    content = outer.content
    icon = outer.iconName
    hideIcon = outer.hideWidgetIcon
    link = outer.linkConfig
    // sqltree properties (null/omitted when not a sqltree)
    sql = sqlQuery
    credential = credentialRef
    connectorConfigName = connectorConfig
    schemaExcludePattern = schemaExcludePatterns
    databaseExcludePattern = databaseExcludePatterns
    description = desc
    multiple = multiSelect
    dependentConnectionField = dependsOn
    areDatabasesUnselectable = databasesUnselectable
    // connection properties (null/omitted when not a connection)
    connectionOptions = connOptions
    // credential properties (null/omitted when not a credential)
    credentialType = outer.credentialType
    isTestAuthenticationDisabled = if (allowTestAuthentication != null) !allowTestAuthentication else null
    authTypeVsLabel = outer.authTypeVsLabel
    hiddenFields = outer.hiddenFields
    additionalDisplayFields = outer.additionalDisplayFields
  }
}

/// A condition that overrides rendering when a form property, lab flag, or feature flag matches.
class Condition {
  /// Form property to check.
  property: String?

  /// Value that triggers this condition.
  value: Any?

  /// Lab flag that triggers this condition.
  labFlag: String?

  /// Feature flag that triggers this condition.
  featureFlag: String?

  /// Compound boolean filter (`$and`/`$or` tree) evaluated against sibling form fields.
  /// When set, emitted verbatim alongside `ui`; `property`/`value` are typically left null.
  /// Use to express multi-property conditions like SAP's connection-type/extraction-method combo.
  filter: Dynamic?

  /// Override enum values when condition matches.
  hidden overrideEnum: Listing<String>?

  /// Override enum display names when condition matches.
  hidden overrideEnumNames: Listing<String>?

  /// Override required flag when condition matches.
  hidden overrideRequired: Boolean?

  /// Override default value when condition matches.
  hidden overrideDefault: Any?

  /// Override property type when condition matches.
  hidden overrideType: String?

  /// Override ui widget when condition matches.
  hidden overrideUi: (Widget|Mapping<String, Any>)? = null

  /// (Generated) Override enum keys.
  fixed enum: List<String>? = if (overrideEnum != null) overrideEnum.toList() else null

  /// (Generated) Override enum display names.
  fixed enumNames: List<String>? = if (overrideEnumNames != null) overrideEnumNames.toList() else null

  /// (Generated) Override required.
  fixed required: Boolean? = overrideRequired

  /// (Generated) Override default.
  fixed default: Any? = overrideDefault

  /// (Generated) Override type.
  fixed type: String? = overrideType

  /// (Generated) Override ui.
  fixed ui: (Widget|Mapping<String, Any>)? = overrideUi
}

/// Widget that renders a repeatable list of text input fields for entering multiple string values.
