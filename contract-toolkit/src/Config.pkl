/// |---|---|---|---|
/// | **`title`** | | name to show in the UI for the widget | |
/// | `required` | | whether at least one value must be entered | `false` |
/// | `hide` | | whether the widget will be shown in the UI (false) or not (true) | `false` |
/// | `helpText` | | informational text to place in a hover-over to describe the use of the input | `""` |
/// | `placeholderText` | | example text to place within each input field | `""` |
/// | `width` | | sizing of the input on the UI (8 is full-width, 4 is half-width) | `8` |
class InputRepeater extends UIElement {
  fixed type = "object"
  required: Boolean? = false

  /// Example text to place within each repeatable input field.
  hidden placeholderText: String = ""

  /// (Optional) Validation rules for the field.
  hidden validationRules: Listing<Dynamic>?

  /// (Generated) Internal configuration for the UI's rendering.
  fixed ui {
    widget = "inputRepeater"
    placeholder = placeholderText
    rules = validationRules
  }
}

/// Create an `evaluate` widget override for use inside `Condition.overrideUi`.
///
/// The evaluate widget is a hidden computed field — it derives a value from other
/// form selections without rendering any visible UI (like `<input type="hidden">`).
/// It is used inside `ConditionalInput` conditions to map an upstream field's
/// value into a workflow form-state key.
///
/// Example:
/// ```
/// new Config.Condition {
///   property = "credential-guid.auth-type"
///   value = "ru"
///   overrideUi = Config.evaluateWidget("ru")
/// }
/// ```
const function evaluateWidget(val: String): Widget = new Widget {
  widget = "evaluate"
  value = val
}

/// Widget that renders a cron schedule picker.
///
/// | Field | | Description | Default |
/// |---|---|---|---|
/// | **`title`** | | name to show in the UI for the widget | |
/// | `required` | | whether a schedule must be set to proceed | `false` |
/// | `hide` | | whether the widget will be shown in the UI (false) or not (true) | `false` |
/// | `helpText` | | informational text to place in a hover-over to describe the use of the input | `""` |
class Schedule extends UIElement {
  fixed type = "string"
  required: Boolean? = false

  /// (Generated) Internal configuration for the UI's rendering.
  fixed ui {
    widget = "schedule"
  }
}

/// Escape hatch for bespoke frontend widgets not covered by the typed widget catalog.
/// Emits a `ui` object with the given `widgetName` plus any arbitrary `props` passed
/// through verbatim. Use sparingly — prefer a typed widget class when the widget is
/// reusable across connectors. `CustomWidget` is for connector-specific components
/// like `FivetranDeprecationWarning`, `FivetranPrerequisites`, etc.
///
/// Example:
/// ```
/// ["deprecation-warning"] = new Config.CustomWidget {
///   title = ""
///   widgetName = "FivetranDeprecationWarning"
///   props {
///     ["link"] = "https://ask.atlan.com/…"
///     ["endDate"] = 1714521600000
///     ["style"] = new Dynamic { marginBottom = "1rem" }
///   }
/// }
/// ```
///
/// | Field | | Description | Default |
/// |---|---|---|---|
/// | **`widgetName`** | | string emitted as the `widget` field — picks the frontend component | |
/// | `props` | | arbitrary key/value map merged into the `ui` object verbatim | |
/// | `valueType` | | JSON-schema `type` for the property (most custom widgets are presentational → `"string"`) | `"string"` |
/// | `required` | | whether a value must be set to proceed | `false` |
class CustomWidget extends UIElement {
  /// JSON-schema type for the emitted property. Custom widgets are typically
  /// presentational (banners, warnings) and should stay as `"string"`.
  hidden valueType: String = "string"
  fixed type = valueType
  required: Boolean? = false

  /// Frontend component name emitted as the `widget` field in the ui object.
  hidden widgetName: String

  /// Pass-through properties merged into the `ui` object verbatim. Values are
  /// emitted as-is to JSON — mappings become objects, listings become arrays,
  /// `Dynamic` blocks become nested objects. Do not re-declare `widget` here.
  hidden props: Mapping<String, Any>?

  /// (Generated) Internal configuration for the UI's rendering. Unlike typed
  /// widgets, this emits a plain `Mapping<String, Any>` so arbitrary props
  /// pass through without being constrained to the `Widget` shape.
  fixed ui: Mapping<String, Any> = new Mapping {
    ["widget"] = widgetName
    when (props != null) {
      for (k, v in props!!) {
        [k] = v
      }
    }
  }
}
