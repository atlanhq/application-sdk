// Tests for compound-filter support on conditional credential fields.
// Ground truth: packages/atlan/connectors/configmaps/sap-s4.yaml (basic.extra.sap-port).

amends "pkl:test"

import "pkl:json"
import "../src/Config.pkl"
import "../src/NativeApp.pkl"
import "../src/Connectors.pkl"
import "../examples/sap-s4/app.pkl" as sapS4App

local renderer = new JsonRenderer { indent = "  " }

local credJson: String = sapS4App.output.files["atlan-connectors-sap-s4.json"].text

// ---------------------------------------------------------------------------
// Test 1: Condition accepts a compound `filter` field (pass-through Dynamic)
// ---------------------------------------------------------------------------

local sapPortCondition0: Config.Condition = new {
  filter = new Dynamic {
    `$or` {
      new Dynamic {
        `$and` {
          new Dynamic { ["extraction-method"] = "agent" }
          new Dynamic { ["agent-json.basic.extra.connection-type"] = "0" }
        }
      }
      new Dynamic {
        `$and` {
          new Dynamic { ["extraction-method"] = "direct" }
          new Dynamic { ["credential-guid.basic.extra.connection-type"] = "0" }
        }
      }
    }
  }
  overrideUi = new Config.Widget {
    widget = ""
    label = "Port"
    `hidden` = true
    placeholder = "Port"
  }
}

local sapPortCondition0Json: String = renderer.renderValue(sapPortCondition0)

// ---------------------------------------------------------------------------
// Test 3: AuthOption.extraFields accepts a Config.ConditionalInput
// ---------------------------------------------------------------------------

local authOpt: NativeApp.AuthOption = new {
  label = "Basic Authentication"
  fields {
    new NativeApp.FieldSpec { name = "username" }
    new NativeApp.FieldSpec { name = "password"; sensitive = true }
  }
  extraFields {
    new NativeApp.FieldSpec { name = "connection-type"; fieldType = "select"; options { "0"; "1" } }
    new Config.ConditionalInput {
      title = ""
      required = false
      conditions {
        sapPortCondition0
      }
    }
  }
}

facts {
  ["Condition accepts a filter with nested $or/$and"] {
    sapPortCondition0.filter != null
  }
  ["Condition with filter has no property/value"] {
    sapPortCondition0.property == null
    sapPortCondition0.value == null
  }
  ["rendered JSON contains compound filter tree"] {
    sapPortCondition0Json.contains("\"$or\"")
    sapPortCondition0Json.contains("\"$and\"")
    sapPortCondition0Json.contains("\"extraction-method\": \"agent\"")
    sapPortCondition0Json.contains("\"agent-json.basic.extra.connection-type\": \"0\"")
    sapPortCondition0Json.contains("\"credential-guid.basic.extra.connection-type\": \"0\"")
  }
  ["rendered JSON omits null property/value keys"] {
    !sapPortCondition0Json.contains("\"property\"")
    !sapPortCondition0Json.contains("\"value\"")
  }
  ["AuthOption.extraFields accepts a ConditionalInput"] {
    authOpt.extraFields.length == 2
  }
  ["generated credential JSON contains the conditional field at basic.extra.sap-port"] {
    credJson.contains("\"sap-port\"")
  }
  ["generated credential JSON contains the compound filter"] {
    credJson.contains("\"$or\"")
    credJson.contains("\"$and\"")
    credJson.contains("\"agent-json.basic.extra.connection-type\": \"1\"")
    credJson.contains("\"credential-guid.basic.extra.connection-type\": \"1\"")
  }
  ["generated credential JSON marks field type as conditional"] {
    credJson.contains("\"type\": \"conditional\"")
  }
  ["both branches of connection-type are emitted"] {
    credJson.contains("\"agent-json.basic.extra.connection-type\": \"0\"")
    credJson.contains("\"agent-json.basic.extra.connection-type\": \"1\"")
    credJson.contains("\"credential-guid.basic.extra.connection-type\": \"0\"")
    credJson.contains("\"credential-guid.basic.extra.connection-type\": \"1\"")
  }
  ["branch A hides the port, branch B shows it with SAP Port placeholder"] {
    credJson.contains("\"placeholder\": \"Port\"")
    credJson.contains("\"placeholder\": \"SAP Port\"")
    credJson.contains("\"hidden\": true")
  }
}
