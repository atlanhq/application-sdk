/// Unit tests for `credentialExtraAnyOfRules` — arbitrary `UIRule` branches
/// appended to the generated credential `anyOf` block, beyond the
/// auto-generated auth-type conditional-requirement branches.
amends "pkl:test"

import "pkl:json"
import "../src/App.pkl" as App
import "../src/Connectors.pkl"

// Plain auth-type flow with an extra rule keyed on a non-auth-type input.
local appPlain = (App) {
  name = "extra-anyof-plain"
  displayName = "Extra AnyOf Plain"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"

  credentialCommonFields {
    new App.FieldSpec {
      name = "enable_ssl"
      displayName = "Enable SSL"
      fieldType = "checkbox"
      defaultValue = "true"
      required = false
    }
    new App.FieldSpec { name = "ssl_cert"; displayName = "SSL Certificate"; required = false }
  }

  credentialAuthOptions {
    ["basic"] = new App.AuthOption {
      label = "Basic"
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  credentialExtraAnyOfRules {
    new App.UIRule {
      whenInputs { ["enable_ssl"] = "true" }
      required { "ssl_cert" }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-extra-anyof-plain"
          }
        }
      }
    }
  }
}

// Same shape, but no extra rules — backward-compat baseline.
local appNoRules = (App) {
  name = "extra-anyof-none"
  displayName = "Extra AnyOf None"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"

  credentialAuthOptions {
    ["basic"] = new App.AuthOption {
      label = "Basic"
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-extra-anyof-none"
          }
        }
      }
    }
  }
}

// JDBC-URL flow with an extra rule — the anyOf lives inside the jdbcUrl object.
local appJdbc = (App) {
  name = "extra-anyof-jdbc"
  displayName = "Extra AnyOf JDBC"
  connector = Connectors.TERADATA
  icon = "https://example.com/icon.svg"

  credentialUrlGroup = new App.AdvancedJDBCUrlGroup {
    protocol = ""
    urlAddonBefore = "driver://"
    hostField = new App.FieldSpec { name = "host"; displayName = "Host" }
    portField = new App.FieldSpec {
      name = "port"; fieldType = "number"; displayName = "Port"; defaultValue = "1025"; required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new App.JDBCUrlAuthOption {
      label = "Basic"
      nestedLabel = "Basic"
      urlPartMapping = new App.UrlPartMapping {
        hostname = "host"
        searchParams { ["PORT"] = new App.UrlRef { field = "port" } }
      }
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  credentialExtraAnyOfRules {
    new App.UIRule {
      whenInputs { ["connectBy"] = "url" }
      required { "extra.compiled_url" }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-extra-anyof-jdbc"
          }
        }
      }
    }
  }
}

local parser = new json.Parser { useMapping = true }

local plainCredential =
  parser.parse(appPlain.output.files["app/generated/atlan-connectors-extra-anyof-plain.json"].text)
local noRulesCredential =
  parser.parse(appNoRules.output.files["app/generated/atlan-connectors-extra-anyof-none.json"].text)
local jdbcCredential =
  parser.parse(appJdbc.output.files["app/generated/atlan-connectors-extra-anyof-jdbc.json"].text)

local plainAnyOf = plainCredential["config"]["anyOf"]
local noRulesAnyOf = noRulesCredential["config"]["anyOf"]
local jdbcAnyOf = jdbcCredential["config"]["properties"]["jdbcUrl"]["anyOf"]

facts {
  ["default is empty: an app without rules keeps only the auth-type branch"] {
    appNoRules.credentialExtraAnyOfRules.isEmpty
    noRulesAnyOf.length == 1
    noRulesAnyOf[0]["properties"]["auth-type"]["const"] == "basic"
  }

  ["plain flow appends the extra rule after the auth-type branch"] {
    appPlain.credentialExtraAnyOfRules.length == 1
    plainAnyOf.length == 2
    // Auth-type branch first, extra rule appended last.
    plainAnyOf[0]["properties"]["auth-type"]["const"] == "basic"
    plainAnyOf[1]["properties"]["enable_ssl"]["const"] == "true"
    plainAnyOf[1]["required"][0] == "ssl_cert"
  }

  ["the conditionally-required field is not unconditionally required"] {
    // required:false is omitted from the schema, so the only requiredness
    // for ssl_cert comes from the appended anyOf branch.
    !plainCredential["config"]["properties"]["ssl_cert"].containsKey("required")
  }

  ["UIRule does not leak the hidden whenInputs key into the branch"] {
    !plainAnyOf[1].containsKey("whenInputs")
    plainAnyOf[1].keys == Set("properties", "required")
  }

  ["JDBC flow appends the extra rule inside the jdbcUrl anyOf"] {
    appJdbc.credentialExtraAnyOfRules.length == 1
    jdbcAnyOf.length == 2
    jdbcAnyOf[0]["properties"]["auth-type"]["const"] == "basic"
    jdbcAnyOf[1]["properties"]["connectBy"]["const"] == "url"
    jdbcAnyOf[1]["required"][0] == "extra.compiled_url"
  }
}
