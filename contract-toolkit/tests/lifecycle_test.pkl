/// Lifecycle marker tests — verifies `applyLifecycle` emits the correct Pydantic
/// markers in generated `_input.py` for active, deprecated, and sunset fields.
amends "pkl:test"

import "../src/App.pkl" as App

// ── Fixture ─────────────────────────────────────────────────────────────────

local lifecycleApp = (App) {
  name = "lifecycle-test"
  displayName = "Lifecycle Test"
  icon = "https://assets.atlan.com/assets/dummy.svg"
  hasCredentialConfig = false
  pipeline { publish = null }
  uiConfig = new App.UIConfig {
    tasks {
      ["Settings"] {
        inputs {
          // active — plain default, no Field() wrapping
          ["active_field"] = new App.NumericInput {
            title = "Active field"
            default = 10
          }
          // deprecated simple field
          ["deprecated_field"] = new App.NumericInput {
            title = "Deprecated field"
            default = 99
            lifecycle = "deprecated"
            lifecycleMessage = "Use active_field instead."
          }
          // sunset simple field (BooleanInput generates bool = False)
          ["sunset_field"] = new App.BooleanInput {
            title = "Sunset field"
            default = false
            lifecycle = "sunset"
          }
          // deprecated factory field (TagsInput generates Field(default_factory=list))
          ["factory_deprecated"] = new App.TagsInput {
            title = "Factory deprecated"
            lifecycle = "deprecated"
          }
          // sunset factory field
          ["factory_sunset"] = new App.TagsInput {
            title = "Factory sunset"
            lifecycle = "sunset"
          }
          // deprecated TextInput (string default) — exercises regex on quoted-string default
          ["deprecated_text"] = new App.TextInput {
            title = "Deprecated text field"
            default = "legacy"
            lifecycle = "deprecated"
          }
          // deprecated field with lifecycleMessage — message wires into Field(deprecated="...")
          ["deprecated_with_msg"] = new App.NumericInput {
            title = "Deprecated with message"
            default = 7
            lifecycle = "deprecated"
            lifecycleMessage = "Use active_field instead."
          }
        }
      }
    }
  }
}

local inputPy: String = lifecycleApp.output.files["app/generated/_input.py"].text

facts {
  ["active field generates a plain default — no Field() wrapping"] {
    inputPy.contains("active_field: int = 10")
  }

  ["active field has no deprecated= annotation"] {
    inputPy.contains("active_field: int = 10") && !inputPy.contains("active_field: int = Field(")
  }

  ["deprecated NumericInput field with lifecycleMessage carries Field(deprecated=<message>)"] {
    inputPy.contains("deprecated_field: int = Field(default=99, deprecated=\"Use active_field instead.\")")
  }

  ["sunset BooleanInput field carries deprecated=True and x-lifecycle: sunset"] {
    inputPy.contains("sunset_field") &&
      inputPy.contains("deprecated=True") &&
      inputPy.contains("x-lifecycle") &&
      inputPy.contains("\"sunset\"")
  }

  ["sunset field also carries deprecated=True (sunset is a stronger form of deprecated)"] {
    inputPy.contains("sunset_field: bool = Field(") &&
      inputPy.contains("deprecated=True")
  }

  ["deprecated TagsInput (factory field) carries deprecated=True inside Field(...)"] {
    inputPy.contains("factory_deprecated") && inputPy.contains("deprecated=True")
  }

  ["sunset TagsInput (factory field) carries both deprecated=True and x-lifecycle: sunset"] {
    inputPy.contains("factory_sunset") &&
      inputPy.contains("deprecated=True") &&
      inputPy.contains("x-lifecycle")
  }

  ["deprecated TextInput carries Field(default=..., deprecated=True)"] {
    inputPy.contains("deprecated_text: str = Field(default=\"legacy\", deprecated=True)")
  }

  ["deprecated field with lifecycleMessage carries Field(deprecated=<message>)"] {
    inputPy.contains("deprecated_with_msg: int = Field(default=7, deprecated=\"Use active_field instead.\")")
  }
}
