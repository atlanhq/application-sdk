/// NativeApp fixture exercising the PART-1123 credential-gating change —
/// app opts out of credentials via `hasCredentialConfig = false`. Used by
/// credential_gating_test.pkl to assert that the extract-node
/// `args.credential = "{{credential}}"` placeholder is suppressed when an
/// app has no credentials.
amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"

name = "without-credential-app"
displayName = "Without Credential App"
workflowType = "WithoutCredentialWorkflow"
icon = "https://example.com/icon.svg"

// PART-1123 fix — opt out of credentials.
hasCredentialConfig = false

uiConfig = new Config.UIConfig {
  tasks {
    ["Connection"] {
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = "Connection"
          placeholderText = "Connection Name"
        }
      }
    }
  }
}
