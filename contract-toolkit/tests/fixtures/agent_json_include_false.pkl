/// Fixture: app that DOES model `agent-json` but sets `includeInManifest = false`.
///
/// Exercises the deliberate, field-specific semantic added in PR #2312: for the
/// `agent-json` slot only, `includeInManifest = false` does NOT suppress the
/// manifest `args["agent_json"]` slot — the extract-node guard still emits it,
/// because `agent_json` is structurally required for SDR credential routing and
/// an app that ends up with NO slot at all silently breaks agent-mode runs
/// (the gap that broke MSSQL's SDR rollout, atlan-mssql-app#177).
amends "../../src/App.pkl"

name = "agent-json-include-false"
displayName = "Agent JSON Include False"
icon = "https://assets.atlan.com/assets/fullscreen-exit.svg"
hasCredentialConfig = false

uiConfig = new UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["connection"] = new ConnectionCreator {
          placeholderText = "Connection Name"
        }
        // Modeled agent-json, but explicitly opted OUT of the manifest. The
        // guard must still emit the slot regardless.
        ["agent-json"] = new AgentSelector {
          placeholderText = "Agent JSON"
          includeInManifest = false
        }
      }
    }
  }
}
