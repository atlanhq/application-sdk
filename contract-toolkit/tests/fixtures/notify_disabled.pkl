/// Fixture: app that opts out of the run-level notification node.
///
/// Exercises `notifications = false` — the top-level on/off switch utility and
/// internal apps use so they do not append (and thus self-trigger) the
/// notify-on-failure node, e.g. the notification app itself.
amends "../../src/App.pkl"

name = "notify-disabled"
displayName = "Notify Disabled"
icon = "https://assets.atlan.com/assets/fullscreen-exit.svg"
hasCredentialConfig = false

notifications = false

uiConfig = new UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["connection"] = new ConnectionCreator {
          placeholderText = "Connection Name"
        }
      }
    }
  }
}
