/// Baseline NativeApp fixture with credentials enabled (the default).
/// Used by credential_gating_test.pkl to assert backward compatibility:
/// the extract-node `args.credential = "{{credential}}"` is emitted when
/// `hasCredentialConfig` defaults to true.
amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"

name = "with-credential-app"
displayName = "With Credential App"
workflowType = "WithCredentialWorkflow"
icon = "https://example.com/icon.svg"
credentialConnectorType = "rest"

credentialCommonFields {
  new FieldSpec { name = "host"; displayName = "Host"; width = 6 }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic"
    fields {
      new FieldSpec { name = "username"; displayName = "Username"; width = 4 }
      new FieldSpec { name = "password"; sensitive = true; displayName = "Password"; width = 4 }
    }
  }
}

uiConfig = new Config.UIConfig {
  tasks {
    ["Credential"] {
      inputs {
        ["credential-guid"] = new Config.CredentialInput {
          title = "Credential"
          credType = "atlan-connectors-with-credential-app"
        }
      }
    }
    ["Connection"] {
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = "Connection"
          placeholderText = "Connection Name"
        }
      }
    }
  }
}
