local appJdbcCredentialRendering = (App) {
  name = "jdbc-credential-rendering-test"
  displayName = "JDBC Credential Rendering Test"
  connector = Connectors.TERADATA
  icon = "https://example.com/icon.svg"

  credentialUrlGroup = new App.AdvancedJDBCUrlGroup {
    protocol = ""
    urlAddonBefore = "driver://"
    hostField = new App.FieldSpec {
      name = "host"
      displayName = "Host"
      placeholder = "host.example.com"
    }
    portField = new App.FieldSpec {
      name = "port"
      fieldType = "number"
      displayName = "Port"
      defaultValue = "1025"
      required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new App.JDBCUrlAuthOption {
      label = "Basic"
      nestedLabel = "Basic"
      urlPartMapping = new App.UrlPartMapping {
        hostname = "host"
        searchParams {
          ["PORT"] = new App.UrlRef { field = "port" }
        }
      }
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-jdbc-credential-rendering-test"
          }
        }
      }
    }
  }
}

local nativeJdbcCredentialRendering = (NativeApp) {
  name = "native-jdbc-credential-rendering-test"
  displayName = "Native JDBC Credential Rendering Test"
  connector = Connectors.TERADATA
  icon = "https://example.com/icon.svg"
  workflowType = "NativeJdbcCredentialRenderingTestWorkflow"

  credentialUrlGroup = new NativeApp.AdvancedJDBCUrlGroup {
    protocol = ""
    urlAddonBefore = "driver://"
    hostField = new NativeApp.FieldSpec {
      name = "host"
      displayName = "Host"
      placeholder = "host.example.com"
    }
    portField = new NativeApp.FieldSpec {
      name = "port"
      fieldType = "number"
      displayName = "Port"
      defaultValue = "1025"
      required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new NativeApp.JDBCUrlAuthOption {
      label = "Basic"
      nestedLabel = "Basic"
      urlPartMapping = new NativeApp.UrlPartMapping {
        hostname = "host"
        searchParams {
          ["PORT"] = new NativeApp.UrlRef { field = "port" }
        }
      }
      fields {
        new NativeApp.FieldSpec { name = "username"; displayName = "Username" }
        new NativeApp.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new Config.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new Config.CredentialInput {
            credType = "atlan-connectors-native-jdbc-credential-rendering-test"
          }
        }
      }
    }
  }
}

local appCredentialJson: String =
  appCredentialRendering.output.files["app/generated/atlan-connectors-credential-rendering-test.json"].text

local nativeCredentialJson: String =
  nativeCredentialRendering.output.files["atlan-connectors-native-credential-rendering-test.json"].text

local appJdbcCredentialJson: String =
  appJdbcCredentialRendering.output.files["app/generated/atlan-connectors-jdbc-credential-rendering-test.json"].text

local nativeJdbcCredentialJson: String =
  nativeJdbcCredentialRendering.output.files["atlan-connectors-native-jdbc-credential-rendering-test.json"].text

local appCredential = new json.Parser { useMapping = true }.parse(appCredentialJson)
local nativeCredential = new json.Parser { useMapping = true }.parse(nativeCredentialJson)
local appJdbcCredential = new json.Parser { useMapping = true }.parse(appJdbcCredentialJson)
local nativeJdbcCredential = new json.Parser { useMapping = true }.parse(nativeJdbcCredentialJson)

local appEnableSsl = appCredential["config"]["properties"]["enable_ssl"]
local nativeEnableSsl = nativeCredential["config"]["properties"]["enable_ssl"]
local appCaCertFile = appCredential["config"]["properties"]["ca_cert-file"]
local nativeCaCertFile = nativeCredential["config"]["properties"]["ca_cert-file"]
local appKeytabFile = appCredential["config"]["properties"]["keytab-file"]
local nativeKeytabFile = nativeCredential["config"]["properties"]["keytab-file"]
local appConditionalCertFile = appCredential["config"]["properties"]["conditional-cert-file"]
local nativeConditionalCertFile = nativeCredential["config"]["properties"]["conditional-cert-file"]
local appAuthType = appCredential["config"]["properties"]["auth-type"]
local nativeAuthType = nativeCredential["config"]["properties"]["auth-type"]
local appJdbcAuthType = appJdbcCredential["config"]["properties"]["jdbcUrl"]["properties"]["auth-type"]
local nativeJdbcAuthType =
  nativeJdbcCredential["config"]["properties"]["jdbcUrl"]["properties"]["auth-type"]

local configFileUploaderDefault = new json.Parser { useMapping = true }.parse(new JsonRenderer {}.renderDocument(
  new Config.FileUploader {
    title = "Upload"
    fileTypes { ".pem" }
  }
))
local configFileUploaderWithRemove = new json.Parser { useMapping = true }.parse(new JsonRenderer {}.renderDocument(
  new Config.FileUploader {
    title = "Upload"
    fileTypes { ".pem" }
    removeBeforeUpload = true
  }
))
local widgetsFileUploaderDefault = new json.Parser { useMapping = true }.parse(new JsonRenderer {}.renderDocument(
  new Widgets.FileUploader {
    title = "Upload"
    fileTypes { ".pem" }
  }
))
local widgetsFileUploaderWithRemove = new json.Parser { useMapping = true }.parse(new JsonRenderer {}.renderDocument(
  new Widgets.FileUploader {
    title = "Upload"
    fileTypes { ".pem" }
    removeBeforeUpload = true
  }
))

facts {
  ["App.pkl renders checkbox FieldSpec as checkbox widget with boolean schema"] {
    appEnableSsl["type"] == "boolean"
    appEnableSsl["default"] == true
    appEnableSsl["ui"]["widget"] == "checkbox"
  }

  ["App.pkl renders fileUpload FieldSpec as frontend credential file widget"] {
    appCaCertFile["type"] == "string"
    appCaCertFile["required"] == false
    appCaCertFile["ui"]["widget"] == "fileUpload"
    appCaCertFile["ui"]["accept"].toList() == new Listing { ".crt"; ".pem" }.toList()
    appCaCertFile["ui"]["fileMetadata"] == true
    appCaCertFile["ui"]["removeBeforeUpload"] == true
  }

  ["App.pkl renders credentialFileInput FieldSpec as hybrid credential file widget"] {
    appKeytabFile["type"] == "string"
    appKeytabFile["ui"]["widget"] == "credentialFileInput"
    appKeytabFile["ui"]["accept"].toList() == new Listing { ".keytab"; "application/kerberos-keytab" }.toList()
    appKeytabFile["ui"]["fileMetadata"] == true
  }

  ["App.pkl renders conditional upload override UI with removeBeforeUpload"] {
    appConditionalCertFile["type"] == "conditional"
    appConditionalCertFile["conditions"][0]["ui"]["widget"] == "fileUpload"
    appConditionalCertFile["conditions"][0]["ui"]["accept"].toList() == new Listing { ".crt"; ".pem" }.toList()
    appConditionalCertFile["conditions"][0]["ui"]["fileMetadata"] == true
    appConditionalCertFile["conditions"][0]["ui"]["removeBeforeUpload"] == true
  }

  ["App.pkl auto-hides the auth-type selector when there is a single auth option"] {
    appAuthType["default"] == "basic"
    appAuthType["ui"]["widget"] == "radio"
    appAuthType["ui"]["hidden"] == true
  }

  ["NativeApp.pkl renders checkbox FieldSpec as checkbox widget with boolean schema"] {
    nativeEnableSsl["type"] == "boolean"
    nativeEnableSsl["default"] == true
    nativeEnableSsl["ui"]["widget"] == "checkbox"
  }

  ["NativeApp.pkl renders fileUpload FieldSpec as frontend credential file widget"] {
    nativeCaCertFile["type"] == "string"
    nativeCaCertFile["required"] == false
    nativeCaCertFile["ui"]["widget"] == "fileUpload"
    nativeCaCertFile["ui"]["accept"].toList() == new Listing { ".crt"; ".pem" }.toList()
    nativeCaCertFile["ui"]["fileMetadata"] == true
    nativeCaCertFile["ui"]["removeBeforeUpload"] == true
  }

  ["NativeApp.pkl renders credentialFileInput FieldSpec as hybrid credential file widget"] {
    nativeKeytabFile["type"] == "string"
    nativeKeytabFile["ui"]["widget"] == "credentialFileInput"
    nativeKeytabFile["ui"]["accept"].toList() == new Listing { ".keytab"; "application/kerberos-keytab" }.toList()
    nativeKeytabFile["ui"]["fileMetadata"] == true
  }

  ["NativeApp.pkl renders conditional upload override UI with removeBeforeUpload"] {
    nativeConditionalCertFile["type"] == "conditional"
    nativeConditionalCertFile["conditions"][0]["ui"]["widget"] == "fileUpload"
    nativeConditionalCertFile["conditions"][0]["ui"]["accept"].toList() == new Listing { ".crt"; ".pem" }.toList()
    nativeConditionalCertFile["conditions"][0]["ui"]["fileMetadata"] == true
    nativeConditionalCertFile["conditions"][0]["ui"]["removeBeforeUpload"] == true
  }

  ["NativeApp.pkl auto-hides the auth-type selector when there is a single auth option"] {
    nativeAuthType["default"] == "basic"
    nativeAuthType["ui"]["widget"] == "radio"
    nativeAuthType["ui"]["hidden"] == true
  }

  ["Config.pkl FileUploader omits removeBeforeUpload by default and emits it when enabled"] {
    !configFileUploaderDefault["ui"].containsKey("removeBeforeUpload")
    configFileUploaderWithRemove["ui"]["removeBeforeUpload"] == true
  }

  ["Widgets.pkl FileUploader omits removeBeforeUpload by default and emits it when enabled"] {
    !widgetsFileUploaderDefault["ui"].containsKey("removeBeforeUpload")
    widgetsFileUploaderWithRemove["ui"]["removeBeforeUpload"] == true
  }

  ["App.pkl auto-hides JDBC auth-type selector when there is a single direct auth option"] {
    appJdbcAuthType["default"] == "basic"
    appJdbcAuthType["ui"]["widget"] == "radio"
    appJdbcAuthType["ui"]["hidden"] == true
  }

  ["NativeApp.pkl auto-hides JDBC auth-type selector when there is a single direct auth option"] {
    nativeJdbcAuthType["default"] == "basic"
    nativeJdbcAuthType["ui"]["widget"] == "radio"
    nativeJdbcAuthType["ui"]["hidden"] == true
  }
}
