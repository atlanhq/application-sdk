/// Unit tests for credential FieldSpec widget rendering and auth-type visibility.
amends "pkl:test"

import "pkl:json"
import "../src/App.pkl" as App
import "../src/Config.pkl"
import "../src/Connectors.pkl"
import "../src/NativeApp.pkl"

local appCredentialRendering = (App) {
  name = "credential-rendering-test"
  displayName = "Credential Rendering Test"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"
  credentialAuthHidden = true

  credentialCommonFields {
    new App.FieldSpec {
      name = "enable_ssl"
      displayName = "Enable SSL"
      fieldType = "checkbox"
      defaultValue = "true"
      required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new App.AuthOption {
      label = "Basic"
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-credential-rendering-test"
          }
        }
      }
    }
  }
}

local nativeCredentialRendering = (NativeApp) {
  name = "native-credential-rendering-test"
  displayName = "Native Credential Rendering Test"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"
  workflowType = "NativeCredentialRenderingTestWorkflow"
  credentialAuthHidden = true

  credentialCommonFields {
    new NativeApp.FieldSpec {
      name = "enable_ssl"
      displayName = "Enable SSL"
      fieldType = "checkbox"
      defaultValue = "true"
      required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new NativeApp.AuthOption {
      label = "Basic"
      fields {
        new NativeApp.FieldSpec { name = "username"; displayName = "Username" }
        new NativeApp.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new Config.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new Config.CredentialInput {
            credType = "atlan-connectors-native-credential-rendering-test"
          }
        }
      }
    }
  }
}

local appJdbcCredentialRendering = (App) {
  name = "jdbc-credential-rendering-test"
  displayName = "JDBC Credential Rendering Test"
  connector = Connectors.TERADATA
  icon = "https://example.com/icon.svg"
  credentialAuthHidden = true

  credentialUrlGroup = new App.AdvancedJDBCUrlGroup {
    protocol = ""
    urlAddonBefore = "driver://"
    hostField = new App.FieldSpec {
      name = "host"
      displayName = "Host"
      placeholder = "host.example.com"
    }
    portField = new App.FieldSpec {
      name = "port"
      fieldType = "number"
      displayName = "Port"
      defaultValue = "1025"
      required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new App.JDBCUrlAuthOption {
      label = "Basic"
      nestedLabel = "Basic"
      urlPartMapping = new App.UrlPartMapping {
        hostname = "host"
        searchParams {
          ["PORT"] = new App.UrlRef { field = "port" }
        }
      }
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-jdbc-credential-rendering-test"
          }
        }
      }
    }
  }
}

local nativeJdbcCredentialRendering = (NativeApp) {
  name = "native-jdbc-credential-rendering-test"
  displayName = "Native JDBC Credential Rendering Test"
  connector = Connectors.TERADATA
  icon = "https://example.com/icon.svg"
  workflowType = "NativeJdbcCredentialRenderingTestWorkflow"
  credentialAuthHidden = true

  credentialUrlGroup = new NativeApp.AdvancedJDBCUrlGroup {
    protocol = ""
    urlAddonBefore = "driver://"
    hostField = new NativeApp.FieldSpec {
      name = "host"
      displayName = "Host"
      placeholder = "host.example.com"
    }
    portField = new NativeApp.FieldSpec {
      name = "port"
      fieldType = "number"
      displayName = "Port"
      defaultValue = "1025"
      required = false
    }
  }

  credentialAuthOptions {
    ["basic"] = new NativeApp.JDBCUrlAuthOption {
      label = "Basic"
      nestedLabel = "Basic"
      urlPartMapping = new NativeApp.UrlPartMapping {
        hostname = "host"
        searchParams {
          ["PORT"] = new NativeApp.UrlRef { field = "port" }
        }
      }
      fields {
        new NativeApp.FieldSpec { name = "username"; displayName = "Username" }
        new NativeApp.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new Config.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new Config.CredentialInput {
            credType = "atlan-connectors-native-jdbc-credential-rendering-test"
          }
        }
      }
    }
  }
}

local appCredentialJson: String =
  appCredentialRendering.output.files["app/generated/atlan-connectors-credential-rendering-test.json"].text

local nativeCredentialJson: String =
  nativeCredentialRendering.output.files["atlan-connectors-native-credential-rendering-test.json"].text

local appJdbcCredentialJson: String =
  appJdbcCredentialRendering.output.files["app/generated/atlan-connectors-jdbc-credential-rendering-test.json"].text

local nativeJdbcCredentialJson: String =
  nativeJdbcCredentialRendering.output.files["atlan-connectors-native-jdbc-credential-rendering-test.json"].text

local appCredential = new json.Parser { useMapping = true }.parse(appCredentialJson)
local nativeCredential = new json.Parser { useMapping = true }.parse(nativeCredentialJson)
local appJdbcCredential = new json.Parser { useMapping = true }.parse(appJdbcCredentialJson)
local nativeJdbcCredential = new json.Parser { useMapping = true }.parse(nativeJdbcCredentialJson)

local appEnableSsl = appCredential["config"]["properties"]["enable_ssl"]
local nativeEnableSsl = nativeCredential["config"]["properties"]["enable_ssl"]
local appAuthType = appCredential["config"]["properties"]["auth-type"]
local nativeAuthType = nativeCredential["config"]["properties"]["auth-type"]
local appJdbcAuthType = appJdbcCredential["config"]["properties"]["jdbcUrl"]["properties"]["auth-type"]
local nativeJdbcAuthType =
  nativeJdbcCredential["config"]["properties"]["jdbcUrl"]["properties"]["auth-type"]

facts {
  ["App.pkl renders checkbox FieldSpec as checkbox widget with boolean schema"] {
    appEnableSsl["type"] == "boolean"
    appEnableSsl["default"] == true
    appEnableSsl["ui"]["widget"] == "checkbox"
  }

  ["App.pkl can hide the auth-type selector while preserving default auth type"] {
    appAuthType["default"] == "basic"
    appAuthType["ui"]["widget"] == "radio"
    appAuthType["ui"]["hidden"] == true
  }

  ["NativeApp.pkl renders checkbox FieldSpec as checkbox widget with boolean schema"] {
    nativeEnableSsl["type"] == "boolean"
    nativeEnableSsl["default"] == true
    nativeEnableSsl["ui"]["widget"] == "checkbox"
  }

  ["NativeApp.pkl can hide the auth-type selector while preserving default auth type"] {
    nativeAuthType["default"] == "basic"
    nativeAuthType["ui"]["widget"] == "radio"
    nativeAuthType["ui"]["hidden"] == true
  }

  ["App.pkl can hide JDBC auth-type selector while preserving default auth type"] {
    appJdbcAuthType["default"] == "basic"
    appJdbcAuthType["ui"]["widget"] == "radio"
    appJdbcAuthType["ui"]["hidden"] == true
  }

  ["NativeApp.pkl can hide JDBC auth-type selector while preserving default auth type"] {
    nativeJdbcAuthType["default"] == "basic"
    nativeJdbcAuthType["ui"]["widget"] == "radio"
    nativeJdbcAuthType["ui"]["hidden"] == true
  }
}
