/// Unit tests for credential FieldSpec widget rendering and auth-type visibility.
amends "pkl:test"

import "pkl:json"
import "../src/App.pkl" as App
import "../src/Config.pkl"
import "../src/Connectors.pkl"
import "../src/NativeApp.pkl"
import "../src/Widgets.pkl" as Widgets

local appCredentialRendering = (App) {
  name = "credential-rendering-test"
  displayName = "Credential Rendering Test"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"

  credentialCommonFields {
    new App.FieldSpec {
      name = "enable_ssl"
      displayName = "Enable SSL"
      fieldType = "checkbox"
      defaultValue = "true"
      required = false
    }
    new App.FieldSpec {
      name = "ca_cert-file"
      displayName = "CA Certificate File"
      fieldType = "fileUpload"
      sensitive = true
      fileTypes { ".crt"; ".pem" }
      removeBeforeUpload = true
      required = false
      includeRequiredWhenFalse = true
    }
    new App.FieldSpec {
      name = "keytab-file"
      displayName = "Keytab File"
      fieldType = "credentialFileInput"
      fileTypes { ".keytab"; "application/kerberos-keytab" }
      required = false
    }
    new App.ConditionalFieldSpec {
      name = "conditional-cert-file"
      conditions {
        new App.Condition {
          property = "enable_ssl"
          value = true
          overrideType = "string"
          overrideUi = new App.Widget {
            widget = "fileUpload"
            label = "Conditional CA Certificate File"
            accept = new Listing { ".crt"; ".pem" }.toList()
            fileMetadata = true
            removeBeforeUpload = true
          }
        }
      }
    }
  }

  credentialAuthOptions {
    ["basic"] = new App.AuthOption {
      label = "Basic"
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }

  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-credential-rendering-test"
          }
        }
      }
    }
  }
}

