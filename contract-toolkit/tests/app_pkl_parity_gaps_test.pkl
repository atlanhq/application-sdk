/// Unit tests for the HYP-1848 App.pkl parity gaps:
///   Gap 1 — Widgets.CredentialInput renders `placeholderText` as `ui.placeholder`.
///   Gap 2 — `argoPackageNames` renders to atlan.yaml as `argo_package_names`,
///           in canonical position between `visibility` and `build_tag`.
///   Gap 3 — `workflowType` emits its value verbatim when set; when unset the
///           `name` is kebab-cased to derive the default `workflow_type`.
amends "pkl:test"

import "pkl:json"
import "../src/App.pkl" as App
import "../src/Connectors.pkl"

// ── Gap 1: credential placeholder ───────────────────────────────────────────
local appCredWithPlaceholder = (App) {
  name = "cred-placeholder-test"
  displayName = "Cred Placeholder Test"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"
  credentialAuthOptions {
    ["basic"] = new App.AuthOption {
      label = "Basic"
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }
  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-cred-placeholder-test"
            placeholderText = "Credential GUID"
          }
        }
      }
    }
  }
}

local appCredNoPlaceholder = (App) {
  name = "cred-no-placeholder-test"
  displayName = "Cred No Placeholder Test"
  connector = Connectors.TRINO
  icon = "https://example.com/icon.svg"
  credentialAuthOptions {
    ["basic"] = new App.AuthOption {
      label = "Basic"
      fields {
        new App.FieldSpec { name = "username"; displayName = "Username" }
        new App.FieldSpec { name = "password"; sensitive = true; displayName = "Password" }
      }
    }
  }
  uiConfig = new App.UIConfig {
    tasks {
      ["Credential"] {
        inputs {
          ["credential-guid"] = new App.CredentialInput {
            credType = "atlan-connectors-cred-no-placeholder-test"
          }
        }
      }
    }
  }
}

local credWithJson = new json.Parser { useMapping = true }.parse(appCredWithPlaceholder.output.files["app/generated/cred-placeholder-test.json"].text)
local credNoJson = new json.Parser { useMapping = true }.parse(appCredNoPlaceholder.output.files["app/generated/cred-no-placeholder-test.json"].text)
local credWithUi = credWithJson["config"]["properties"]["credential-guid"]["ui"]
local credNoUi = credNoJson["config"]["properties"]["credential-guid"]["ui"]

// ── Gap 2: argoPackageNames → atlan.yaml ────────────────────────────────────
local appArgoPkgs = (App) {
  name = "argo-pkgs-test"
  displayName = "Argo Pkgs Test"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  pipeline { publish = null }
  argoPackageNames { "@atlan/a"; "@atlan/b" }
}

local appNoArgoPkgs = (App) {
  name = "no-argo-pkgs-test"
  displayName = "No Argo Pkgs Test"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  pipeline { publish = null }
}

local argoYaml = appArgoPkgs.output.files["atlan.yaml"].text
local noArgoYaml = appNoArgoPkgs.output.files["atlan.yaml"].text
local argoE2eBase = appArgoPkgs.output.files["app/generated/_e2e_base.py"].text
local noArgoE2eBase = appNoArgoPkgs.output.files["app/generated/_e2e_base.py"].text

// ── Gap 3: workflowType verbatim vs default ──────────────────────────────────
local workflowUiConfig = new App.UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["target"] = new App.TextInput { title = "Target"; helpText = "What to process." }
      }
    }
  }
}

local appWorkflowVerbatim = (App) {
  name = "wf-verbatim-test"
  displayName = "WF Verbatim Test"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  pipeline { publish = null }
  workflowType = "WfVerbatimTest"
  uiConfig = workflowUiConfig
}

local appWorkflowDefault = (App) {
  name = "wf-default-test"
  displayName = "WF Default Test"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  pipeline { publish = null }
  // workflowType unset → derives from name
  uiConfig = workflowUiConfig
}

local verbatimManifest = new json.Parser { useMapping = true }.parse(appWorkflowVerbatim.output.files["app/generated/manifest.json"].text)
local defaultManifest = new json.Parser { useMapping = true }.parse(appWorkflowDefault.output.files["app/generated/manifest.json"].text)
local verbatimWorkflowType = verbatimManifest["dag"]["extract"]["inputs"]["workflow_type"]
local defaultWorkflowType = defaultManifest["dag"]["extract"]["inputs"]["workflow_type"]

facts {
  ["Gap 1: CredentialInput renders placeholderText as ui.placeholder"] {
    credWithUi["placeholder"] == "Credential GUID"
  }

  ["Gap 1: CredentialInput omits ui.placeholder when placeholderText is unset"] {
    !credNoUi.containsKey("placeholder")
  }

  ["Gap 2: argoPackageNames renders argo_package_names between visibility and build_tag"] {
    argoYaml.contains("argo_package_names:")
    argoYaml.indexOf("visibility:") < argoYaml.indexOf("argo_package_names:")
    argoYaml.indexOf("argo_package_names:") < argoYaml.indexOf("build_tag:")
  }

  ["Gap 2: argo_package_names omitted from atlan.yaml when list is empty"] {
    !noArgoYaml.contains("argo_package_names")
  }

  ["Gap 2: e2e argo_package_name takes the first argoPackageNames entry"] {
    argoE2eBase.contains("argo_package_name = \"@atlan/a\"")
  }

  ["Gap 2: e2e argo_package_name falls back to @atlan/{name} when list is empty"] {
    noArgoE2eBase.contains("argo_package_name = \"@atlan/no-argo-pkgs-test\"")
  }

  ["Gap 3: workflowType when set is emitted verbatim with no conversion"] {
    verbatimWorkflowType == "WfVerbatimTest"
  }

  ["Gap 3: workflowType when unset defaults to kebab-cased name"] {
    defaultWorkflowType == "wf-default-test"
  }
}
