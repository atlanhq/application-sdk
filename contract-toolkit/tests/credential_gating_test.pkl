// Tests for PART-1123: gate the extract-node `args.credential` placeholder
// on `hasCredentialConfig`. Apps that opt out of credentials should not
// have a phantom `credential = "{{credential}}"` in their generated
// manifest.

amends "pkl:test"

import "fixtures/native_app_with_credential.pkl" as withCredentialApp
import "fixtures/native_app_without_credential.pkl" as withoutCredentialApp

local withCredentialManifestJson: String =
  withCredentialApp.output.files["manifest.json"].text
local withoutCredentialManifestJson: String =
  withoutCredentialApp.output.files["manifest.json"].text

facts {
  // ── Regression guard: default behavior preserved ─────────────────────────
  ["hasCredentialConfig defaults to true and emits the credential arg"] {
    withCredentialApp.hasCredentialConfig == true
    withCredentialManifestJson.contains("\"credential\": \"{{credential}}\"")
  }

  // ── New behavior: hasCredentialConfig = false drops the credential arg ───
  ["hasCredentialConfig = false drops the credential arg from manifest"] {
    withoutCredentialApp.hasCredentialConfig == false
    !withoutCredentialManifestJson.contains("\"credential\":")
  }

  ["hasCredentialConfig = false still emits other args (sanity)"] {
    withoutCredentialManifestJson.contains("\"connection\": \"{{connection}}\"")
  }
}
