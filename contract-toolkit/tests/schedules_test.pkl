// Tests for background-job schedules (DISTR-815).
//
// When an app declares `schedules`, the toolkit renders a `triggers.schedules`
// block into `manifest.json` (AE ScheduleTrigger shape). The feature lives in
// BOTH schemas (App.pkl and NativeApp.pkl) while the toolkit migrates from
// NativeApp.pkl to App.pkl. When `schedules` is empty, no `triggers` key is
// emitted.

amends "pkl:test"

import "pkl:json"
import "../src/App.pkl" as App
import "../src/NativeApp.pkl" as NativeApp
import "../src/Connectors.pkl"

local parser = new json.Parser { useMapping = true }

// ── App.pkl ───────────────────────────────────────────────────────────────

local appUiConfig = new App.UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["target"] = new App.TextInput {
          title = "Target"
          placeholderText = "my-target"
        }
      }
    }
  }
}

local appWithSchedules = (App) {
  name = "app-with-schedules"
  displayName = "App With Schedules"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  uiConfig = appUiConfig

  pipeline {
    publish = null
  }

  schedules {
    new App.ScheduleSpec {
      name = "policy-eval-daily"
      cronExpression = "0 0 * * *"
    }
    new App.ScheduleSpec {
      name = "dp-score-refresh-6h"
      cronExpression = "0 */6 * * *"
      timezone = "America/New_York"
      status = "PAUSED"
    }
  }

  events {
    new App.EventTriggerSpec {
      name = "cdc-user-entity"
      source = new App.EventSource {
        name = "atlan-kafka"
        topic = "app.cdc.user_entity"
      }
      triggerConfig = new App.EventTriggerConfig {
        maxRetries = 5
        ackPaths { "$.extract.outputs.ack_path" }
      }
    }
    new App.EventTriggerSpec {
      name = "cdc-group-disabled"
      source = new App.EventSource {
        name = "atlan-kafka"
        topic = "app.cdc.group"
      }
      status = "PAUSED"
    }
  }
}

local appNoSchedules = (App) {
  name = "app-no-schedules"
  displayName = "App No Schedules"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  uiConfig = appUiConfig
  pipeline {
    publish = null
  }
}

// Events-only (no schedules) — the shape an event-driven entrypoint uses (e.g.
// atlan-auth-app's event-sync, DISTR-844). Proves triggers.events renders while
// triggers.schedules is ABSENT (not just empty).
local appEventsOnly = (App) {
  name = "app-events-only"
  displayName = "App Events Only"
  icon = "https://example.com/icon.svg"
  hasCredentialConfig = false
  uiConfig = appUiConfig
  pipeline {
    publish = null
  }

  events {
    new App.EventTriggerSpec {
      name = "cdc-user-entity"
      source = new App.EventSource {
        name = "atlan-kafka"
        topic = "app.cdc.user_entity"
      }
      triggerConfig = new App.EventTriggerConfig {
        ackPaths { "$.extract.outputs.ack_path" }
      }
    }
  }
}

local appManifest = parser.parse(
  appWithSchedules.output.files["app/generated/manifest.json"].text
)
local appNoSchedManifest = parser.parse(
  appNoSchedules.output.files["app/generated/manifest.json"].text
)
local appEventsOnlyManifest = parser.parse(
  appEventsOnly.output.files["app/generated/manifest.json"].text
)

// ── NativeApp.pkl ───────────────────────────────────────────────────────────

local nativeWithSchedules = (NativeApp) {
  name = "native-with-schedules"
  displayName = "Native With Schedules"
  connector = Connectors.API
  icon = "https://example.com/icon.svg"
  workflowType = "NativeWithSchedulesWorkflow"
  hasPublishStep = false
  hasPublishInputFields = false

  schedules {
    new NativeApp.ScheduleSpec {
      name = "policy-eval-daily"
      cronExpression = "0 0 * * *"
    }
  }

  events {
    new NativeApp.EventTriggerSpec {
      name = "cdc-user-entity"
      source = new NativeApp.EventSource {
        name = "atlan-kafka"
        topic = "native.cdc.user_entity"
      }
      triggerConfig = new NativeApp.EventTriggerConfig {
        ackPaths { "$.sync.outputs.ack_path" }
      }
    }
  }
}

local nativeNoSchedules = (NativeApp) {
  name = "native-no-schedules"
  displayName = "Native No Schedules"
  connector = Connectors.API
  icon = "https://example.com/icon.svg"
  workflowType = "NativeNoSchedulesWorkflow"
  hasPublishStep = false
  hasPublishInputFields = false
}

// Events-only (no schedules) NativeApp — same case as appEventsOnly.
local nativeEventsOnly = (NativeApp) {
  name = "native-events-only"
  displayName = "Native Events Only"
  connector = Connectors.API
  icon = "https://example.com/icon.svg"
  workflowType = "NativeEventsOnlyWorkflow"
  hasPublishStep = false
  hasPublishInputFields = false

  events {
    new NativeApp.EventTriggerSpec {
      name = "cdc-user-entity"
      source = new NativeApp.EventSource {
        name = "atlan-kafka"
        topic = "native.cdc.user_entity"
      }
      triggerConfig = new NativeApp.EventTriggerConfig {
        ackPaths { "$.extract.outputs.ack_path" }
      }
    }
  }
}

local nativeManifest = parser.parse(
  nativeWithSchedules.output.files["manifest.json"].text
)
local nativeNoSchedManifest = parser.parse(
  nativeNoSchedules.output.files["manifest.json"].text
)
local nativeEventsOnlyManifest = parser.parse(
  nativeEventsOnly.output.files["manifest.json"].text
)

facts {
  // ── App.pkl ───────────────────────────────────────────────────────────────
  ["App renders triggers.schedules from declared schedules"] {
    appManifest["triggers"]["schedules"].length == 2
    appManifest["triggers"]["schedules"][0]["name"] == "policy-eval-daily"
    appManifest["triggers"]["schedules"][0]["cron_expression"] == "0 0 * * *"
  }

  ["App schedule defaults are UTC + ACTIVE"] {
    appManifest["triggers"]["schedules"][0]["timezone"] == "UTC"
    appManifest["triggers"]["schedules"][0]["status"] == "ACTIVE"
  }

  ["App schedule honours timezone + PAUSED overrides"] {
    appManifest["triggers"]["schedules"][1]["timezone"] == "America/New_York"
    appManifest["triggers"]["schedules"][1]["status"] == "PAUSED"
  }

  ["App renders triggers.events from declared events (AE EventTrigger shape)"] {
    appManifest["triggers"]["events"].length == 2
    appManifest["triggers"]["events"][0]["name"] == "cdc-user-entity"
    appManifest["triggers"]["events"][0]["source"]["name"] == "atlan-kafka"
    appManifest["triggers"]["events"][0]["source"]["topic"] == "app.cdc.user_entity"
    appManifest["triggers"]["events"][0]["trigger_config"]["max_retries"] == 5
    appManifest["triggers"]["events"][0]["trigger_config"]["ack_paths"][0] == "$.extract.outputs.ack_path"
  }

  ["App event defaults: maxRetries 3, fire-and-forget ack_paths [\"\"] (AE-valid, not [])"] {
    appManifest["triggers"]["events"][1]["status"] == "PAUSED"
    appManifest["triggers"]["events"][1]["trigger_config"]["max_retries"] == 3
    // AE requires ack_paths non-empty; omitting ackPaths renders the fire-and-forget
    // [""] (a single empty string), never [].
    appManifest["triggers"]["events"][1]["trigger_config"]["ack_paths"].length == 1
    appManifest["triggers"]["events"][1]["trigger_config"]["ack_paths"][0] == ""
  }

  ["App carries schedules and events in one triggers block"] {
    appManifest["triggers"].containsKey("schedules")
    appManifest["triggers"].containsKey("events")
  }

  ["App events-only: renders triggers.events with schedules ABSENT"] {
    appEventsOnlyManifest["triggers"].containsKey("events")
    appEventsOnlyManifest["triggers"]["events"].length == 1
    appEventsOnlyManifest["triggers"]["events"][0]["source"]["topic"] == "app.cdc.user_entity"
    !appEventsOnlyManifest["triggers"].containsKey("schedules")
  }

  ["App omits triggers when neither schedules nor events are declared"] {
    !appNoSchedManifest.containsKey("triggers")
  }

  // ── NativeApp.pkl ───────────────────────────────────────────────────────────
  ["NativeApp renders triggers.schedules from declared schedules"] {
    nativeManifest["triggers"]["schedules"].length == 1
    nativeManifest["triggers"]["schedules"][0]["name"] == "policy-eval-daily"
    nativeManifest["triggers"]["schedules"][0]["cron_expression"] == "0 0 * * *"
  }

  ["NativeApp schedule defaults are UTC + ACTIVE"] {
    nativeManifest["triggers"]["schedules"][0]["timezone"] == "UTC"
    nativeManifest["triggers"]["schedules"][0]["status"] == "ACTIVE"
  }

  ["NativeApp renders triggers.events from declared events"] {
    nativeManifest["triggers"]["events"].length == 1
    nativeManifest["triggers"]["events"][0]["name"] == "cdc-user-entity"
    nativeManifest["triggers"]["events"][0]["source"]["topic"] == "native.cdc.user_entity"
    nativeManifest["triggers"]["events"][0]["trigger_config"]["ack_paths"][0] == "$.sync.outputs.ack_path"
    nativeManifest["triggers"]["events"][0]["status"] == "ACTIVE"
  }

  ["NativeApp events-only: renders triggers.events with schedules ABSENT"] {
    nativeEventsOnlyManifest["triggers"].containsKey("events")
    nativeEventsOnlyManifest["triggers"]["events"].length == 1
    nativeEventsOnlyManifest["triggers"]["events"][0]["source"]["topic"] == "native.cdc.user_entity"
    !nativeEventsOnlyManifest["triggers"].containsKey("schedules")
  }

  ["NativeApp omits triggers when neither schedules nor events are declared"] {
    !nativeNoSchedManifest.containsKey("triggers")
  }
}
