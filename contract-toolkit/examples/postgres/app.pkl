amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"
import "../../src/Connectors.pkl"

local schemaQuery = "SELECT current_database() AS TABLE_CATALOG, schema_name AS TABLE_SCHEMA FROM information_schema.schemata WHERE schema_name NOT IN ('information_schema', 'pg_catalog') AND schema_name NOT LIKE 'pg_toast%' ORDER BY schema_name"
local systemSchemas = List("information_schema", "pg_catalog", "pg_toast.*")

name = "postgres"
displayName = "Postgres"
connector = Connectors.POSTGRES
workflowTypeOverride = "PostgresMetadataExtractionWorkflow"
icon = "https://assets.atlan.com/assets/postgres.svg"
logo = icon
credentialConnectorType = "jdbc"

credentialCommonFields {
  new FieldSpec {
    name = "host"
    displayName = "Host"
    placeholder = "postgres.example.com"
    helpText = "Postgres host name"
    width = 6
  }
  new FieldSpec {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    defaultValue = "5432"
    width = 2
  }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic Authentication"
    fields {
      new FieldSpec {
        name = "username"
        displayName = "Username"
        placeholder = "Username"
        width = 4
      }
      new FieldSpec {
        name = "password"
        displayName = "Password"
        placeholder = "Password"
        sensitive = true
        width = 4
      }
    }
    extraFields {
      new FieldSpec {
        name = "database"
        displayName = "Database"
        placeholder = "postgres"
        helpText = "Default database to connect to for metadata extraction."
        width = 4
      }
      new FieldSpec {
        name = "__enable_ssl"
        displayName = "Enable SSL"
        fieldType = "select"
        options { "true"; "false" }
        optionLabels {
          ["true"] = "True"
          ["false"] = "False"
        }
        defaultValue = "true"
        width = 4
      }
    }
  }
}

uiConfig {
  tasks {
    ["Credential"] {
      inputs {
        ["credential-guid"] = new Config.CredentialInput {
          title = ""
          credType = "atlan-connectors-postgres"
          placeholderText = "Credential Guid"
        }
      }
    }
    ["Connection"] {
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = ""
          placeholderText = "Connection Name"
        }
      }
    }
    ["Metadata"] {
      inputs {
        ["include-filter"] = new Config.SqlTree {
          title = "Include Metadata"
          desc = "Only selected databases and schemas will be extracted."
          sqlQuery = schemaQuery
          credentialType = "atlan-connectors-postgres"
          cred = "credential-guid"
          excludePatterns = systemSchemas
          width = 4
        }
        ["exclude-filter"] = new Config.SqlTree {
          title = "Exclude Metadata"
          desc = "Selected databases and schemas will not be extracted."
          sqlQuery = schemaQuery
          credentialType = "atlan-connectors-postgres"
          cred = "credential-guid"
          excludePatterns = systemSchemas
          width = 4
        }
        ["temp-table-regex"] = new Config.TextInput {
          title = "Exclude regex for tables & views"
          helpText = "Regex of tables and views to ignore."
          placeholderText = ".*_tmp|.*_temp|tmp_.*|temp_.*"
          required = false
          width = 4
        }
        ["preflight-check"] = new Config.SageV2 {
          title = ""
          checks {
            new Dynamic { id = 1; name = "connectivity"; title = "Connectivity"; loaderText = "Checking connectivity to Postgres" }
            new Dynamic { id = 2; name = "schemasCheck"; title = "Databases and schemas"; loaderText = "Checking schema metadata permissions" }
          }
        }
      }
    }
  }
}
