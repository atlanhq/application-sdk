/// Full-featured example — demonstrates every configurable App.pkl property.
///
/// This is a toolkit reference contract, not a real connector. Each section
/// exercises a distinct feature surface:
///   - pipeline: typed extract/parseQueries/publish overrides with errorHandling
///   - credentialUrlGroup: AdvancedJDBCUrlGroup (JDBC URL builder with two auth modes)
///   - credentialAuthOptions: JDBCUrlAuthOption with UrlPartMapping/UrlRef/UrlLiteral
///   - ConditionalFieldSpec: small field-level conditional credential input
///   - uiConfig: TextInput, BooleanInput, NumericInput, Radio, DropDown, SqlTree,
///               conditional UIRule, CredentialInput, ConnectionCreator
///   - extraNodes: custom DAG node outside the typed pipeline
///   - notifications: explicit opt-in to the run-completion notification node
///   - marketplace metadata: docsUrl, shortDescription, longDescription, tags
amends "../../src/App.pkl"

import "../../src/Connectors.pkl"

name = "full-featured"
displayName = "Full-Featured Example"
connector = Connectors.POSTGRES
workflowType = "FullFeaturedExampleWorkflow"
icon = "https://assets.atlan.com/assets/fullscreen-open.svg"
docsUrl = "https://docs.example.com/apps/full-featured"
shortDescription = "Reference contract that exercises every App.pkl property."
longDescription = """
Full-featured reference contract used by the toolkit's own tests.

Covers JDBC URL auth, every pipeline step, diverse widgets, UIRules,
extraNodes, run-completion notifications, and the full marketplace
metadata block emitted into atlan.yaml.
"""
tags = new Listing {
  "reference"
  "example"
  "postgres"
}
credentialConnectorType = "jdbc"
notifications = true

pipeline {
  extract {
    // Override the default "Extract" label for apps whose first step is
    // conceptually different (e.g. "Discover", "Apply", "Sync").
    displayName = "Discover"
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 7200
    }
  }
  parseQueries = new ParseQueriesStep {
    vendorName = "postgres"
    sqlKey = "QUERY_TEXT"
    catalogKey = "DATABASE_NAME"
    schemaKey = "SCHEMA_NAME"
    inputPrefix = "$.extract.outputs.query_history_prefix"
    outputPrefix = "$.extract.outputs.qi_output_prefix"
  }
  publish {
    // Wire the publish toggle from a workflow form field so the user can
    // opt out of publishing assets on a given run.
    executorEnabled = "{{load-to-atlan}}"
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 14400
    }
  }
}

credentialUrlGroup = new AdvancedJDBCUrlGroup {
  protocol = ""
  urlAddonBefore = "jdbc:postgresql://"
  hostField = new FieldSpec {
    name = "host"
    displayName = "Host"
    placeholder = "host.example.com"
    width = 6
    feedback = true
  }
  portField = new FieldSpec {
    name = "port"
    fieldType = "number"
    displayName = "Port"
    placeholder = "5432"
    defaultValue = "5432"
    required = false
    width = 3
  }
  extraFields {
    new FieldSpec { name = "database"; displayName = "Database"; width = 4 }
    new ConditionalFieldSpec {
      name = "token_audience"
      defaultValue = ""
      conditions {
        new Condition {
          filter = new Dynamic {
            `$or` {
              new Dynamic { ["agent-json.auth-type"] = "token" }
              new Dynamic { ["credential-guid.auth-type"] = "token" }
            }
          }
          overrideRequired = true
          overrideType = "string"
          overrideUi = new Widget {
            widget = "input"
            label = "Token audience"
            placeholder = "api://default"
            grid = 4
          }
        }
      }
    }
  }
}

credentialAuthOptions {
  ["basic"] = new JDBCUrlAuthOption {
    label = "Basic"
    nestedLabel = "Basic Auth"
    urlPartMapping = new UrlPartMapping {
      hostname = "host"
      searchParams {
        ["port"] = new UrlRef { field = "port" }
      }
    }
    fields {
      new FieldSpec { name = "username"; displayName = "Username"; width = 4 }
      new FieldSpec { name = "password"; sensitive = true; displayName = "Password"; width = 4 }
    }
  }
  ["token"] = new JDBCUrlAuthOption {
    label = "Token"
    nestedLabel = "Token Auth"
    urlPartMapping = new UrlPartMapping {
      hostname = "host"
      searchParams {
        ["port"] = new UrlRef { field = "port" }
        ["sslmode"] = new UrlLiteral { value = "require" }
      }
    }
    fields {
      new FieldSpec { name = "token"; sensitive = true; displayName = "API Token"; width = 8 }
      new FieldSpec {
        name = "ca_cert-file"
        displayName = "CA Certificate File"
        fieldType = "fileUpload"
        fileTypes { ".crt"; ".pem" }
        removeBeforeUpload = true
        required = false
      }
      new FieldSpec {
        name = "keytab-file"
        displayName = "Keytab File"
        fieldType = "credentialFileInput"
        placeholder = "Upload a file, type a secret-store key, or objectstore://path"
        fileTypes { ".keytab"; "application/kerberos-keytab" }
        required = false
      }
    }
  }
}

uiConfig = new UIConfig {
  tasks {
    ["Credential"] {
      inputs {
        ["credential-guid"] = new CredentialInput {
          credType = "atlan-connectors-full-featured"
          placeholderText = "Credential GUID"
        }
      }
    }
    ["Connection"] {
      inputs {
        ["connection"] = new ConnectionCreator {
          placeholderText = "Connection Name"
        }
      }
    }
    ["Configuration"] {
      inputs {
        ["include_filter"] = new TextInput {
          title = "Include filter"
          helpText = "Comma-separated list of schemas to include (leave blank for all)."
          width = 8
        }
        ["output_format"] = new Radio {
          title = "Output format"
          helpText = "Format for extracted metadata files."
          possibleValues {
            ["parquet"] = "Parquet"
            ["json"] = "JSON"
          }
          default = "parquet"
          required = true
        }
        ["max_results"] = new NumericInput {
          title = "Max results"
          helpText = "Cap on assets returned per schema."
          default = 500
          width = 4
          validationRules {
            new { type = "number"; required = false; min = 1; message = "Must be at least 1." }
          }
        }
        ["enable_lineage"] = new BooleanInput {
          title = "Enable lineage parsing"
          helpText = "Parse query history for column-level lineage."
          width = 4
        }
        ["load-to-atlan"] = new BooleanInput {
          title = "Publish to Atlan"
          helpText = "Publish extracted assets; uncheck for a dry run."
          default = true
          width = 4
        }
        ["log_level"] = new DropDown {
          title = "Log level"
          helpText = "Verbosity for the extraction run."
          possibleValues {
            ["INFO"] = "Info"
            ["DEBUG"] = "Debug"
            ["WARNING"] = "Warning"
          }
          default = "INFO"
          width = 4
        }
        ["lineage_depth"] = new NumericInput {
          title = "Lineage depth"
          helpText = "How many hops of upstream lineage to resolve (required when lineage is on)."
          default = 3
          width = 4
        }
        ["table_prefix"] = new TextInput {
          title = "Table prefix"
          helpText = "Only extract tables whose name starts with this prefix."
          width = 4
          // `validationRules` (ui.rules) and `validation` (ui.validation) are
          // independent pipelines; both can be set on the same widget.
          validationRules {
            new { required = false; max = 63; message = "Keep the prefix under 64 characters." }
          }
          // Regex validation: reject anything but lowercase alphanumerics and underscores.
          validation = new {
            type = "regex"
            pattern = "^[a-z0-9_]+$"
            message = "Only lowercase alphanumeric and underscores allowed."
          }
        }
        ["custom_attributes"] = new TextBoxInput {
          title = "Custom attributes"
          helpText = "Extra attributes to attach to every asset, as a JSON object."
          // JSON validation with auto-format on blur.
          validation = new {
            type = "json"
            formatOnBlur = true
          }
        }
        // lifecycle = "deprecated": generated Python field carries Field(deprecated=True).
        ["legacy_timeout"] = new NumericInput {
          title = "Legacy timeout"
          helpText = "Deprecated: use the standard pipeline timeout instead."
          required = false
          default = 60
          width = 4
          lifecycle = "deprecated"
          lifecycleMessage = "Use the standard pipeline timeout configuration instead."
        }
        // lifecycle = "sunset": generated Python field carries Field(deprecated=True,
        // json_schema_extra={"x-lifecycle": "sunset"}).
        ["old_batch_mode"] = new BooleanInput {
          title = "Old batch mode"
          helpText = "Sunset: no longer consumed by the extractor."
          required = false
          default = false
          lifecycle = "sunset"
        }
      }
    }
    ["Schema selection"] {
      inputs {
        ["schemas"] = new SqlTree {
          title = "Schemas to include"
          desc = "Select schemas from which to extract metadata."
          sqlQuery = "show atlan schemas"
          credentialType = "atlan-connectors-full-featured"
          excludePatterns = List("information_schema")
        }
      }
    }
  }
  // lineage_depth becomes required when the lineage toggle is on.
  rules {
    new UIRule {
      whenInputs { ["enable_lineage"] = "true" }
      required { "lineage_depth" }
    }
  }
}

// Custom node outside the typed pipeline — useful for one-off steps that
// do not fit the canonical extract→qi→publish sequence.
extraNodes {
  // Custom node outside the typed pipeline — runs after publish completes.
  ["notify"] = new DAGNode {
    displayName = "Notify"
    workflowType = "NotifyWorkflow"
    args {
      ["webhook_url"] = "$.extract.outputs.notify_webhook_url"
    }
    dependsOn { "publish" }
  }
}

// Opt-in full-DAG e2e test. Because this is set, `pkl eval` emits a complete,
// runnable AGENT-mode (SDR) test at `tests/e2e/test_full_featured_full_dag.py` —
// no per-app test authoring. The knobs below are all a SQL connector needs; the
// AE-payload / credential / polling machinery lives in the SDK's SQLAppE2ETest.
e2e = new E2EConfig {
  // The hermetic source the CI-side worker reaches (compose service name).
  host = "postgres"
  port = 5432
  // Scope the crawl to the seed's `public.e2e_*` objects.
  includeFilter = #"^public\.e2e_.*$"#
  expectedMinAssetCounts {
    ["Database"] = 1
    ["Schema"] = 1
    ["Table"] = 2
    ["Column"] = 8
  }
}
