amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"
import "../../src/Connectors.pkl"

name = "trino"
displayName = "Trino Assets"
connector = Connectors.TRINO
// These apps use explicit name override in their Python code (v2 convention).
// The override prevents auto kebab-case conversion in the manifest.
workflowTypeOverride = "TrinoMetadataExtractionWorkflow"
icon = "https://assets.atlan.com/assets/trino.svg"
logo = "https://assets.atlan.com/assets/trino.svg"
credentialConnectorType = "jdbc"

// ---------------------------------------------------------------------------
// Credential config — FieldSpec-based
// ---------------------------------------------------------------------------

credentialCommonFields {
  new FieldSpec {
    name = "host"
    displayName = "Host"
    placeholder = "trino.example.com"
    width = 6
  }
  new FieldSpec {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    defaultValue = "443"
    width = 2
  }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic Authentication"
    fields {
      new FieldSpec { name = "username"; displayName = "Username"; placeholder = "Username"; width = 4 }
      new FieldSpec { name = "password"; sensitive = true; displayName = "Password"; placeholder = "Password"; width = 4 }
    }
    extraFields {
      new FieldSpec { name = "__enable_tls_https"; displayName = "Enable TLS/HTTPS"; fieldType = "select"; options { "true"; "false" }; optionLabels { ["true"] = "True"; ["false"] = "False" }; defaultValue = "false"; helpText = "If enabled will allow only TLS/HTTPS connections on the host/port."; width = 4 }
      new FieldSpec { name = "__disable_ssl_verification"; displayName = "Disable SSL verification"; fieldType = "select"; options { "true"; "false" }; optionLabels { ["true"] = "True"; ["false"] = "False" }; defaultValue = "false"; helpText = "Disable if using self signed certificates instead of a trusted certificate authority (CA)."; width = 4 }
    }
  }
  ["jwt"] = new AuthOption {
    label = "JWT Authentication"
    fields {}
    extraFields {
      new FieldSpec { name = "__jwt_token"; sensitive = true; displayName = "JWT Token"; placeholder = "JWT Token" }
      new FieldSpec { name = "__enable_tls_https"; displayName = "Enable TLS/HTTPS"; fieldType = "select"; options { "true"; "false" }; optionLabels { ["true"] = "True"; ["false"] = "False" }; defaultValue = "false"; helpText = "If enabled will allow only TLS/HTTPS connections on the host/port."; width = 4 }
      new FieldSpec { name = "__disable_ssl_verification"; displayName = "Disable SSL verification"; fieldType = "select"; options { "true"; "false" }; optionLabels { ["true"] = "True"; ["false"] = "False" }; defaultValue = "false"; helpText = "Disable if using self signed certificates instead of a trusted certificate authority (CA)."; width = 4 }
    }
  }
}

// ---------------------------------------------------------------------------
// Workflow config
// ---------------------------------------------------------------------------

uiConfig {
  tasks {
    ["Credential"] {
      inputs {
        ["extraction-method"] = new Config.Radio {
          title = "Extraction method"
          helpText = "Determines the method the package will use to extract metadata."
          possibleValues {
            ["direct"] = "Direct"
          }
          default = "direct"
          required = true
        }
        ["credential-guid"] = new Config.CredentialInput {
          title = ""
          credType = "atlan-connectors-trino"
          placeholderText = "Credential Guid"
        }
      }
    }
    ["Connection"] {
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = ""
          placeholderText = "Connection Name"
        }
        ["publish-mode"] = new Config.DropDown {
          title = "Run Mode"
          possibleValues {
            ["production"] = "Production"
            ["test"] = "Test"
            ["dev"] = "Development"
          }
          default = "production"
          width = 4
        }
      }
    }
    ["Metadata"] {
      inputs {
        ["include-filter"] = new Config.SqlTree {
          title = "Include Metadata"
          desc = "Only selected catalogs and schemas will be extracted."
          sqlQuery = "show atlan schemas"
          credentialType = "atlan-connectors-trino"
          cred = "credential-guid"
          excludePatterns = List("information_*")
          databaseExcludePatterns = List("jmx", "memory", "system", "tpcds", "tpch")
          width = 4
        }
        ["exclude-filter"] = new Config.SqlTree {
          title = "Exclude Metadata"
          desc = "Selected catalogs and schemas wont be extracted."
          sqlQuery = "show atlan schemas"
          credentialType = "atlan-connectors-trino"
          cred = "credential-guid"
          excludePatterns = List("information_*")
          databaseExcludePatterns = List("jmx", "memory", "system", "tpcds", "tpch")
          width = 4
        }
        ["preflight-check"] = new Config.SageV2 {
          title = ""
          checks {
            new Dynamic { id = 1; name = "catalogsCheck"; title = "Catalogs and schemas"; loaderText = "Checking permissions" }
          }
        }
        ["advanced-config-strategy"] = new Config.Radio {
          title = "Advanced Config"
          helpText = "Set advanced configuration of the crawler"
          possibleValues {
            ["default"] = "Default"
            ["custom"] = "Advanced"
          }
          default = "default"
          required = true
        }
        ["use-source-schema-filtering"] = new Config.Radio {
          title = "Enable Source Level Filtering"
          helpText = "Enable or Disable Schema Level Filtering on source."
          possibleValues {
            ["true"] = "True"
            ["false"] = "False"
          }
          default = "false"
          width = 4
        }
        ["use-jdbc-internal-methods"] = new Config.Radio {
          title = "Use JDBC Internal Methods"
          helpText = "Enable or Disable JDBC internal methods for data extraction."
          possibleValues {
            ["true"] = "True"
            ["false"] = "False"
          }
          default = "true"
          width = 4
          hide = true
        }
      }
    }
  }
}
