{
  "id": "trino",
  "name": "Trino Assets",
  "logo": "https://assets.atlan.com/assets/trino.svg",
  "config": {
    "properties": {
      "extraction-method": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Extraction method",
          "hidden": false,
          "help": "Determines the method the package will use to extract metadata.",
          "grid": 8
        },
        "default": "direct",
        "enum": [
          "direct"
        ],
        "enumNames": [
          "Direct"
        ]
      },
      "credential-guid": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "credential",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Credential Guid",
          "grid": 8,
          "credentialType": "atlan-connectors-trino",
          "isTestAuthenticationDisabled": false
        }
      },
      "connection": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "connection",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Connection Name",
          "grid": 8
        }
      },
      "publish-mode": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "select",
          "label": "Run Mode",
          "hidden": false,
          "help": "",
          "grid": 4,
          "mode": ""
        },
        "default": "production",
        "enum": [
          "production",
          "test",
          "dev"
        ],
        "enumNames": [
          "Production",
          "Test",
          "Development"
        ]
      },
      "include-filter": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "sqltree",
          "label": "Include Metadata",
          "hidden": false,
          "help": "",
          "grid": 4,
          "connectorConfigName": "atlan-connectors-trino",
          "credential": "credential-guid",
          "sql": "show atlan schemas",
          "schemaExcludePattern": [
            "information_*"
          ],
          "databaseExcludePattern": [
            "jmx",
            "memory",
            "system",
            "tpcds",
            "tpch"
          ],
          "description": "Only selected catalogs and schemas will be extracted."
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}"
      },
      "exclude-filter": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "sqltree",
          "label": "Exclude Metadata",
          "hidden": false,
          "help": "",
          "grid": 4,
          "connectorConfigName": "atlan-connectors-trino",
          "credential": "credential-guid",
          "sql": "show atlan schemas",
          "schemaExcludePattern": [
            "information_*"
          ],
          "databaseExcludePattern": [
            "jmx",
            "memory",
            "system",
            "tpcds",
            "tpch"
          ],
          "description": "Selected catalogs and schemas wont be extracted."
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}"
      },
      "preflight-check": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "sageV2",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8,
          "config": [
            {
              "id": 1,
              "name": "catalogsCheck",
              "title": "Catalogs and schemas",
              "loaderText": "Checking permissions"
            }
          ]
        }
      },
      "advanced-config-strategy": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Advanced Config",
          "hidden": false,
          "help": "Set advanced configuration of the crawler",
          "grid": 8
        },
        "default": "default",
        "enum": [
          "default",
          "custom"
        ],
        "enumNames": [
          "Default",
          "Advanced"
        ]
      },
      "use-source-schema-filtering": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "radio",
          "label": "Enable Source Level Filtering",
          "hidden": false,
          "help": "Enable or Disable Schema Level Filtering on source.",
          "grid": 4
        },
        "default": "false",
        "enum": [
          "true",
          "false"
        ],
        "enumNames": [
          "True",
          "False"
        ]
      },
      "use-jdbc-internal-methods": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "radio",
          "label": "Use JDBC Internal Methods",
          "hidden": true,
          "help": "Enable or Disable JDBC internal methods for data extraction.",
          "grid": 4
        },
        "default": "true",
        "enum": [
          "true",
          "false"
        ],
        "enumNames": [
          "True",
          "False"
        ]
      }
    },
    "steps": [
      {
        "title": "Credential",
        "description": "",
        "id": "credential",
        "properties": [
          "extraction-method",
          "credential-guid"
        ]
      },
      {
        "title": "Connection",
        "description": "",
        "id": "connection",
        "properties": [
          "connection",
          "publish-mode"
        ]
      },
      {
        "title": "Metadata",
        "description": "",
        "id": "metadata",
        "properties": [
          "include-filter",
          "exclude-filter",
          "preflight-check",
          "advanced-config-strategy",
          "use-source-schema-filtering",
          "use-jdbc-internal-methods"
        ]
      }
    ]
  }
}
