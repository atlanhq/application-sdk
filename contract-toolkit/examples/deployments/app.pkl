/// Deployments map example — demonstrates named worker pools with per-pool
/// KEDA, profiles, resources, and cooldownPeriod.
///
/// Two pools:
///   "hot"  — always-on (minReplicaCount=1), serves the "main" profile,
///             lenient cooldown (300 s) so warm workers are not killed
///             between bursts.
///   "cold" — scale-to-zero (minReplicaCount=0), serves the "exceptional"
///             profile, aggressive cooldown (30 s) to reclaim resources fast.
amends "../../src/App.pkl"

name = "deployments-example"
displayName = "Deployments Map Example"
icon = "https://assets.atlan.com/assets/fullscreen-open.svg"
hasCredentialConfig = false

deployments {
  ["hot"] = new Deployment {
    profiles { "main" }
    keda {
      enabled = true
      minReplicaCount = 1
      cooldownPeriod = 300
      temporal {
        targetQueueSize = 10
      }
    }
    resources = new ResourceConfig {
      requests {
        ["cpu"] = "500m"
        ["memory"] = "1Gi"
      }
      limits {
        ["cpu"] = "2"
        ["memory"] = "4Gi"
      }
    }
    env {
      ["WORKER_TYPE"] = "hot"
    }
  }
  ["cold"] = new Deployment {
    profiles { "exceptional" }
    keda {
      enabled = true
      minReplicaCount = 0
      cooldownPeriod = 30
      temporal {
        targetQueueSize = 5
      }
    }
    resources = new ResourceConfig {
      requests {
        ["cpu"] = "100m"
        ["memory"] = "256Mi"
      }
    }
    env {
      ["WORKER_TYPE"] = "cold"
    }
  }
}

pipeline {
  publish = null
}

uiConfig = new UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["target"] = new TextInput {
          title = "Target"
          placeholderText = "my-target"
          helpText = "What to process."
        }
      }
    }
  }
}
