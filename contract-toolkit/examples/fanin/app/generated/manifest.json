{
  "execution_mode": "automation-engine",
  "dag": {
    "extract": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Extract Fan-in Example Metadata",
      "app_name": "{app_name}",
      "inputs": {
        "workflow_type": "fanin",
        "app_name": "{app_name}",
        "app_id": "",
        "argo_workflow_slug": "",
        "task_queue": "atlan-fanin-{deployment_name}",
        "args": {
          "credential": "{{credential}}",
          "credential_guid": "{{credential-guid}}"
        }
      }
    },
    "publish": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Publish to Atlas",
      "app_name": "publish",
      "inputs": {
        "workflow_type": "PublishWorkflow",
        "app_name": "publish",
        "task_queue": "atlan-publish-{deployment_name}",
        "args": {
          "connection_qualified_name": "$.extract.outputs.connection_qualified_name",
          "transformed_data_prefix": "$.extract.outputs.transformed_data_prefix",
          "publish_state_prefix": "$.extract.outputs.publish_state_prefix",
          "current_state_prefix": "$.extract.outputs.current_state_prefix",
          "connection_creation_enabled": true,
          "executor_enabled": true,
          "connection_entity": "{{connection}}"
        }
      },
      "depends_on": {
        "node_id": "extract"
      },
      "error_handling": {
        "start_to_close_timeout_seconds": 86400
      }
    },
    "left": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Left Branch",
      "app_name": "automation-engine",
      "inputs": {
        "workflow_type": "LeftWorkflow",
        "app_name": "automation-engine",
        "task_queue": "atlan-automation-engine-{deployment_name}",
        "args": {}
      },
      "depends_on": {
        "node_id": "extract"
      }
    },
    "right": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Right Branch",
      "app_name": "automation-engine",
      "inputs": {
        "workflow_type": "RightWorkflow",
        "app_name": "automation-engine",
        "task_queue": "atlan-automation-engine-{deployment_name}",
        "args": {}
      },
      "depends_on": {
        "node_id": "extract"
      }
    },
    "join": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Join After Both",
      "app_name": "automation-engine",
      "inputs": {
        "workflow_type": "JoinWorkflow",
        "app_name": "automation-engine",
        "task_queue": "atlan-automation-engine-{deployment_name}",
        "args": {}
      },
      "depends_on": {
        "and_conditions": [
          {
            "node_id": "left",
            "tag": "success"
          },
          {
            "node_id": "right",
            "tag": "success"
          }
        ]
      }
    },
    "recover": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Recover If Either Branch Fails",
      "app_name": "automation-engine",
      "inputs": {
        "workflow_type": "RecoverWorkflow",
        "app_name": "automation-engine",
        "task_queue": "atlan-automation-engine-{deployment_name}",
        "args": {}
      },
      "depends_on": {
        "or_conditions": [
          {
            "node_id": "left",
            "tag": "failure"
          },
          {
            "node_id": "right",
            "tag": "failure"
          }
        ]
      }
    }
  }
}
