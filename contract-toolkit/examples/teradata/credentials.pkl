/// Shared Teradata credential configuration.
///
/// Both crawler.pkl and miner.pkl import this module to define credentials
/// once. The same host/port/auth options apply to both workflows.
module credentials

import "../../src/NativeApp.pkl"

/// Common fields: host and port for Teradata connection.
commonFields: Listing<NativeApp.FieldSpec> = new {
  new {
    name = "host"
    displayName = "Host"
    placeholder = "teradata.example.com"
    helpText = "Hostname or IP address of the Teradata instance."
    width = 6
  }
  new {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    defaultValue = "1025"
    width = 2
  }
}

/// Authentication options: basic and LDAP.
authOptions: Mapping<String, NativeApp.AuthOption> = new {
  ["basic"] = new {
    label = "Basic Authentication"
    fields {
      new NativeApp.FieldSpec { name = "username"; displayName = "Username"; placeholder = "Username"; width = 4 }
      new NativeApp.FieldSpec { name = "password"; sensitive = true; displayName = "Password"; placeholder = "Password"; width = 4 }
    }
  }
  ["ldap"] = new {
    label = "LDAP Authentication"
    fields {
      new NativeApp.FieldSpec { name = "username"; displayName = "Username"; placeholder = "LDAP Username"; width = 4 }
      new NativeApp.FieldSpec { name = "password"; sensitive = true; displayName = "Password"; placeholder = "LDAP Password"; width = 4 }
    }
  }
}

/// Agent selector config shared between crawler and miner.
agentConfig: Listing = new {
  new Listing {
    "atlan-connectors-teradata"
    new Mapping {
      ["properties"] = new Mapping {
        ["agent-type"] = new Mapping { ["type"] = "string"; ["ui"] = new Mapping { ["hidden"] = true } }
        ["basic"] = new Mapping {
          ["properties"] = new Mapping {
            ["username"] = new Mapping { ["default"] = ""; ["ui"] = new Mapping { ["placeholder"] = "Store Credential Path" } }
            ["password"] = new Mapping { ["default"] = ""; ["ui"] = new Mapping { ["widget"] = ""; ["placeholder"] = "Store Credential Path" } }
          }
        }
        ["ldap"] = new Mapping {
          ["properties"] = new Mapping {
            ["username"] = new Mapping { ["default"] = ""; ["ui"] = new Mapping { ["placeholder"] = "Store Credential Path" } }
            ["password"] = new Mapping { ["default"] = ""; ["ui"] = new Mapping { ["widget"] = ""; ["placeholder"] = "Store Credential Path" } }
          }
        }
      }
    }
  }
  new Listing { "atlan-connectors-agent" }
}
