{
  "icon": "https://assets.atlan.com/assets/Teradata.svg",
  "helpdeskLink": "",
  "logo": "https://assets.atlan.com/assets/Teradata.svg",
  "connector": "teradata",
  "defaultConnectorType": "",
  "config": {
    "properties": {
      "name": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Name",
          "hidden": true,
          "placeholder": "Host Name"
        }
      },
      "connector": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Connector",
          "hidden": true,
          "placeholder": "Connector"
        }
      },
      "connectorType": {
        "type": "string",
        "required": false,
        "ui": {
          "key": "_host",
          "label": "connectorType",
          "placeholder": "connectorType",
          "hidden": true
        }
      },
      "host": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "input",
          "label": "Host",
          "hidden": false,
          "help": "Hostname or IP address of the Teradata instance.",
          "placeholder": "teradata.example.com",
          "grid": 6
        }
      },
      "port": {
        "type": "number",
        "required": true,
        "default": 1025,
        "ui": {
          "widget": "inputNumber",
          "label": "Port",
          "hidden": false,
          "grid": 2
        }
      },
      "auth-type": {
        "type": "string",
        "enum": [
          "basic",
          "ldap"
        ],
        "default": "basic",
        "required": true,
        "enumNames": [
          "Basic Authentication",
          "LDAP Authentication"
        ],
        "ui": {
          "widget": "radio",
          "hidden": false,
          "label": "Authentication"
        }
      },
      "basic": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "username": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "input",
              "label": "Username",
              "hidden": false,
              "placeholder": "Username",
              "grid": 4
            }
          },
          "password": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "password",
              "label": "Password",
              "hidden": false,
              "placeholder": "Password",
              "grid": 4
            }
          }
        }
      },
      "ldap": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "username": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "input",
              "label": "Username",
              "hidden": false,
              "placeholder": "LDAP Username",
              "grid": 4
            }
          },
          "password": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "password",
              "label": "Password",
              "hidden": false,
              "placeholder": "LDAP Password",
              "grid": 4
            }
          }
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "auth-type": {
            "const": "basic"
          }
        },
        "required": [
          "basic"
        ]
      },
      {
        "properties": {
          "auth-type": {
            "const": "ldap"
          }
        },
        "required": [
          "ldap"
        ]
      }
    ]
  }
}
