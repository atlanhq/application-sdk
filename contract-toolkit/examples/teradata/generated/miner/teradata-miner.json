{
  "id": "teradata-miner",
  "name": "Teradata Miner",
  "logo": "https://assets.atlan.com/assets/Teradata.svg",
  "config": {
    "properties": {
      "connection-qualified-name": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "connectionSelector",
          "label": "Connection",
          "hidden": false,
          "help": "",
          "placeholder": "Select a connection",
          "grid": 8,
          "mode": "",
          "start": 1,
          "connectorName": "teradata"
        }
      },
      "extraction-method": {
        "type": "conditional",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Miner Extraction Method",
          "hidden": false,
          "help": "Determines the method to use to fetch the raw metadata for mining",
          "grid": 8
        },
        "default": "query_history",
        "conditions": [
          {
            "property": "labFlag",
            "value": "SECURE_AGENT_EXTRACTION",
            "enum": [
              "query_history",
              "agent"
            ],
            "enumNames": [
              "Query History",
              "Agent"
            ]
          }
        ],
        "enum": [
          "query_history"
        ],
        "enumNames": [
          "Query History"
        ]
      },
      "agent-json": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "agent",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Agent JSON",
          "grid": 8,
          "agentConfigs": [
            [
              "atlan-connectors-teradata",
              {
                "properties": {
                  "agent-type": {
                    "type": "string",
                    "ui": {
                      "hidden": true
                    }
                  },
                  "basic": {
                    "properties": {
                      "username": {
                        "default": "",
                        "ui": {
                          "placeholder": "Store Credential Path"
                        }
                      },
                      "password": {
                        "default": "",
                        "ui": {
                          "widget": "",
                          "placeholder": "Store Credential Path"
                        }
                      }
                    }
                  },
                  "ldap": {
                    "properties": {
                      "username": {
                        "default": "",
                        "ui": {
                          "placeholder": "Store Credential Path"
                        }
                      },
                      "password": {
                        "default": "",
                        "ui": {
                          "widget": "",
                          "placeholder": "Store Credential Path"
                        }
                      }
                    }
                  }
                }
              }
            ],
            [
              "atlan-connectors-agent"
            ]
          ]
        }
      },
      "miner-start-time-epoch": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "input",
          "label": "Start date",
          "hidden": false,
          "help": "Start time epoch for miner query extraction.",
          "placeholder": "0",
          "grid": 4
        }
      },
      "advanced-config": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Advanced Config",
          "hidden": false,
          "help": "Set advanced configuration of the miner",
          "grid": 8
        },
        "default": "default",
        "enum": [
          "default",
          "custom"
        ],
        "enumNames": [
          "Default",
          "Advanced"
        ]
      },
      "cross-connection": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "radio",
          "label": "Cross Connection",
          "hidden": false,
          "help": "Enable searching for lineage across all available connections.",
          "grid": 4
        },
        "default": "false",
        "enum": [
          "true",
          "false"
        ],
        "enumNames": [
          "True",
          "False"
        ]
      },
      "control-config-strategy": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Control Config",
          "hidden": false,
          "help": "Controls custom experimental feature flags for the miner",
          "grid": 8
        },
        "default": "default",
        "enum": [
          "default",
          "custom"
        ],
        "enumNames": [
          "Default",
          "Custom"
        ]
      },
      "control-config": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "input",
          "label": "Custom Config",
          "hidden": false,
          "help": "Custom JSON config controlling experimental feature flags.",
          "placeholder": "{\"feature_x\":true}",
          "grid": 8
        }
      },
      "preflight-check": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "sageV2",
          "label": "Preflight Checks",
          "hidden": false,
          "help": "",
          "grid": 8
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "extraction-method": {
            "const": "query_history"
          }
        },
        "required": [
          "miner-start-time-epoch",
          "preflight-check"
        ]
      },
      {
        "properties": {
          "extraction-method": {
            "const": "agent"
          }
        },
        "required": [
          "agent-json",
          "miner-start-time-epoch"
        ]
      },
      {
        "properties": {
          "advanced-config": {
            "const": "custom"
          }
        },
        "required": [
          "cross-connection",
          "control-config-strategy"
        ]
      },
      {
        "properties": {
          "control-config-strategy": {
            "const": "custom"
          }
        },
        "required": [
          "control-config"
        ]
      }
    ],
    "steps": [
      {
        "title": "Configuration",
        "description": "",
        "id": "configuration",
        "properties": [
          "connection-qualified-name",
          "extraction-method",
          "agent-json",
          "miner-start-time-epoch",
          "advanced-config",
          "cross-connection",
          "control-config-strategy",
          "control-config",
          "preflight-check"
        ]
      }
    ]
  }
}
