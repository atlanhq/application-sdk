{
  "id": "redshift",
  "name": "Redshift",
  "logo": "https://assets.atlan.com/assets/redshift.svg",
  "config": {
    "properties": {
      "extraction-method": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Extraction method",
          "hidden": false,
          "help": "Determines the method the package will use to extract metadata.",
          "grid": 8
        },
        "default": "direct",
        "enum": [
          "direct",
          "s3"
        ],
        "enumNames": [
          "Direct",
          "Offline"
        ]
      },
      "credential-guid": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "credential",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Credential Guid",
          "grid": 8,
          "credentialType": "atlan-connectors-redshift",
          "isTestAuthenticationDisabled": false
        }
      },
      "connection": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "connection",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Connection Name",
          "grid": 8
        }
      },
      "include-filter": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "sqltree",
          "label": "Include Metadata",
          "hidden": false,
          "help": "",
          "grid": 4,
          "credential": "credential-guid",
          "sql": "show atlan schemas",
          "schemaExcludePattern": [
            "pg_*",
            "information_*"
          ],
          "description": "Only selected databases and schemas will be extracted."
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}"
      },
      "exclude-filter": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "sqltree",
          "label": "Exclude Metadata",
          "hidden": false,
          "help": "",
          "grid": 4,
          "credential": "credential-guid",
          "sql": "show atlan schemas",
          "schemaExcludePattern": [
            "pg_*",
            "information_*"
          ],
          "description": "Selected databases and schemas wont be extracted."
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}"
      },
      "temp-table-regex": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "input",
          "label": "Exclude regex for tables & views",
          "hidden": false,
          "help": "Regex of tables & views to ignore.",
          "placeholder": ".*_TMP|.*_TEMP|TMP.*|TEMP.*",
          "grid": 4
        }
      },
      "advanced-config": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Advanced Config",
          "hidden": false,
          "help": "Set advanced configuration of the crawler",
          "grid": 8
        },
        "default": "default",
        "enum": [
          "default",
          "custom"
        ],
        "enumNames": [
          "Default",
          "Advanced"
        ]
      },
      "cross-connection": {
        "type": "boolean",
        "required": false,
        "ui": {
          "widget": "boolean",
          "label": "Cross Connection",
          "hidden": false,
          "help": "Enable searching for lineage across all available connections on Atlan.",
          "grid": 4
        },
        "default": false
      },
      "use-source-schema-filtering": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "radio",
          "label": "Enable Source Level Filtering",
          "hidden": false,
          "help": "Enable or Disable Schema Level Filtering on source.",
          "grid": 4
        },
        "default": "false",
        "enum": [
          "true",
          "false"
        ],
        "enumNames": [
          "True",
          "False"
        ]
      },
      "use-jdbc-internal-methods": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "radio",
          "label": "Use JDBC Internal Methods",
          "hidden": true,
          "help": "Enable or Disable JDBC internal methods for data extraction.",
          "grid": 4
        },
        "default": "true",
        "enum": [
          "true",
          "false"
        ],
        "enumNames": [
          "True",
          "False"
        ]
      },
      "control-config-strategy": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Control Config",
          "hidden": false,
          "help": "Controls custom experimental feature flags for the crawler",
          "grid": 8
        },
        "default": "default",
        "enum": [
          "default",
          "custom"
        ],
        "enumNames": [
          "Default",
          "Custom"
        ]
      },
      "control-config": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "input",
          "label": "Custom Config",
          "hidden": false,
          "help": "Custom JSON config controlling experimental feature flags",
          "placeholder": "{\"feature_x\":true}",
          "grid": 8
        },
        "default": "{}"
      },
      "preflight-check": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "sageV2",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8,
          "config": [
            {
              "id": 1,
              "name": "schemasCheck",
              "title": "Databases and schemas",
              "loaderText": "Checking databases/schemas permissions"
            },
            {
              "id": 2,
              "name": "tablesMetadataCheck",
              "title": "Tables metadata",
              "loaderText": "Checking tables full metadata permission"
            },
            {
              "id": 3,
              "name": "externalTablesMetadataCheck",
              "title": "External tables metadata",
              "loaderText": "Checking external tables full metadata permission",
              "optional": true
            }
          ]
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "extraction-method": {
            "const": "direct"
          }
        },
        "required": [
          "credential-guid",
          "include-filter",
          "exclude-filter",
          "temp-table-regex",
          "preflight-check"
        ]
      },
      {
        "properties": {
          "advanced-config": {
            "const": "custom"
          }
        },
        "required": [
          "cross-connection",
          "use-source-schema-filtering",
          "use-jdbc-internal-methods",
          "control-config-strategy"
        ]
      },
      {
        "properties": {
          "advanced-config": {
            "const": "custom"
          },
          "control-config-strategy": {
            "const": "custom"
          }
        },
        "required": [
          "control-config"
        ]
      }
    ],
    "steps": [
      {
        "title": "Credential",
        "description": "",
        "id": "credential",
        "properties": [
          "extraction-method",
          "credential-guid"
        ]
      },
      {
        "title": "Connection",
        "description": "",
        "id": "connection",
        "properties": [
          "connection"
        ]
      },
      {
        "title": "Metadata",
        "description": "",
        "id": "metadata",
        "properties": [
          "include-filter",
          "exclude-filter",
          "temp-table-regex",
          "advanced-config",
          "cross-connection",
          "use-source-schema-filtering",
          "use-jdbc-internal-methods",
          "control-config-strategy",
          "control-config",
          "preflight-check"
        ]
      }
    ]
  }
}
