{
  "icon": "https://assets.atlan.com/assets/redshift.svg",
  "helpdeskLink": "https://ask.atlan.com/hc/en-us/articles/4418217886481-How-to-set-up-your-Redshift-connection-with-Atlan",
  "logo": "https://assets.atlan.com/assets/redshift.svg",
  "connector": "redshift",
  "defaultConnectorType": "jdbc",
  "config": {
    "properties": {
      "name": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Name",
          "hidden": true,
          "placeholder": "Host Name"
        }
      },
      "connector": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Connector",
          "hidden": true,
          "placeholder": "Connector"
        }
      },
      "connectorType": {
        "type": "string",
        "required": false,
        "ui": {
          "key": "_host",
          "label": "connectorType",
          "placeholder": "connectorType",
          "hidden": true
        }
      },
      "host": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "input",
          "label": "Host Name",
          "hidden": false,
          "help": "Redshift cluster hostname",
          "placeholder": "examplecluster.abc123xyz789.us-west-2.redshift.amazonaws.com",
          "grid": 6
        }
      },
      "port": {
        "type": "number",
        "required": true,
        "default": 5439,
        "ui": {
          "widget": "inputNumber",
          "label": "Port",
          "hidden": false,
          "grid": 2
        }
      },
      "auth-type": {
        "type": "string",
        "enum": [
          "basic",
          "iam",
          "role"
        ],
        "default": "basic",
        "required": true,
        "enumNames": [
          "Basic",
          "IAM User",
          "IAM Role"
        ],
        "ui": {
          "widget": "radio",
          "hidden": false,
          "label": "Authentication"
        }
      },
      "basic": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "username": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "input",
              "label": "Username",
              "hidden": false,
              "help": "Redshift database username",
              "placeholder": "Username",
              "grid": 4
            }
          },
          "password": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "password",
              "label": "Password",
              "hidden": false,
              "placeholder": "Password",
              "grid": 4
            }
          },
          "extra": {
            "type": "object",
            "ui": {
              "widget": "nested",
              "label": "",
              "header": "Advanced",
              "hidden": false
            },
            "properties": {
              "database": {
                "type": "string",
                "required": true,
                "ui": {
                  "widget": "input",
                  "label": "Database",
                  "hidden": false,
                  "help": "Default database for JDBC connection authentication.",
                  "placeholder": "dev",
                  "grid": 4
                }
              },
              "deployment_type": {
                "type": "string",
                "required": true,
                "enum": [
                  "provisioned",
                  "serverless"
                ],
                "enumNames": [
                  "Provisioned",
                  "Serverless"
                ],
                "default": "provisioned",
                "ui": {
                  "widget": "radio",
                  "label": "Deployment Type",
                  "hidden": false,
                  "help": "Redshift cluster Deployment Type",
                  "grid": 8
                }
              }
            }
          }
        }
      },
      "iam": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "username": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "input",
              "label": "AWS Access Key",
              "hidden": false,
              "help": "AWS Access Key",
              "placeholder": "Access Key",
              "grid": 4
            }
          },
          "password": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "password",
              "label": "AWS Secret Key",
              "hidden": false,
              "help": "AWS Secret Key",
              "placeholder": "Secret Key",
              "grid": 4
            }
          },
          "extra": {
            "type": "object",
            "ui": {
              "widget": "nested",
              "label": "",
              "header": "Advanced",
              "hidden": false
            },
            "properties": {
              "dbuser": {
                "type": "string",
                "required": true,
                "ui": {
                  "widget": "input",
                  "label": "Username",
                  "hidden": false,
                  "help": "Redshift database username",
                  "placeholder": "Username",
                  "grid": 4
                }
              },
              "cluster_id": {
                "type": "string",
                "ui": {
                  "widget": "input",
                  "label": "Cluster ID",
                  "hidden": false,
                  "help": "Redshift cluster ID, needed only for private clusters",
                  "placeholder": "cluster-id",
                  "grid": 4
                }
              },
              "database": {
                "type": "string",
                "required": true,
                "ui": {
                  "widget": "input",
                  "label": "Database",
                  "hidden": false,
                  "help": "Default database for JDBC connection authentication.",
                  "placeholder": "dev",
                  "grid": 4
                }
              },
              "deployment_type": {
                "type": "string",
                "required": true,
                "enum": [
                  "provisioned",
                  "serverless"
                ],
                "enumNames": [
                  "Provisioned",
                  "Serverless"
                ],
                "default": "provisioned",
                "ui": {
                  "widget": "radio",
                  "label": "Deployment Type",
                  "hidden": false,
                  "help": "Redshift cluster Deployment Type",
                  "grid": 8
                }
              }
            }
          }
        }
      },
      "role": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "extra": {
            "type": "object",
            "ui": {
              "widget": "nested",
              "label": "",
              "header": "Advanced",
              "hidden": false
            },
            "properties": {
              "dbuser": {
                "type": "string",
                "required": true,
                "ui": {
                  "widget": "input",
                  "label": "Username",
                  "hidden": false,
                  "help": "Redshift database username",
                  "placeholder": "Username",
                  "grid": 4
                }
              },
              "aws_role_arn": {
                "type": "string",
                "ui": {
                  "widget": "input",
                  "label": "AWS Role ARN",
                  "hidden": false,
                  "help": "AWS role to assume for the connection",
                  "placeholder": "arn:aws:iam::123456789012:role/roleName",
                  "grid": 4,
                  "rules": [
                    {
                      "pattern": "^arn:aws:iam::\\d{12}:role/.+",
                      "message": "Invalid format",
                      "trigger": "blur"
                    }
                  ]
                }
              },
              "region_name": {
                "type": "string",
                "ui": {
                  "widget": "input",
                  "label": "Region",
                  "hidden": false,
                  "help": "AWS region of Redshift cluster",
                  "placeholder": "us-west-2",
                  "grid": 4
                }
              },
              "cluster_id": {
                "type": "string",
                "ui": {
                  "widget": "input",
                  "label": "Cluster ID",
                  "hidden": false,
                  "help": "Redshift cluster ID, needed only for private clusters",
                  "placeholder": "cluster-id",
                  "grid": 4
                }
              },
              "aws_external_id": {
                "type": "string",
                "ui": {
                  "widget": "input",
                  "label": "AWS External ID",
                  "hidden": false,
                  "help": "AWS External ID",
                  "placeholder": "12345678-1234-1234-1234",
                  "grid": 4
                }
              },
              "database": {
                "type": "string",
                "required": true,
                "ui": {
                  "widget": "input",
                  "label": "Database",
                  "hidden": false,
                  "help": "Default database for JDBC connection authentication.",
                  "placeholder": "dev",
                  "grid": 4
                }
              },
              "deployment_type": {
                "type": "string",
                "required": true,
                "enum": [
                  "provisioned",
                  "serverless"
                ],
                "enumNames": [
                  "Provisioned",
                  "Serverless"
                ],
                "default": "provisioned",
                "ui": {
                  "widget": "radio",
                  "label": "Deployment Type",
                  "hidden": false,
                  "help": "Redshift cluster Deployment Type",
                  "grid": 8
                }
              }
            }
          }
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "auth-type": {
            "const": "basic"
          }
        },
        "required": [
          "basic"
        ]
      },
      {
        "properties": {
          "auth-type": {
            "const": "iam"
          }
        },
        "required": [
          "iam"
        ]
      },
      {
        "properties": {
          "auth-type": {
            "const": "role"
          }
        },
        "required": [
          "role"
        ]
      }
    ]
  }
}
