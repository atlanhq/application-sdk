/// Reusable object-store credential config for the OpenAPI cloud import path.
///
/// This uses the legacy credential-only module because the OpenAPI app needs to
/// emit an additional credential configmap that is not tied to the host app's
/// native credential.
amends "../../src/Credential.pkl"

import "../../src/Config.pkl"

name = "csa-connectors-objectstore"
source = "Object Store"
icon = "https://assets.atlan.com/assets/ph-shapes-light.svg"
helpdesk = "https://docs.atlan.com/apps/packages/references/all-apps"
logo = "https://assets.atlan.com/assets/ph-shapes-light.svg"
connectorType = "rest"

optionsTitle = "Cloud object store"

options {
  ["s3"] = new NestedCredentialInput {
    optionLabel = "S3"
    inputs {
      ["username"] = new Config.TextInput {
        title = "AWS access key"
        helpText = "Enter your AWS access key."
        width = 4
      }
      ["password"] = new Config.PasswordInput {
        title = "AWS secret key"
        helpText = "Enter your AWS secret key."
        width = 4
      }
      ["extra"] = new Config.NestedInput {
        title = "S3 details"
        inputs {
          ["aws_role_arn"] = new Config.TextInput {
            title = "AWS Role ARN"
            helpText = "ARN of the AWS role to assume"
            placeholderText = "arn:aws:iam::123456789012:role/roleName"
            width = 8
            validationRules {
              new Dynamic {
                pattern = #"^arn:aws:iam::\d{12}:role/.+"#
                message = "Please enter a valid role ARN"
                trigger = "blur"
              }
            }
          }
          ["region"] = new Config.TextInput {
            title = "Region"
            helpText = "Enter your AWS region."
            placeholderText = "us-west-1"
            width = 4
          }
          ["s3_bucket"] = new Config.TextInput {
            title = "Bucket"
            helpText = "Enter the bucket from which to retrieve the object store object(s)."
            placeholderText = "bucket-name"
            width = 4
          }
        }
      }
    }
  }
  ["gcs"] = new NestedCredentialInput {
    optionLabel = "GCS"
    inputs {
      ["username"] = new Config.TextInput {
        title = "Project ID"
        helpText = "Enter the ID of the GCP project."
        width = 4
      }
      ["password"] = new Config.PasswordInput {
        title = "Service account JSON"
        helpText = "Enter the JSON for your service account credentials."
        width = 8
      }
      ["extra"] = new Config.NestedInput {
        title = "GCS details"
        inputs {
          ["gcs_bucket"] = new Config.TextInput {
            title = "Bucket"
            helpText = "Enter the bucket from which to retrieve the object store object(s)."
            placeholderText = "bucket-name"
            width = 4
          }
        }
      }
    }
  }
  ["adls"] = new NestedCredentialInput {
    optionLabel = "ADLS"
    inputs {
      ["username"] = new Config.TextInput {
        title = "Azure client ID"
        helpText = "Enter the unique application (client) ID assigned to your app by Azure AD when the app was registered."
        width = 4
      }
      ["password"] = new Config.PasswordInput {
        title = "Azure client secret"
        helpText = "Enter your client secret."
        width = 4
      }
      ["extra"] = new Config.NestedInput {
        title = "ADLS details"
        inputs {
          ["azure_tenant_id"] = new Config.PasswordInput {
            title = "Azure tenant ID"
            helpText = "Enter the unique identifier of the Azure Active Directory instance."
            width = 4
          }
          ["storage_account_name"] = new Config.TextInput {
            title = "Storage account name"
            helpText = "Enter the name of your storage account."
            width = 4
          }
          ["adls_container"] = new Config.TextInput {
            title = "Container"
            helpText = "Enter the container from which to retrieve the object store object(s)."
            placeholderText = "container-name"
            width = 4
          }
        }
      }
    }
  }
}
