amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"
import "../../src/Connectors.pkl"
import "credentials.pkl" as ObjectStoreCredential

name = "openapi"
displayName = "OpenAPI Spec Loader"
connector = Connectors.API
icon = "https://assets.atlan.com/assets/apispec.png"
logo = "https://assets.atlan.com/assets/apispec.png"
workflowType = name
hasCredentialConfig = false
flatManifestArgs = true

uiConfig {
  tasks {
    ["Configuration"] {
      description = "OpenAPI spec configuration"
      inputs {
        ["import_type"] = new Config.Radio {
          title = "Import type"
          helpText = "How to provide the spec: URL fetch or cloud object storage."
          possibleValues {
            ["URL"] = "URL"
            ["CLOUD"] = "Cloud"
          }
          default = "URL"
          required = true
        }
        ["spec_url"] = new Config.TextInput {
          title = "Spec URL"
          helpText = "URL to the OpenAPI spec JSON/YAML document. Required when import type is URL."
          required = true
          placeholderText = "https://petstore3.swagger.io/api/v3/openapi.json"
        }
        ["spec_prefix"] = new Config.TextInput {
          title = "Object store path"
          helpText = "Object store directory path. Required when import type is Cloud."
          width = 4
          placeholderText = "path/to/file"
        }
        ["spec_key"] = new Config.TextInput {
          title = "Object key"
          helpText = "Object key or filename in the object store. Required when import type is Cloud."
          width = 4
          placeholderText = "openapi.json"
        }
        ["cloud_source"] = new Config.CredentialInput {
          title = "Cloud source"
          helpText = "Cloud storage credential. Required when import type is Cloud."
          required = true
          credType = "csa-connectors-objectstore"
          allowTestAuthentication = false
        }
      }
    }
    ["Connection"] {
      description = "Connection details"
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = "Connection"
          helpText = "Atlan connection to create or reuse."
          required = true
        }
      }
    }
  }
  rules {
    new Config.UIRule {
      whenInputs { ["import_type"] = "URL" }
      required { "spec_url" }
    }
    new Config.UIRule {
      whenInputs { ["import_type"] = "CLOUD" }
      required { "cloud_source"; "spec_prefix"; "spec_key" }
    }
  }
}

manifestTopLevelArgs {
  ["connection"] = "connection"
}

additionalOutputFiles {
  ["csa-connectors-objectstore.json"] = ObjectStoreCredential.output.files["csa-connectors-objectstore.json"]
}
