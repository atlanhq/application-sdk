/// Minimal example demonstrating `ConnectionRefInput`.
///
/// The widget renders the frontend `connectionSelector` with
/// `shouldIncludeConnectionInfo = true`, so the workflow receives full
/// connection object(s) instead of only qualified-name strings.
amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"
import "../../src/Connectors.pkl"

name = "connection-ref"
displayName = "ConnectionRef Example"
connector = Connectors.TRINO
workflowType = "ConnectionRefExampleWorkflow"
icon = "https://assets.atlan.com/assets/trino.svg"
hasCredentialConfig = false
hasPublishStep = false

uiConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["connection"] = new Config.ConnectionRefInput {
          title = "Connection"
          connectorFilter = "trino"
          placeholderText = "Select a connection"
          required = true
        }
        ["connections"] = new Config.ConnectionRefInput {
          title = "Connections"
          connectorFilters { "trino"; "clickhouse" }
          placeholderText = "Select connections"
          multiSelect = true
        }
      }
    }
  }
}
