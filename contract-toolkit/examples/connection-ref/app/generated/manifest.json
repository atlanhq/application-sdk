{
  "execution_mode": "automation-engine",
  "dag": {
    "extract": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Extract ConnectionRef Example Metadata",
      "app_name": "connection-ref",
      "inputs": {
        "workflow_type": "connection-ref",
        "app_name": "connection-ref",
        "app_id": "",
        "argo_workflow_slug": "",
        "task_queue": "atlan-connection-ref-{deployment_name}",
        "args": {
          "credential": "{{credential}}",
          "agent_json": "{{agent-json}}",
          "connection": "{{connection}}",
          "connections": "{{connections}}"
        }
      },
      "error_handling": {
        "start_to_close_timeout_seconds": 86400
      }
    }
  }
}
