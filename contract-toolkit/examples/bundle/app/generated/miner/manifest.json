{
  "execution_mode": "automation-engine",
  "dag": {
    "extract": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Extract Query Miner Metadata",
      "app_name": "miner",
      "inputs": {
        "workflow_type": "miner",
        "app_name": "miner",
        "app_id": "",
        "argo_workflow_slug": "",
        "task_queue": "atlan-miner-{deployment_name}",
        "args": {
          "credential": "{{credential}}",
          "agent_json": "{{agent-json}}",
          "credential_guid": "{{credential-guid}}",
          "lookback_days": "{{lookback-days}}",
          "max_queries": "{{max-queries}}"
        }
      },
      "error_handling": {
        "start_to_close_timeout_seconds": 86400
      }
    }
  }
}
