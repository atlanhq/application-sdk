/// Fixture: deploy block configured but emitDeploy NOT set (defaults to false).
/// Used by tests to verify the deploy: block is absent from atlan.yaml when
/// emitDeploy is omitted, even when deploy { ... } is explicitly configured.
amends "../../src/App.pkl"

name = "deploy-no-emit"
displayName = "Deploy No-Emit Fixture"
icon = "https://assets.atlan.com/assets/fullscreen-open.svg"
hasCredentialConfig = false

// deploy configured — but emitDeploy is NOT set, so the block must be absent.
deploy {
  keda {
    enabled = true
    minReplicaCount = 1
  }
}
