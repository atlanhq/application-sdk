{
  "icon": "https://assets.atlan.com/assets/azureCosmosDB.svg",
  "helpdeskLink": "",
  "logo": "https://assets.atlan.com/assets/azureCosmosDB.svg",
  "connector": "cosmos",
  "defaultConnectorType": "sdk",
  "config": {
    "properties": {
      "name": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Name",
          "hidden": true,
          "placeholder": "Host Name"
        }
      },
      "connector": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Connector",
          "hidden": true,
          "placeholder": "Connector"
        }
      },
      "connectorType": {
        "type": "string",
        "required": false,
        "ui": {
          "key": "_host",
          "label": "connectorType",
          "placeholder": "connectorType",
          "hidden": true
        }
      },
      "auth-type": {
        "type": "string",
        "enum": [
          "vcore",
          "ru",
          "vcoreandru"
        ],
        "default": "vcore",
        "required": true,
        "enumNames": [
          "vCore",
          "RU",
          "vCore and RU"
        ],
        "ui": {
          "widget": "radio",
          "hidden": false,
          "label": "Select the deployment types to crawl",
          "rules": [
            {
              "required": true,
              "message": "Please enter a valid deployment type"
            }
          ],
          "placeholder": "Credential Type"
        }
      },
      "vcore": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "VCORE Deployment",
          "placeholder": "Credential Type",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "extra": {
            "type": "object",
            "ui": {
              "widget": "nested",
              "label": "",
              "header": "Advanced",
              "hidden": false
            },
            "properties": {
              "connection_strings": {
                "type": "object",
                "required": true,
                "ui": {
                  "widget": "inputRepeater",
                  "label": "Connection Strings",
                  "hidden": false,
                  "help": "List of connection strings for vCore deployments",
                  "placeholder": "Enter Connection String",
                  "grid": 8,
                  "rules": [
                    {
                      "required": true,
                      "message": "Please enter valid connection strings"
                    }
                  ]
                }
              }
            }
          }
        }
      },
