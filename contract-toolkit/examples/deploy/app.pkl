/// Single-pool deployment example — shows KEDA, resources, env, Dapr sidecars,
/// and per-pool overrides (VPA). Demonstrates the v0.17.0 API:
/// `deploy.dapr` for global sidecar toggles; `deploy.pools` for per-pool scaling.
///
/// For the multi-pool case, see the `pools` example.
amends "../../src/App.pkl"

name = "deploy"
displayName = "Deploy Config Example"
icon = "https://assets.atlan.com/assets/fullscreen-open.svg"
hasCredentialConfig = false

deploy = new DeployConfig {
  pools {
    ["default"] = new Pool {
      // KEDA: scale-to-zero based on Temporal task-queue depth.
      keda {
        enabled = true
        minReplicaCount = 0
        temporal {
          targetQueueSize = 10
        }
      }

      // Kubernetes resource requests and limits.
      resources = new ResourceConfig {
        requests {
          ["cpu"] = "500m"
          ["memory"] = "1Gi"
        }
        limits {
          ["cpu"] = "2"
          ["memory"] = "4Gi"
        }
      }

      // Static environment variables injected into the app container.
      env {
        ["LOG_LEVEL"] = "INFO"
        ["MAX_WORKERS"] = "4"
      }

      // Marketplace keys not yet modelled by Pool typed fields.
      // Deep-merged on top of the rendered pool block last.
      overrides {
        ["verticalPodAutoscaler"] = new Mapping {
          ["enabled"] = true
          ["updateMode"] = "Auto"
        }
      }
    }
  }
}

// ── Minimal workflow UI ───────────────────────────────────────────────────────

pipeline {
  publish = null
}

uiConfig = new UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["target"] = new TextInput {
          title = "Target"
          helpText = "What to process."
          placeholderText = "my-target"
        }
      }
    }
  }
}
