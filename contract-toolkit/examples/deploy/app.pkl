/// Single-pool deployment example — shows KEDA, resources, env, and per-pool
/// deployOverrides for marketplace keys (Dapr, VPA, etc.) not yet modelled
/// as typed fields on Pool.
///
/// For the multi-pool case, see the `pools` example.
amends "../../src/App.pkl"

name = "deploy"
displayName = "Deploy Config Example"
icon = "https://assets.atlan.com/assets/fullscreen-open.svg"
hasCredentialConfig = false

pools {
  ["default"] = new Pool {
    // KEDA: scale-to-zero based on Temporal task-queue depth.
    keda {
      enabled = true
      minReplicaCount = 1
      temporal {
        targetQueueSize = 10
      }
    }

    // Kubernetes resource requests and limits.
    resources = new ResourceConfig {
      requests {
        ["cpu"] = "500m"
        ["memory"] = "1Gi"
      }
      limits {
        ["cpu"] = "2"
        ["memory"] = "4Gi"
      }
    }

    // Static environment variables injected into the app container.
    env {
      ["LOG_LEVEL"] = "INFO"
      ["MAX_WORKERS"] = "4"
    }

    // Marketplace keys not yet modelled by Pool typed fields.
    // Deep-merged on top of the rendered deploy/pool block last.
    deployOverrides {
      ["dapr"] = new Mapping {
        ["objectstore"] = true
        ["secretstore"] = true
        ["statestore"] = false
        ["eventstore"] = false
        ["subscription"] = false
        ["configurationstore"] = false
        ["lock"] = false
      }
      ["verticalPodAutoscaler"] = new Mapping {
        ["enabled"] = true
        ["updateMode"] = "Auto"
      }
    }
  }
}

// ── Minimal workflow UI ───────────────────────────────────────────────────────

pipeline {
  publish = null
}

uiConfig = new UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["target"] = new TextInput {
          title = "Target"
          helpText = "What to process."
          placeholderText = "my-target"
        }
      }
    }
  }
}
