/// Deploy config example — demonstrates every deployment knob in App.pkl.
///
/// Shows KEDA autoscaling, Dapr sidecar components, resource requests/limits,
/// environment variables, and deployOverrides for marketplace keys the typed
/// block does not yet model.
amends "../../src/App.pkl"

name = "deploy"
displayName = "Deploy Config Example"
icon = "https://assets.atlan.com/assets/fullscreen-open.svg"
hasCredentialConfig = false

// ── Deployment configuration ──────────────────────────────────────────────────

deploy {
  // KEDA: scale-to-zero based on Temporal task-queue depth.
  // targetQueueSize must be set via temporal.targetQueueSize — NOT keda.targetQueueSize.
  keda {
    enabled = true
    minReplicaCount = 1
    temporal {
      targetQueueSize = 10
    }
  }

  // Dapr sidecars required by this app.
  dapr {
    objectstore = true
    secretstore = true
    statestore = false
    eventstore = false
    subscription = false
    configurationstore = false
    lock = false
  }

  // Kubernetes resource requests and limits.
  resources = new ResourceConfig {
    requests {
      ["cpu"] = "500m"
      ["memory"] = "1Gi"
    }
    limits {
      ["cpu"] = "2"
      ["memory"] = "4Gi"
    }
  }

  // Static environment variables injected into the app container.
  env {
    ["LOG_LEVEL"] = "INFO"
    ["MAX_WORKERS"] = "4"
  }
}

// Marketplace keys not yet modelled by the typed deploy block.
// Deep-merged on top of the rendered deploy section last.
deployOverrides {
  ["verticalPodAutoscaler"] = new Mapping {
    ["enabled"] = true
    ["updateMode"] = "Auto"
  }
}

// ── Minimal workflow UI ───────────────────────────────────────────────────────

pipeline {
  publish = null
}

uiConfig = new UIConfig {
  tasks {
    ["Configuration"] {
      inputs {
        ["target"] = new TextInput {
          title = "Target"
          helpText = "What to process."
          placeholderText = "my-target"
        }
      }
    }
  }
}
