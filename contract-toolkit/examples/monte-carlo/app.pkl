amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"
import "../../src/Connectors.pkl"

name = "monte-carlo"
displayName = "Monte Carlo"
connector = Connectors.MONTE_CARLO
// These apps use explicit name override in their Python code (v2 convention).
// The override prevents auto kebab-case conversion in the manifest.
workflowTypeOverride = "MonteCarloWorkflow"
icon = "https://assets.atlan.com/assets/monte-carlo.svg"
docsUrl = ""
credentialConnectorType = "rest"

// ---------------------------------------------------------------------------
// Credential config — FieldSpec-based
// ---------------------------------------------------------------------------

credentialCommonFields {
  new FieldSpec {
    name = "host"
    displayName = "Host"
    placeholder = "https://api.getmontecarlo.com"
    defaultValue = "https://api.getmontecarlo.com"
    required = false
    isHidden = true
    width = 6
  }
  new FieldSpec {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    placeholder = "443"
    defaultValue = "443"
    required = false
    isHidden = true
    width = 2
  }
}

credentialAuthOptions {
  ["api"] = new AuthOption {
    label = "API Key"
    fields {
      new FieldSpec {
        name = "username"
        displayName = "API Key ID"
        placeholder = "Enter your Monte Carlo API Key ID"
        width = 4
      }
      new FieldSpec {
        name = "password"
        sensitive = true
        displayName = "API Secret"
        placeholder = "Enter your Monte Carlo API Secret"
        width = 4
      }
    }
  }
}

// ---------------------------------------------------------------------------
// Workflow config — setup form
// ---------------------------------------------------------------------------

uiConfig {
  tasks {
    ["Credential"] {
      inputs {
        ["credential-guid"] = new Config.CredentialInput {
          title = ""
          credType = "atlan-connectors-monte-carlo"
          placeholderText = "Credential Guid"
        }
      }
    }
    ["Connection"] {
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = ""
          placeholderText = "Connection Name"
        }
      }
    }
    ["Metadata"] {
      inputs {
        ["include-filter"] = new Config.APITree {
          title = "Include Filter"
          desc = "Incidents and Monitors will be fetched from selected filter"
          credentialType = "atlan-connectors-monte-carlo"
          cred = "credential-guid"
          metadataTemplate = "accounts"
          metadataTransformer = "accounts"
          width = 4
        }
        ["exclude-filter"] = new Config.APITree {
          title = "Exclude Filter"
          desc = "Incidents and Monitors from selected filters will be ignored"
          credentialType = "atlan-connectors-monte-carlo"
          cred = "credential-guid"
          metadataTemplate = "accounts"
          metadataTransformer = "accounts"
          width = 4
        }
        ["include-incident-feedback-status"] = new Config.APITree {
          title = "Include Incident Statuses"
          desc = "Incidents having selected feedback statuses will be fetched. No Status will fetch Incidents without any status."
          credentialType = "atlan-connectors-monte-carlo"
          cred = "credential-guid"
          metadataTemplate = "feedbacks"
          metadataTransformer = "feedbacks"
          width = 4
        }
        ["incident-days-filter"] = new Config.DropDown {
          title = "Incidents and Alerts time range"
          helpText = "Select how far back you want to sync Incidents and Alerts from Monte Carlo"
          placeholderText = "Select how many past days to fetch incidents for"
          possibleValues {
            ["14"] = "Last 14 Days"
            ["30"] = "Last 30 Days"
            ["45"] = "Last 45 Days"
          }
          default = "30"
          width = 4
        }
        ["advanced-config-strategy"] = new Config.Radio {
          title = "Advanced Config"
          helpText = "Include specific SQL connections you want to enrich with monte carlo metadata"
          possibleValues {
            ["default"] = "Default"
            ["custom"] = "Custom"
          }
          default = "default"
          required = true
        }
        ["asset-connection-qualified-names"] = new Config.ConnectionSelector {
          title = "Include connections"
          helpText = "Atlan will only enrich Monte Carlo metadata for the selected connections, this is helpful when you have similar assets in dev or prod connection and only want to enrich one of those connection."
          multiSelect = true
          connectionCategories = "['warehouse', 'database', 'lake']"
          placeholderText = "Select connections to map your alerts and monitors"
          width = 4
        }
        ["preflight-check"] = new Config.Sage {
          title = ""
          checks {
            new Dynamic {
              id = 1
              name = "loginCheck"
              extraUrlParam = ""
              optional = false
              title = "Login"
              loaderText = "Checking API credentials"
            }
          }
        }
      }
    }
  }
  rules {
    new Config.UIRule {
      whenInputs { ["advanced-config-strategy"] = "custom" }
      required { "asset-connection-qualified-names" }
    }
  }
}
