amends "../../src/NativeApp.pkl"

import "../../src/Config.pkl"
import "../../src/Connectors.pkl"

local schemaQuery = "SELECT 'default' AS TABLE_CATALOG, name AS TABLE_SCHEMA FROM system.databases WHERE name NOT IN ('system', 'information_schema', 'INFORMATION_SCHEMA') ORDER BY name"
local systemSchemas = List("system", "information_schema", "INFORMATION_SCHEMA")

name = "clickhouse"
displayName = "ClickHouse"
connector = Connectors.CLICKHOUSE
workflowTypeOverride = "SQLMetadataExtractionWorkflow"
icon = "https://upload.wikimedia.org/wikipedia/commons/0/0e/Clickhouse.png"
logo = icon
credentialConnectorType = "jdbc"

credentialCommonFields {
  new FieldSpec {
    name = "host"
    displayName = "Host Name"
    helpText = "Your ClickHouse instance host name"
    placeholder = "clickhouse.example.com"
    width = 6
    feedback = true
    byocDisabled = true
    validationRules {
      new Dynamic { required = true; message = "Please enter a valid host name" }
    }
  }
  new FieldSpec {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    placeholder = "Port"
    width = 2
  }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic"
    fields {
      new FieldSpec {
        name = "username"
        displayName = "Username"
        placeholder = "Username"
        defaultValue = ""
        width = 4
        feedback = true
        message = "Please enter a valid username"
        validationRules {
          new Dynamic { required = true; message = "Please enter a valid username" }
        }
      }
      new FieldSpec {
        name = "password"
        displayName = "Password"
        placeholder = "Password"
        sensitive = true
        width = 4
        feedback = true
        validationRules {
          new Dynamic { required = true; message = "Please enter a valid password" }
        }
      }
    }
  }
}

uiConfig {
  tasks {
    ["Credential"] {
      description = "Credential Details"
      inputs {
        ["credential-guid"] = new Config.CredentialInput {
          title = ""
          credType = "atlan-connectors-clickhouse"
          placeholderText = "Credential Guid"
          required = true
        }
      }
    }
    ["Connection"] {
      description = "Connection Details"
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = ""
          placeholderText = "Connection Name"
          required = true
        }
      }
    }
    ["Metadata"] {
      description = "Metadata Selection"
      inputs {
        ["include-filter"] = new Config.SqlTree {
          title = "Include Metadata"
          helpText = "Only the selected databases and schemas will be extracted. Exclude gets preference over include for common databases and schemas, if present, in the config."
          sqlQuery = schemaQuery
          credentialType = "atlan-connectors-clickhouse"
          cred = "credential-guid"
          excludePatterns = systemSchemas
          width = 4
        }
        ["exclude-filter"] = new Config.SqlTree {
          title = "Exclude Metadata"
          helpText = "Selected databases and schemas won't be extracted."
          sqlQuery = schemaQuery
          credentialType = "atlan-connectors-clickhouse"
          cred = "credential-guid"
          excludePatterns = systemSchemas
          width = 4
        }
        ["temp-table-regex"] = new Config.TextInput {
          title = "Exclude regex for tables & views"
          helpText = "Regex of tables & views to ignore. Defaults to empty string"
          placeholderText = ".*_TMP|.*_TEMP|TMP.*|TEMP.*"
          defaultValue = ""
          required = false
          width = 4
          feedbackEnabled = true
        }
        ["preflight-check"] = new Config.Sage {
          title = ""
          checks {
            new Dynamic { id = 1; name = "connectionTest"; extraUrlParam = ""; optional = false; title = "Connection Test"; loaderText = "Testing basic connection with SELECT 1" }
            new Dynamic { id = 2; name = "systemTablesAccess"; extraUrlParam = ""; optional = false; title = "System Tables Access"; loaderText = "Checking system.tables access permissions" }
            new Dynamic { id = 3; name = "databaseAccess"; extraUrlParam = ""; optional = false; title = "Database Access"; loaderText = "Checking system.databases access permissions" }
            new Dynamic { id = 4; name = "columnMetadataAccess"; extraUrlParam = ""; optional = false; title = "Column Metadata Access"; loaderText = "Checking system.columns access permissions" }
          }
        }
      }
    }
  }
}
