{
  "icon": "https://upload.wikimedia.org/wikipedia/commons/0/0e/Clickhouse.png",
  "helpdeskLink": "",
  "logo": "https://upload.wikimedia.org/wikipedia/commons/0/0e/Clickhouse.png",
  "connector": "clickhouse",
  "defaultConnectorType": "jdbc",
  "config": {
    "properties": {
      "name": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Name",
          "hidden": true,
          "placeholder": "Host Name"
        }
      },
      "connector": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Connector",
          "hidden": true,
          "placeholder": "Connector"
        }
      },
      "connectorType": {
        "type": "string",
        "required": false,
        "ui": {
          "key": "_host",
          "label": "connectorType",
          "placeholder": "connectorType",
          "hidden": true
        }
      },
      "host": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "input",
          "label": "Host Name",
          "hidden": false,
          "help": "Your ClickHouse instance host name",
          "placeholder": "clickhouse.example.com",
          "grid": 6,
          "feedback": true,
          "BYOCdisabled": true,
          "rules": [
            {
              "required": true,
              "message": "Please enter a valid host name"
            }
          ]
        }
      },
      "port": {
        "type": "number",
        "required": true,
        "ui": {
          "widget": "inputNumber",
          "label": "Port",
          "hidden": false,
          "placeholder": "Port",
          "grid": 2
        }
      },
      "auth-type": {
        "type": "string",
        "enum": [
          "basic"
        ],
        "default": "basic",
        "required": true,
        "enumNames": [
          "Basic"
        ],
        "ui": {
          "widget": "radio",
          "hidden": false,
          "label": "Authentication"
        }
      },
      "basic": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "username": {
            "type": "string",
            "required": true,
            "default": "",
            "ui": {
              "widget": "input",
              "label": "Username",
              "hidden": false,
              "placeholder": "Username",
              "grid": 4,
              "feedback": true,
              "message": "Please enter a valid username",
              "rules": [
                {
                  "required": true,
                  "message": "Please enter a valid username"
                }
              ]
            }
          },
          "password": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "password",
              "label": "Password",
              "hidden": false,
              "placeholder": "Password",
              "grid": 4,
              "feedback": true,
              "rules": [
                {
                  "required": true,
                  "message": "Please enter a valid password"
                }
              ]
            }
          }
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "auth-type": {
            "const": "basic"
          }
        },
        "required": [
          "basic"
        ]
      }
    ]
  }
}
