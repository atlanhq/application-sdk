{
  "id": "clickhouse",
  "name": "ClickHouse",
  "logo": "https://upload.wikimedia.org/wikipedia/commons/0/0e/Clickhouse.png",
  "config": {
    "properties": {
      "credential-guid": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "credential",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Credential Guid",
          "grid": 8,
          "credentialType": "atlan-connectors-clickhouse",
          "isTestAuthenticationDisabled": false
        }
      },
      "connection": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "connection",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Connection Name",
          "grid": 8
        }
      },
      "include-filter": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "sqltree",
          "label": "Include Metadata",
          "hidden": false,
          "help": "Only the selected databases and schemas will be extracted. Exclude gets preference over include for common databases and schemas, if present, in the config.",
          "grid": 4,
          "connectorConfigName": "atlan-connectors-clickhouse",
          "credential": "credential-guid",
          "sql": "SELECT 'default' AS TABLE_CATALOG, name AS TABLE_SCHEMA FROM system.databases WHERE name NOT IN ('system', 'information_schema', 'INFORMATION_SCHEMA') ORDER BY name",
          "schemaExcludePattern": [
            "system",
            "information_schema",
            "INFORMATION_SCHEMA"
          ]
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}"
      },
      "exclude-filter": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "sqltree",
          "label": "Exclude Metadata",
          "hidden": false,
          "help": "Selected databases and schemas won't be extracted.",
          "grid": 4,
          "connectorConfigName": "atlan-connectors-clickhouse",
          "credential": "credential-guid",
          "sql": "SELECT 'default' AS TABLE_CATALOG, name AS TABLE_SCHEMA FROM system.databases WHERE name NOT IN ('system', 'information_schema', 'INFORMATION_SCHEMA') ORDER BY name",
          "schemaExcludePattern": [
            "system",
            "information_schema",
            "INFORMATION_SCHEMA"
          ]
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}"
      },
      "temp-table-regex": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "input",
          "label": "Exclude regex for tables & views",
          "hidden": false,
          "help": "Regex of tables & views to ignore. Defaults to empty string",
          "placeholder": ".*_TMP|.*_TEMP|TMP.*|TEMP.*",
          "grid": 4,
          "feedback": true
        },
        "default": ""
      },
      "preflight-check": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "sage",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8,
          "config": [
            {
              "id": 1,
              "name": "connectionTest",
              "extraUrlParam": "",
              "optional": false,
              "title": "Connection Test",
              "loaderText": "Testing basic connection with SELECT 1"
            },
            {
              "id": 2,
              "name": "systemTablesAccess",
              "extraUrlParam": "",
              "optional": false,
              "title": "System Tables Access",
              "loaderText": "Checking system.tables access permissions"
            },
            {
              "id": 3,
              "name": "databaseAccess",
              "extraUrlParam": "",
              "optional": false,
              "title": "Database Access",
              "loaderText": "Checking system.databases access permissions"
            },
            {
              "id": 4,
              "name": "columnMetadataAccess",
              "extraUrlParam": "",
              "optional": false,
              "title": "Column Metadata Access",
              "loaderText": "Checking system.columns access permissions"
            }
          ]
        }
      }
    },
    "steps": [
      {
        "title": "Credential",
        "description": "Credential Details",
        "id": "credential",
        "properties": [
          "credential-guid"
        ]
      },
      {
        "title": "Connection",
        "description": "Connection Details",
        "id": "connection",
        "properties": [
          "connection"
        ]
      },
      {
        "title": "Metadata",
        "description": "Metadata Selection",
        "id": "metadata",
        "properties": [
          "include-filter",
          "exclude-filter",
          "temp-table-regex",
          "preflight-check"
        ]
      }
    ]
  }
}
