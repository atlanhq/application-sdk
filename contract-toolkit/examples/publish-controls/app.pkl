/// Minimal example demonstrating publish input opt-out, publish executor
/// templating, compact activity labels, and workflow-safe error handling for
/// toolkit-managed extract/publish nodes.
///
/// The app keeps the standard extract -> publish DAG, suppresses toolkit
/// scaffolding fields from _input.py, and declares its own load-to-atlan UI
/// toggle that flows to the publish node's executor_enabled argument.
amends "../../src/App.pkl"

import "../../src/Connectors.pkl"

name = "publish-controls"
displayName = "Publish Controls Example"
connector = Connectors.TRINO
icon = "https://assets.atlan.com/assets/trino.svg"
credentialConnectorType = "jdbc"

pipeline {
  extract {
    displayName = "Extract"
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 14400
    }
  }
  publish {
    includeInputFields = false
    executorEnabled = "{{load-to-atlan}}"
    displayName = "Publish"
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 14400
    }
  }
}

credentialCommonFields {
  new FieldSpec { name = "host"; displayName = "Host"; width = 6 }
  new FieldSpec {
    name = "enable_ssl"
    displayName = "Enable SSL"
    fieldType = "checkbox"
    defaultValue = "true"
    required = false
    width = 4
  }
  // Conditionally required via credentialExtraAnyOfRules below — kept
  // required:false at the field level so the rule drives both its requiredness
  // and its visibility.
  new FieldSpec {
    name = "ssl_cert"
    displayName = "SSL Certificate"
    fieldType = "textarea"
    required = false
    helpText = "PEM-encoded certificate. Required when SSL is enabled."
    width = 8
  }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic"
    fields {
      new FieldSpec { name = "username"; displayName = "Username"; width = 4 }
      new FieldSpec { name = "password"; sensitive = true; displayName = "Password"; width = 4 }
    }
  }
}

// Conditional credential requirement keyed on an input other than `auth-type`.
// `AuthOption.anyOfRequiredFields` can only key off the auth-type radio, so a
// requirement driven by the `enable_ssl` checkbox is supplied as an extra
// anyOf rule. (The frontend coerces both sides to strings, so the boolean
// checkbox value matches the `"true"` const.)
credentialExtraAnyOfRules {
  new UIRule {
    whenInputs { ["enable_ssl"] = "true" }
    required { "ssl_cert" }
  }
}

uiConfig = new UIConfig {
  tasks {
    ["Credential"] {
      inputs {
        ["extraction-method"] = new TextInput {
          title = "Extraction method"
          defaultValue = "direct"
          hide = true
        }
        ["credential-guid"] = new CredentialInput {
          credType = "atlan-connectors-publish-controls"
        }
      }
    }
    ["Connection"] {
      inputs {
        ["connection"] = new ConnectionCreator {
          placeholderText = "Connection Name"
        }
        ["load-to-atlan"] = new BooleanInput {
          title = "Load to Atlan"
          defaultSelection = true
          width = 4
        }
      }
    }
  }
}
