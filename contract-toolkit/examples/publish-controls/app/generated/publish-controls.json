{
  "id": "publish-controls",
  "name": "Publish Controls Example",
  "logo": "https://assets.atlan.com/assets/trino.svg",
  "config": {
    "properties": {
      "extraction-method": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "input",
          "label": "Extraction method",
          "hidden": true,
          "help": "",
          "placeholder": "",
          "grid": 8
        },
        "default": "direct"
      },
      "credential-guid": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "credential",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8,
          "credentialType": "atlan-connectors-publish-controls",
          "isTestAuthenticationDisabled": false
        }
      },
      "connection": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "connection",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Connection Name",
          "grid": 8
        }
      },
      "load-to-atlan": {
        "type": "boolean",
        "required": false,
        "ui": {
          "widget": "boolean",
          "label": "Load to Atlan",
          "hidden": false,
          "help": "",
          "grid": 4
        },
        "default": true
      }
    },
    "steps": [
      {
        "title": "Credential",
        "description": "",
        "id": "credential",
        "properties": [
          "extraction-method",
          "credential-guid"
        ]
      },
      {
        "title": "Connection",
        "description": "",
        "id": "connection",
        "properties": [
          "connection",
          "load-to-atlan"
        ]
      }
    ]
  }
}
