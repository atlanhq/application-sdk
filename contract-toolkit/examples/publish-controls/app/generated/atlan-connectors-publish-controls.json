{
  "icon": "https://assets.atlan.com/assets/trino.svg",
  "helpdeskLink": "",
  "logo": "https://assets.atlan.com/assets/trino.svg",
  "connector": "trino",
  "defaultConnectorType": "jdbc",
  "config": {
    "properties": {
      "name": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Name",
          "hidden": true,
          "placeholder": "Host Name"
        }
      },
      "connector": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Connector",
          "hidden": true,
          "placeholder": "Connector"
        }
      },
      "connectorType": {
        "type": "string",
        "required": false,
        "ui": {
          "key": "_host",
          "label": "connectorType",
          "placeholder": "connectorType",
          "hidden": true
        }
      },
      "host": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "input",
          "label": "Host",
          "hidden": false,
          "grid": 6
        }
      },
      "enable_ssl": {
        "type": "boolean",
        "default": true,
        "ui": {
          "widget": "checkbox",
          "label": "Enable SSL",
          "hidden": false,
          "grid": 4
        }
      },
      "ssl_cert": {
        "type": "string",
        "ui": {
          "widget": "TextInput",
          "label": "SSL Certificate",
          "hidden": false,
          "help": "PEM-encoded certificate. Required when SSL is enabled.",
          "grid": 8
        }
      },
      "auth-type": {
        "type": "string",
        "enum": [
          "basic"
        ],
        "default": "basic",
        "required": true,
        "enumNames": [
          "Basic"
        ],
        "ui": {
          "widget": "radio",
          "hidden": true,
          "label": "Authentication"
        }
      },
      "basic": {
        "type": "object",
        "ui": {
          "widget": "nested",
          "label": "",
          "hidden": true,
          "nestedValue": false
        },
        "properties": {
          "username": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "input",
              "label": "Username",
              "hidden": false,
              "grid": 4
            }
          },
          "password": {
            "type": "string",
            "required": true,
            "ui": {
              "widget": "password",
              "label": "Password",
              "hidden": false,
              "grid": 4
            }
          }
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "auth-type": {
            "const": "basic"
          }
        },
        "required": [
          "basic"
        ]
      },
      {
        "properties": {
          "enable_ssl": {
            "const": "true"
          }
        },
        "required": [
          "ssl_cert"
        ]
      }
    ]
  }
}
