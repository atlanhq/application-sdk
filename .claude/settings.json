{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "uv run pre-commit run",
            "statusMessage": "Running pre-commit checks..."
          }
        ]
      }
    ]
  }
}
