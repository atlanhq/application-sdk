        </mxCell>

        <!-- 6. transformers/ -->
        <mxCell id="f_transform" value="&lt;font color=&quot;#6A1B9A&quot; style=&quot;font-size:9px;&quot;&gt;transformers/&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;Transformers&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#555&quot; style=&quot;font-size:10px;&quot;&gt;Converts raw metadata&lt;br&gt;into Atlas entities&lt;br&gt;(Atlan&amp;rsquo;s format).&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;atlas/ &amp;middot; query/ &amp;middot; common/&lt;/font&gt;&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AB47BC;strokeWidth=2;shadow=1;" vertex="1" parent="1">
