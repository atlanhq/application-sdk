        <!-- MAIN FLOW (top row, left to right)                                    -->
        <!-- ==================================================================== -->

        <!-- ATLAN PLATFORM (start) -->
        <mxCell id="atlan_s" value="&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;Atlan Platform&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot; style=&quot;font-size:10px;&quot;&gt;Sends HTTP request&lt;br&gt;to start a workflow&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#64B5F6;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="145" height="85" as="geometry" />
        </mxCell>

        <!-- 1. server/ -->
        <mxCell id="f_server" value="&lt;font color=&quot;#1565C0&quot; style=&quot;font-size:9px;&quot;&gt;server/&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;HTTP Server&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#555&quot; style=&quot;font-size:10px;&quot;&gt;FastAPI app.&lt;br&gt;Routes requests to&lt;br&gt;handler endpoints.&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;fastapi/ &amp;middot; mcp/ &amp;middot; middleware/&lt;/font&gt;&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#64B5F6;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="130" width="175" height="150" as="geometry" />
        </mxCell>

        <!-- 2. handler/ -->
        <mxCell id="f_handler" value="&lt;font color=&quot;#1565C0&quot; style=&quot;font-size:9px;&quot;&gt;handler/&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;Request Handler&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#555&quot; style=&quot;font-size:10px;&quot;&gt;Processes auth checks,&lt;br&gt;preflight validation,&lt;br&gt;and metadata queries.&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;You subclass this.&lt;/font&gt;&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#64B5F6;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="130" width="175" height="150" as="geometry" />
        </mxCell>

        <!-- 3. app/ -->
        <mxCell id="f_app" value="&lt;font color=&quot;#2E7D32&quot; style=&quot;font-size:9px;&quot;&gt;app/&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;App (Core)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#555&quot; style=&quot;font-size:10px;&quot;&gt;Base class you extend.&lt;br&gt;Defines the workflow:&lt;br&gt;which @tasks run&lt;br&gt;and in what order.&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;context &amp;middot; registry &amp;middot; @task&lt;/font&gt;&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#66BB6A;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="130" width="175" height="155" as="geometry" />
        </mxCell>

        <!-- 4. execution/ -->
        <mxCell id="f_exec" value="&lt;font color=&quot;#2E7D32&quot; style=&quot;font-size:9px;&quot;&gt;execution/&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;Temporal Engine&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#555&quot; style=&quot;font-size:10px;&quot;&gt;Runs workflows &amp;amp;&lt;br&gt;activities on Temporal.&lt;br&gt;Crash recovery, retries,&lt;br&gt;heartbeats built in.&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;worker &amp;middot; interceptors &amp;middot; retry&lt;/font&gt;&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#66BB6A;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="130" width="175" height="155" as="geometry" />
        </mxCell>

        <!-- 5. clients/ -->
        <mxCell id="f_clients" value="&lt;font color=&quot;#6A1B9A&quot; style=&quot;font-size:9px;&quot;&gt;clients/&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;font-size:13px;color:#1B2138;&quot;&gt;Source Clients&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#555&quot; style=&quot;font-size:10px;&quot;&gt;Connects to external&lt;br&gt;data sources. SQL,&lt;br&gt;REST, Azure, Redis.&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;auth_strategies/ &amp;middot; sql &amp;middot; azure/&lt;/font&gt;&lt;/font&gt;" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AB47BC;strokeWidth=2;shadow=1;" vertex="1" parent="1">
