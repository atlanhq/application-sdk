{
    "config": {
        "properties": {
            "name": {
                "type": "string",
                "required": false,
                "ui": {
                    "label": "Trainer Name",
                    "hidden": true,
                    "placeholder": "Pokemon Trainer"
                }
            },
            "connector": {
                "type": "string",
                "required": false,
                "ui": {
                    "label": "Pokeball Type",
                    "hidden": true,
                    "placeholder": "Pokeball"
                }
            },
            "connectorType": {
                "type": "string",
                "required": false,
                "ui": {
                    "key": "_region",
                    "label": "Pokemon Region",
                    "placeholder": "Kanto Region",
                    "hidden": true
                }
            },
            "host": {
                "type": "string",
                "required": true,
                "default": "",
                "ui": {
                    "label": "Pokemon Center Location",
                    "help": "Main Pokemon Center in your region",
                    "feedback": true,
                    "placeholder": "cerulean-city.kanto.pokemon-center.com",
                    "BYOCdisabled": true,
                    "rules": [
                        {
                            "required": true,
                            "message": "Please enter a valid Pokemon Center location"
                        }
                    ],
                    "grid": 6
                }
            },
            "port": {
                "type": "number",
                "default": 151,
                "required": true,
                "ui": {
                    "label": "Pokedex Number",
                    "placeholder": "151",
                    "disabled": false,
                    "grid": 2,
                    "BYOCdisabled": true,
                    "rules": [
                        {
                            "required": true,
                            "message": "Please enter a valid Pokedex number"
                        }
                    ]
                }
            },
            "auth-type": {
                "type": "string",
                "enum": ["trainer", "gym-leader", "elite-four"],
                "default": "trainer",
                "required": true,
                "enumNames": ["Pokemon Trainer", "Gym Leader", "Elite Four"],
                "ui": {
                    "widget": "radio",
                    "hidden": false,
                    "label": "Trainer Level",
                    "placeholder": "Choose your trainer level",
                    "rules": [
                        {
                            "required": true,
                            "message": "Please select a valid trainer level"
                        }
                    ]
                }
            },
            "trainer": {
                "type": "object",
                "properties": {
                    "username": {
                        "type": "string",
                        "required": true,
                        "ui": {
                            "label": "Trainer ID",
                            "placeholder": "ASH001",
                            "help": "Your Pokemon Trainer ID",
                            "feedback": true,
                            "message": "Please enter a valid Trainer ID",
                            "grid": 4,
                            "rules": [
                                {
                                    "required": true,
                                    "message": "Please enter a valid Trainer ID"
                                }
                            ]
                        }
                    },
                    "password": {
                        "type": "string",
                        "required": true,
                        "ui": {
                            "widget": "password",
                            "label": "Secret Pokemon Name",
                            "feedback": true,
                            "placeholder": "Pikachu",
                            "grid": 4,
                            "rules": [
                                {
                                    "required": true,
                                    "message": "Please enter your secret Pokemon name"
                                }
                            ]
                        }
                    },
                    "extra": {
                        "type": "object",
                        "properties": {
                            "deployment_type": {
                                "type": "string",
                                "enum": ["wild", "captured"],
                                "default": "captured",
                                "required": true,
                                "enumNames": [
                                    "Wild Pokemon",
                                    "Captured Pokemon"
                                ],
                                "ui": {
                                    "widget": "radio",
                                    "hidden": false,
                                    "label": "Pokemon Status",
                                    "help": "Are these wild or captured Pokemon?",
                                    "placeholder": "Pokemon Status",
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please select a valid Pokemon status"
                                        }
                                    ]
                                }
                            },
                            "database": {
                                "type": "string",
                                "required": true,
                                "ui": {
                                    "label": "Pokedex Version",
                                    "help": "Which Pokedex version to access",
                                    "placeholder": "national",
                                    "grid": 4,
                                    "feedback": true,
                                    "message": "Please enter a valid Pokedex version",
                                    "BYOCdisabled": true,
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please enter a valid Pokedex version"
                                        }
                                    ]
                                }
                            }
                        },
                        "ui": {
                            "widget": "nested",
                            "label": "",
                            "header": "Advanced Pokemon Settings",
                            "hidden": false
                        }
                    }
                },
                "ui": {
                    "widget": "nested",
                    "label": "",
                    "placeholder": "Trainer Level",
                    "nestedValue": false,
                    "hidden": true
                }
            },
            "gym-leader": {
                "type": "object",
                "properties": {
                    "username": {
                        "type": "string",
                        "required": true,
                        "ui": {
                            "label": "Gym Badge ID",
                            "placeholder": "BOULDER_BADGE",
                            "help": "Your Gym Leader Badge ID",
                            "feedback": true,
                            "message": "Please enter a valid Badge ID",
                            "grid": 4,
                            "rules": [
                                {
                                    "required": true,
                                    "message": "Please enter a valid Badge ID"
                                }
                            ]
                        }
                    },
                    "password": {
                        "type": "string",
                        "required": true,
                        "ui": {
                            "widget": "password",
                            "label": "Gym Secret Key",
                            "help": "Your Gym's secret access key",
                            "feedback": true,
                            "placeholder": "OnixRockSolid",
                            "grid": 4,
                            "rules": [
                                {
                                    "required": true,
                                    "message": "Please enter a valid Gym secret key"
                                }
                            ]
                        }
                    },
                    "extra": {
                        "type": "object",
                        "properties": {
                            "dbuser": {
                                "type": "string",
                                "required": true,
                                "ui": {
                                    "label": "Gym Leader Name",
                                    "placeholder": "Brock",
                                    "help": "The Gym Leader's name",
                                    "feedback": true,
                                    "message": "Please enter a valid Gym Leader name",
                                    "grid": 4,
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please enter a valid Gym Leader name"
                                        }
                                    ]
                                }
                            },
                            "cluster_id": {
                                "type": "string",
                                "required": false,
                                "ui": {
                                    "label": "Gym ID",
                                    "placeholder": "pewter-gym",
                                    "help": "Gym identifier for private gyms only",
                                    "grid": 4,
                                    "rules": []
                                }
                            },
                            "deployment_type": {
                                "type": "string",
                                "enum": ["wild", "captured"],
                                "default": "captured",
                                "required": true,
                                "enumNames": [
                                    "Wild Pokemon",
                                    "Captured Pokemon"
                                ],
                                "ui": {
                                    "widget": "radio",
                                    "hidden": false,
                                    "label": "Pokemon Status",
                                    "help": "Are these wild or captured Pokemon?",
                                    "placeholder": "Pokemon Status",
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please select a valid Pokemon status"
                                        }
                                    ]
                                }
                            },
                            "database": {
                                "type": "string",
                                "required": true,
                                "ui": {
                                    "label": "Pokedex Version",
                                    "help": "Which Pokedex version to access",
                                    "placeholder": "national",
                                    "grid": 4,
                                    "feedback": true,
                                    "message": "Please enter a valid Pokedex version",
                                    "BYOCdisabled": true,
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please enter a valid Pokedex version"
                                        }
                                    ]
                                }
                            }
                        },
                        "ui": {
                            "widget": "nested",
                            "label": "",
                            "header": "Advanced Pokemon Settings",
                            "hidden": false
                        }
                    }
                },
                "ui": {
                    "widget": "nested",
                    "label": "",
                    "placeholder": "Trainer Level",
                    "nestedValue": false,
                    "hidden": true
                }
            },
            "elite-four": {
                "type": "object",
                "properties": {
                    "extra": {
                        "type": "object",
                        "properties": {
                            "dbuser": {
                                "type": "string",
                                "required": true,
                                "ui": {
                                    "label": "Elite Four Member",
                                    "placeholder": "Lance",
                                    "help": "Elite Four member name",
                                    "feedback": true,
                                    "message": "Please enter a valid Elite Four member name",
                                    "grid": 4,
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please enter a valid Elite Four member name"
                                        }
                                    ]
                                }
                            },
                            "aws_role_arn": {
                                "type": "string",
                                "required": false,
                                "ui": {
                                    "label": "Champion Role ARN",
                                    "hidden": false,
                                    "placeholder": "arn:pokemon:champion::123456789012:role/PokemonMaster",
                                    "help": "Pokemon Champion role to assume",
                                    "grid": 4,
                                    "rules": [
                                        {
                                            "pattern": "^arn:pokemon:champion::\\d{12}:role/.+",
                                            "message": "Please enter a valid Champion role ARN",
                                            "trigger": "blur"
                                        }
                                    ]
                                }
                            },
                            "region_name": {
                                "type": "string",
                                "required": false,
                                "ui": {
                                    "label": "Pokemon Region",
                                    "hidden": false,
                                    "placeholder": "kanto",
                                    "help": "Pokemon region (Kanto, Johto, Hoenn, etc.)",
                                    "grid": 4,
                                    "rules": [
                                        {
                                            "required": false,
                                            "message": "Please enter a valid Pokemon region"
                                        }
                                    ]
                                }
                            },
                            "cluster_id": {
                                "type": "string",
                                "required": false,
                                "ui": {
                                    "label": "Elite Four Chamber ID",
                                    "placeholder": "indigo-plateau",
                                    "help": "Elite Four chamber identifier for private access",
                                    "grid": 4,
                                    "rules": []
                                }
                            },
                            "aws_external_id": {
                                "type": "string",
                                "required": false,
                                "ui": {
                                    "label": "Pokemon League ID",
                                    "hidden": false,
                                    "placeholder": "12345678-PKMN-LEAGUE-1234",
                                    "help": "Pokemon League External ID",
                                    "grid": 4,
                                    "rules": [
                                        {
                                            "message": "Please enter a valid League ID",
                                            "trigger": "blur"
                                        }
                                    ]
                                }
                            },
                            "deployment_type": {
                                "type": "string",
                                "enum": ["wild", "captured"],
                                "default": "captured",
                                "required": true,
                                "enumNames": [
                                    "Wild Pokemon",
                                    "Captured Pokemon"
                                ],
                                "ui": {
                                    "widget": "radio",
                                    "hidden": false,
                                    "label": "Pokemon Status",
                                    "help": "Are these wild or captured Pokemon?",
                                    "placeholder": "Pokemon Status",
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please select a valid Pokemon status"
                                        }
                                    ]
                                }
                            },
                            "database": {
                                "type": "string",
                                "required": true,
                                "ui": {
                                    "label": "Pokedex Version",
                                    "help": "Which Pokedex version to access",
                                    "placeholder": "national",
                                    "grid": 4,
                                    "feedback": true,
                                    "message": "Please enter a valid Pokedex version",
                                    "BYOCdisabled": true,
                                    "rules": [
                                        {
                                            "required": true,
                                            "message": "Please enter a valid Pokedex version"
                                        }
                                    ]
                                }
                            }
                        },
                        "ui": {
                            "widget": "nested",
                            "label": "",
                            "header": "Advanced Pokemon Settings",
                            "hidden": false
                        }
                    }
                },
                "ui": {
                    "widget": "nested",
                    "label": "",
                    "placeholder": "Trainer Level",
                    "nestedValue": false,
                    "hidden": true
                }
            }
        },
        "anyOf": [
            {
                "properties": {
                    "auth-type": {
                        "const": "trainer"
                    }
                },
                "required": ["trainer"]
            },
            {
                "properties": {
                    "auth-type": {
                        "const": "gym-leader"
                    }
                },
                "required": ["gym-leader"]
            },
            {
                "properties": {
                    "auth-type": {
                        "const": "elite-four"
                    }
                },
                "required": ["elite-four"]
            }
        ]
    }
}
