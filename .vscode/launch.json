{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Python: Run Unit Tests",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/.venv/bin/pytest",
        "args": [
          "--capture=no",
          "--log-cli-level=INFO",
          "tests/unit",
          "-v"
        ],
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      }
    ]
}